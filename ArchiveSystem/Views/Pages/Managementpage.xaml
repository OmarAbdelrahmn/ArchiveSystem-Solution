<Page x:Class="ArchiveSystem.Views.Pages.ManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="الإدارة"
      Background="#F5F5F5"
      FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="White"
                BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="🏢  الإدارة"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#1a7a60"
                           VerticalAlignment="Center"/>

                <Button x:Name="AddRootManagementBtn"
                        Grid.Column="1"
                        Content="➕ إدارة رئيسية"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#1a7a60" Foreground="White"
                        Height="36" Margin="0,0,8,0"
                        Click="AddRootManagement_Click"/>

                <Button x:Name="AddSubManagementBtn"
                        Grid.Column="2"
                        Content="➕ إدارة فرعية"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Height="36" Margin="0,0,8,0"
                        IsEnabled="False"
                        Click="AddSubManagement_Click"/>

                <Button x:Name="EditManagementBtn"
                        Grid.Column="3"
                        Content="✏️ تعديل الإدارة"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Height="36"
                        IsEnabled="False"
                        Click="EditManagement_Click"/>
            </Grid>
        </Border>

        <!-- ══ MAIN CONTENT ══════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: Management Tree ─────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderThickness="0,0,1,0"
                    BorderBrush="#E0E0E0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#F0F7F4"
                            BorderThickness="0,0,0,1" BorderBrush="#C8E6C9"
                            Padding="14,10">
                        <TextBlock Text="قائمة الإدارات"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#1a7a60"/>
                    </Border>

                    <ListBox Grid.Row="1"
                             x:Name="ManagementsList"
                             BorderThickness="0"
                             Background="Transparent"
                             VirtualizingPanel.IsVirtualizing="True"
                             SelectionChanged="ManagementsList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4,3">
                                    <TextBlock FontSize="13" FontWeight="SemiBold"
                                               Foreground="#222">
                                        <Run Text="{Binding DisplayName}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" Foreground="#888"
                                               Margin="4,1,0,0">
                                        <Run Text="{Binding DossierCount}"/>
                                        <Run Text=" دوسية"/>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="10,6"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ParentManagementId}" Value="{x:Null}">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Background" Value="#F9FFFE"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <!-- Delete management button at the bottom -->
                    <Border Grid.Row="2"
                            BorderThickness="0,1,0,0" BorderBrush="#EEEEEE"
                            Padding="10,8">
                        <Button x:Name="DeleteManagementBtn"
                                Content="🗑 حذف الإدارة المحددة"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="#C62828"
                                Height="32"
                                IsEnabled="False"
                                HorizontalAlignment="Stretch"
                                Click="DeleteManagement_Click"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ── RIGHT: Dossiers Area ────────────────────────────────── -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Management info bar -->
                    <RowDefinition Height="Auto"/>
                    <!-- Types + dossier actions bar -->
                    <RowDefinition Height="Auto"/>
                    <!-- Filters bar -->
                    <RowDefinition Height="Auto"/>
                    <!-- Result count -->
                    <RowDefinition Height="*"/>
                    <!-- DataGrid -->
                </Grid.RowDefinitions>

                <!-- Management info bar -->
                <Border Grid.Row="0"
                        x:Name="ManagementInfoBar"
                        Background="#F0F7F4"
                        BorderThickness="0,0,0,1" BorderBrush="#C8E6C9"
                        Padding="20,12"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="SelectedManagementName"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="#1a7a60"/>
                            <TextBlock x:Name="SelectedManagementDesc"
                                       FontSize="12" Foreground="#888"
                                       Margin="0,2,0,0"
                                       Visibility="Collapsed"/>
                        </StackPanel>

                        <!-- Dossier Types management -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="ManageTypesBtn"
                                    Content="🏷️ أنواع الدوسيات"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Height="34" Margin="0,0,8,0"
                                    Click="ManageTypes_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Dossier actions bar -->
                <Border Grid.Row="1"
                        Background="White"
                        BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"
                        Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="AddDossierBtn"
                                Grid.Column="0"
                                Content="➕ إضافة دوسية"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#1a7a60" Foreground="White"
                                Height="34" Margin="0,0,8,0"
                                IsEnabled="False"
                                Click="AddDossier_Click"/>

                        <Button x:Name="EditDossierBtn"
                                Grid.Column="1"
                                Content="✏️ تعديل"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="34" Margin="0,0,8,0"
                                IsEnabled="False"
                                Click="EditDossier_Click"/>

                        <Button x:Name="DeleteDossierBtn"
                                Grid.Column="2"
                                Content="🗑 حذف"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="#C62828"
                                Height="34"
                                IsEnabled="False"
                                Click="DeleteDossier_Click"/>

                        <!-- empty placeholder stays for no management selected text -->
                        <TextBlock x:Name="NoManagementHint"
                                   Grid.Column="3"
                                   Text="← اختر إدارة من القائمة لعرض دوسياتها"
                                   FontSize="12" Foreground="#AAA"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Visibility="Visible"/>
                    </Grid>
                </Border>

                <!-- Filters bar -->
                <Border Grid.Row="2"
                        Background="White"
                        BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"
                        Padding="16,10"
                        x:Name="FiltersBar"
                        Visibility="Collapsed">
                    <WrapPanel>

                        <!-- Dossier number search -->
                        <TextBox x:Name="DossierNumBox"
                                 materialDesign:HintAssist.Hint="رقم الدوسية"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Width="130" Height="38" Margin="0,0,8,0"
                                 TextChanged="Filter_Changed"/>

                        <!-- Year -->
                        <ComboBox x:Name="YearCombo"
                                  materialDesign:HintAssist.Hint="السنة الهجرية"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  Width="140" Height="38" Margin="0,0,8,0"
                                  SelectionChanged="Filter_Changed"/>

                        <!-- Month -->
                        <ComboBox x:Name="MonthCombo"
                                  materialDesign:HintAssist.Hint="الشهر"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  Width="90" Height="38" Margin="0,0,8,0"
                                  SelectionChanged="Filter_Changed">
                            <ComboBoxItem Content="الكل" Tag="0"/>
                            <ComboBoxItem Content="1"  Tag="1"/>
                            <ComboBoxItem Content="2"  Tag="2"/>
                            <ComboBoxItem Content="3"  Tag="3"/>
                            <ComboBoxItem Content="4"  Tag="4"/>
                            <ComboBoxItem Content="5"  Tag="5"/>
                            <ComboBoxItem Content="6"  Tag="6"/>
                            <ComboBoxItem Content="7"  Tag="7"/>
                            <ComboBoxItem Content="8"  Tag="8"/>
                            <ComboBoxItem Content="9"  Tag="9"/>
                            <ComboBoxItem Content="10" Tag="10"/>
                            <ComboBoxItem Content="11" Tag="11"/>
                            <ComboBoxItem Content="12" Tag="12"/>
                        </ComboBox>

                        <!-- Type -->
                        <ComboBox x:Name="TypeFilterCombo"
                                  materialDesign:HintAssist.Hint="النوع"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  DisplayMemberPath="TypeName"
                                  SelectedValuePath="TypeId"
                                  Width="160" Height="38" Margin="0,0,8,0"
                                  SelectionChanged="Filter_Changed"/>

                        <!-- Reset -->
                        <Button Content="مسح"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="#C62828" Height="38"
                                Click="ResetFilter_Click"/>
                    </WrapPanel>
                </Border>

                <!-- Result count -->
                <Border Grid.Row="3"
                        Background="#F0F7F4"
                        BorderThickness="0,0,0,1" BorderBrush="#E0E0E0"
                        Padding="16,6"
                        x:Name="ResultBar"
                        Visibility="Collapsed">
                    <TextBlock x:Name="ResultCountText"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#1a7a60"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- DataGrid -->
                <DataGrid Grid.Row="4"
                          x:Name="DossiersGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          Style="{StaticResource MaterialDesignDataGrid}"
                          materialDesign:DataGridAssist.CellPadding="12 8 12 8"
                          RowBackground="White"
                          AlternatingRowBackground="#F9FBF9"
                          VirtualizingPanel.IsVirtualizing="True"
                          Margin="12,0,12,12"
                          MouseDoubleClick="DossiersGrid_DoubleClick"
                          SelectionChanged="DossiersGrid_SelectionChanged">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم الدوسية"
                                            Binding="{Binding DossierNumber}"
                                            Width="110"/>
                        <DataGridTextColumn Header="التاريخ الهجري"
                                            Binding="{Binding HijriDisplay}"
                                            Width="120"/>
                        <DataGridTextColumn Header="النوع"
                                            Binding="{Binding TypeName}"
                                            Width="160"/>
                        <DataGridTextColumn Header="الحالة"
                                            Binding="{Binding StatusDisplay}"
                                            Width="80"/>
                        <DataGridTextColumn Header="ملاحظات"
                                            Binding="{Binding Notes}"
                                            Width="*"/>
                        <DataGridTextColumn Header="تاريخ الإنشاء"
                                            Binding="{Binding CreatedAt}"
                                            Width="155"/>
                    </DataGrid.Columns>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DeletedAt}" Value="{x:Null}">
                                    <Setter Property="Opacity" Value="1"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                </DataGrid>

                <!-- Empty-state placeholder -->
                <TextBlock Grid.Row="4"
                           x:Name="EmptyHint"
                           Text="لا توجد دوسيات لهذه الإدارة."
                           FontSize="14" Foreground="#AAA"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>

            </Grid>
        </Grid>
    </Grid>
</Page>
