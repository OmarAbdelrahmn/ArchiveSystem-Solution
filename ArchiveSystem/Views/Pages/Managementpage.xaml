<Page x:Class="ArchiveSystem.Views.Pages.ManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="الإدارة"
      Background="{StaticResource MidnightBase}"
      FontFamily="Noto Kufi Arabic, Segoe UI"
      FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <Border Grid.Row="0"
                BorderThickness="0,0,0,1">
            <Border.Background>
                <SolidColorBrush Color="#0A1628" Opacity="0.60"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
            </Border.BorderBrush>
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="🏢  الإدارة"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource RoseGold}"
                           VerticalAlignment="Center"/>

                <Button x:Name="AddRootManagementBtn"
                        Grid.Column="1"
                        Content="➕ إدارة جديدة"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="{StaticResource EmeraldMid}" Foreground="White"
                        Height="36" Margin="0,0,8,0"
                        Click="AddRootManagement_Click"/>

                <Button x:Name="AddSubManagementBtn"
                        Grid.Column="2"
                        Content="➕ شعبة او قسم"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="{StaticResource TextSecondary}"
                        Height="36" Margin="0,0,8,0"
                        IsEnabled="False"
                        Click="AddSubManagement_Click"/>

                <Button x:Name="EditManagementBtn"
                        Grid.Column="3"
                        Content="✏️ تعديل الإدارة"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="{StaticResource TextSecondary}"
                        Height="36"
                        IsEnabled="False"
                        Click="EditManagement_Click"/>
            </Grid>
        </Border>

        <!-- ══ MAIN CONTENT ══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: Management Tree ── -->
            <Border Grid.Column="0"
                    BorderThickness="0,0,1,0">
                <Border.Background>
                    <SolidColorBrush Color="#0D1F3C" Opacity="0.90"/>
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                </Border.BorderBrush>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            BorderThickness="0,0,0,1"
                            Padding="14,10">
                        <Border.Background>
                            <SolidColorBrush Color="#0A1628" Opacity="0.70"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                        </Border.BorderBrush>
                        <TextBlock Text="قائمة الإدارات"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource RoseGold}"/>
                    </Border>

                    <ListBox Grid.Row="1"
                             x:Name="ManagementsList"
                             BorderThickness="0"
                             Background="Transparent"
                             VirtualizingPanel.IsVirtualizing="True"
                             SelectionChanged="ManagementsList_SelectionChanged">

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,1">

                                    <!-- ROOT -->
                                    <Border x:Name="RootIndicator"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="10,7"
                                            Visibility="Collapsed">
                                        <Border.Background>
                                            <SolidColorBrush Color="#00E676" Opacity="0.08"/>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#00E676" Opacity="0.20"/>
                                        </Border.BorderBrush>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🏢 " FontSize="14" VerticalAlignment="Center"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name, Mode=OneWay}"
                                                           FontSize="13" FontWeight="Bold"
                                                           Foreground="{StaticResource EmeraldMid}"/>
                                                <TextBlock FontSize="10" Foreground="#4A5A7A" Margin="0,1,0,0">
                                                    <Run Text="{Binding DossierCount, Mode=OneWay}"/>
                                                    <Run Text=" دوسية"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- SUB -->
                                    <Border x:Name="SubIndicator"
                                            Padding="8,6"
                                            Margin="16,0,0,0"
                                            CornerRadius="3">
                                        <Border.Background>
                                            <SolidColorBrush Color="#0D1F3C" Opacity="0.60"/>
                                        </Border.Background>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="└  " FontSize="12"
                                                       Foreground="#4A5A7A"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name, Mode=OneWay}"
                                                           FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                                <TextBlock FontSize="10" Foreground="#4A5A7A" Margin="0,1,0,0">
                                                    <Run Text="{Binding DossierCount, Mode=OneWay}"/>
                                                    <Run Text=" دوسية"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding ParentManagementId, Mode=OneWay}"
                                                 Value="{x:Null}">
                                        <Setter TargetName="RootIndicator" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="SubIndicator"  Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#1A2E4A"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>

                    </ListBox>

                    <!-- Delete management button at the bottom -->
                    <Border Grid.Row="2"
                            BorderThickness="0,1,0,0"
                            Padding="10,8">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                        </Border.BorderBrush>
                        <Button x:Name="DeleteManagementBtn"
                                Content="🗑 حذف الإدارة المحددة"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="{StaticResource DangerRed}"
                                Height="32"
                                IsEnabled="False"
                                HorizontalAlignment="Stretch"
                                Click="DeleteManagement_Click"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ── RIGHT: Dossiers Area ── -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Management info bar -->
                <Border Grid.Row="0"
                        x:Name="ManagementInfoBar"
                        BorderThickness="0,0,0,1"
                        Padding="20,12"
                        Visibility="Collapsed">
                    <Border.Background>
                        <SolidColorBrush Color="#0A1628" Opacity="0.70"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                    </Border.BorderBrush>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="SelectedManagementName"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource RoseGold}"/>
                            <TextBlock x:Name="SelectedManagementDesc"
                                       FontSize="12" Foreground="#4A5A7A"
                                       Margin="0,2,0,0"
                                       Visibility="Collapsed"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="ManageTypesBtn"
                                    Content="🏷️ أنواع الدوسيات"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="{StaticResource TextSecondary}"
                                    Height="34" Margin="0,0,8,0"
                                    Click="ManageTypes_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Dossier actions bar -->
                <Border Grid.Row="1"
                        BorderThickness="0,0,0,1"
                        Padding="16,10">
                    <Border.Background>
                        <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#1E3050" Opacity="0.60"/>
                    </Border.BorderBrush>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="AddDossierBtn"
                                Grid.Column="0"
                                Content="➕ إضافة دوسية"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{StaticResource EmeraldMid}" Foreground="White"
                                Height="34" Margin="0,0,8,0"
                                IsEnabled="False"
                                Click="AddDossier_Click"/>

                        <Button x:Name="EditDossierBtn"
                                Grid.Column="1"
                                Content="✏️ تعديل"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="{StaticResource TextSecondary}"
                                Height="34" Margin="0,0,8,0"
                                IsEnabled="False"
                                Click="EditDossier_Click"/>

                        <Button x:Name="DeleteDossierBtn"
                                Grid.Column="2"
                                Content="🗑 حذف"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="{StaticResource DangerRed}"
                                Height="34"
                                IsEnabled="False"
                                Click="DeleteDossier_Click"/>

                        <TextBlock x:Name="NoManagementHint"
                                   Grid.Column="3"
                                   Text="← اختر إدارة من القائمة لعرض دوسياتها"
                                   FontSize="12" Foreground="#4A5A7A"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Visibility="Visible"/>
                    </Grid>
                </Border>

                <!-- Filters bar -->
                <Border Grid.Row="2"
                        BorderThickness="0,0,0,1"
                        Padding="16,10"
                        x:Name="FiltersBar"
                        Visibility="Collapsed">
                    <Border.Background>
                        <SolidColorBrush Color="#0D1F3C" Opacity="0.60"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#1E3050" Opacity="0.60"/>
                    </Border.BorderBrush>
                    <WrapPanel>

                        <TextBox x:Name="DossierNumBox"
                                 materialDesign:HintAssist.Hint="رقم الدوسية"
                                 materialDesign:HintAssist.Foreground="#4A5A7A"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Width="130" Height="50" Margin="0,0,8,0"
                                 TextChanged="Filter_Changed"/>

                        <ComboBox x:Name="YearCombo"
                                  materialDesign:HintAssist.Hint="السنة الهجرية"
                                  materialDesign:HintAssist.Foreground="#4A5A7A"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  Width="140" Height="50" Margin="0,0,8,0"
                                  SelectionChanged="Filter_Changed"/>

                        <ComboBox x:Name="MonthCombo"
                                  materialDesign:HintAssist.Hint="الشهر"
                                  materialDesign:HintAssist.Foreground="#4A5A7A"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  Width="90" Height="50" Margin="0,0,8,0"
                                  SelectionChanged="Filter_Changed">
                            <ComboBoxItem Content="الكل" Tag="0"/>
                            <ComboBoxItem Content="1"  Tag="1"/>
                            <ComboBoxItem Content="2"  Tag="2"/>
                            <ComboBoxItem Content="3"  Tag="3"/>
                            <ComboBoxItem Content="4"  Tag="4"/>
                            <ComboBoxItem Content="5"  Tag="5"/>
                            <ComboBoxItem Content="6"  Tag="6"/>
                            <ComboBoxItem Content="7"  Tag="7"/>
                            <ComboBoxItem Content="8"  Tag="8"/>
                            <ComboBoxItem Content="9"  Tag="9"/>
                            <ComboBoxItem Content="10" Tag="10"/>
                            <ComboBoxItem Content="11" Tag="11"/>
                            <ComboBoxItem Content="12" Tag="12"/>
                        </ComboBox>

                        <ComboBox x:Name="TypeFilterCombo"
                                  materialDesign:HintAssist.Hint="النوع"
                                  materialDesign:HintAssist.Foreground="#4A5A7A"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  DisplayMemberPath="TypeName"
                                  SelectedValuePath="TypeId"
                                  Width="160" Height="50" Margin="0,0,8,0"
                                  SelectionChanged="Filter_Changed"/>

                        <Button Content="مسح"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="{StaticResource DangerRed}" Height="38"
                                Click="ResetFilter_Click"/>
                    </WrapPanel>
                </Border>

                <!-- Result count -->
                <Border Grid.Row="3"
                        BorderThickness="0,0,0,1"
                        Padding="16,6"
                        x:Name="ResultBar"
                        Visibility="Collapsed">
                    <Border.Background>
                        <SolidColorBrush Color="#00E676" Opacity="0.06"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#00E676" Opacity="0.15"/>
                    </Border.BorderBrush>
                    <TextBlock x:Name="ResultCountText"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource EmeraldMid}"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- DataGrid -->
                <DataGrid Grid.Row="4"
                          x:Name="DossiersGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          Style="{StaticResource MaterialDesignDataGrid}"
                          materialDesign:DataGridAssist.CellPadding="12 8 12 8"
                          RowBackground="Transparent"
                          AlternatingRowBackground="Transparent"
                          VirtualizingPanel.IsVirtualizing="True"
                          Margin="12,0,12,12"
                          MouseDoubleClick="DossiersGrid_DoubleClick"
                          SelectionChanged="DossiersGrid_SelectionChanged">

                    <DataGrid.Background>
                        <SolidColorBrush Color="#0D1F3C" Opacity="0.50"/>
                    </DataGrid.Background>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم الدوسية"
                                            Binding="{Binding DossierNumber}"
                                            Width="110"/>
                        <DataGridTextColumn Header="التاريخ الهجري"
                                            Binding="{Binding HijriDisplay}"
                                            Width="120"/>
                        <DataGridTextColumn Header="النوع"
                                            Binding="{Binding TypeName}"
                                            Width="160"/>
                        <DataGridTextColumn Header="الحالة"
                                            Binding="{Binding StatusDisplay}"
                                            Width="80"/>
                        <DataGridTextColumn Header="ملاحظات"
                                            Binding="{Binding Notes}"
                                            Width="*"/>
                        <DataGridTextColumn Header="تاريخ الإنشاء"
                                            Binding="{Binding CreatedAt}"
                                            Width="155"/>
                    </DataGrid.Columns>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="#0D1F3C" Opacity="0.60"/>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusDisplay}" Value="محذوف">
                                    <Setter Property="Background" Value="#20E53935"/>
                                    <Setter Property="Opacity" Value="0.6"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                </DataGrid>

                <!-- Empty-state placeholder -->
                <TextBlock Grid.Row="4"
                           x:Name="EmptyHint"
                           Text="لا توجد دوسيات لهذه الإدارة."
                           FontSize="14" Foreground="#4A5A7A"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>

            </Grid>
        </Grid>
    </Grid>
</Page>
