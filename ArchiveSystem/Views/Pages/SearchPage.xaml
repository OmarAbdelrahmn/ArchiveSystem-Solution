<Page x:Class="ArchiveSystem.Views.Pages.SearchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="البحث"
      FlowDirection="RightToLeft">

    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#050D1A" Offset="0"/>
            <GradientStop Color="#0A1628" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <Border Grid.Row="0" Background="#0D1F3C"
                BorderThickness="0,0,0,1">
            <Border.BorderBrush>
                <SolidColorBrush Color="#C9956A" Opacity="0.20"/>
            </Border.BorderBrush>
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="بحث فوري"
                               FontSize="10" Foreground="#4A5A7A"
                               Margin="0,0,0,1"/>
                    <TextBlock Text="لوحة البحث السريع"
                               FontSize="17" FontWeight="Bold"
                               Foreground="#E8EDF5"/>
                </StackPanel>

                <Button Grid.Column="1"
                        x:Name="QuickPrintBtn"
                        Content="🖨️ طباعة واجهة الدوسية"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="{StaticResource RoseGold}"
                        BorderBrush="{StaticResource RoseGoldDark}"
                        Height="32"
                        Visibility="Collapsed"
                        Click="QuickPrint_Click"/>
            </Grid>
        </Border>

        <!-- ══ STAT CARDS ══ -->
        <Border Grid.Row="1" Background="#0A1628"
                BorderThickness="0,0,0,1">
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
            </Border.BorderBrush>
            <Border Padding="20,12">
                <UniformGrid x:Name="StatsPanel" Columns="5"/>
            </Border>
        </Border>

        <!-- ══ SEARCH BAR ══ -->
        <Border Grid.Row="2" Background="#0A1628"
                Padding="20,14,20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search input — glassmorphism box -->
                <Border Grid.Column="0"
                        CornerRadius="8">
                    <Border.Background>
                        <SolidColorBrush Color="#0D1F3C" Opacity="0.90"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#1adf8a" Opacity="0.30"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="🔍"
                                   FontSize="15"
                                   VerticalAlignment="Center"
                                   Margin="12,0,6,0"
                                   Foreground="#4A5A7A"/>
                        <TextBox Grid.Column="1"
                                 x:Name="SearchBox"
                                 materialDesign:HintAssist.Hint="ابحث باسم السجين أو رقمه أو رقم الدوسية أو حقل إضافي..."
                                 materialDesign:HintAssist.Foreground="#4A5A7A"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#E8EDF5"
                                 FontSize="13"
                                 Height="40"
                                 Padding="0,0,8,0"
                                 VerticalContentAlignment="Center"
                                 KeyDown="SearchBox_KeyDown"
                                 TextChanged="SearchBox_TextChanged"/>
                    </Grid>
                </Border>

                <!-- Search button — emerald glow -->
                <Button Grid.Column="1"
                        Content="بحث"
                        Height="40" Width="80"
                        Margin="10,0,0,0"
                        Foreground="#050D1A"
                        FontWeight="SemiBold"
                        Click="Search_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
                        </Style>
                    </Button.Style>
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00BCD4" Offset="0"/>
                            <GradientStop Color="#00E676" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="14" ShadowDepth="0"
                                          Color="#00E676" Opacity="0.40"/>
                    </Button.Effect>
                </Button>

                <Button x:Name="ClearBtn"
                        Grid.Column="2"
                        Content="✕"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="#4A5A7A"
                        Height="40" Width="40"
                        Margin="4,0,0,0"
                        Visibility="Collapsed"
                        Click="Clear_Click"/>
            </Grid>
        </Border>

        <!-- ══ CONTENT AREA ══ -->
        <Grid Grid.Row="3" Margin="20,16,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: RESULT PANEL ── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   x:Name="ResultCountText"
                                   FontSize="12" Foreground="#4A5A7A"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="QuickCardBtn"
                                Grid.Column="1"
                                Content="🪪 بطاقة السجل"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="{StaticResource RoseGold}"
                                BorderBrush="{StaticResource RoseGoldDark}"
                                Height="28" FontSize="11"
                                Visibility="Collapsed"
                                Click="QuickCard_Click"/>
                    </Grid>
                </Border>

                <!-- ── Results DataGrid (multiple results) ── -->
                <Border Grid.Row="1"
                        x:Name="ResultsContainer"
                        CornerRadius="10"
                        BorderThickness="1"
                        Visibility="Collapsed">
                    <Border.Background>
                        <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                    </Border.BorderBrush>
                    <DataGrid x:Name="ResultsGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              BorderThickness="0"
                              Background="Transparent"
                              Style="{StaticResource MaterialDesignDataGrid}"
                              materialDesign:DataGridAssist.CellPadding="12 8 12 8"
                              SelectionChanged="ResultsGrid_SelectionChanged"
                              MouseDoubleClick="ResultsGrid_DoubleClick">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                                <Setter Property="Cursor" Value="Hand"/>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="رقم الدوسية"  Binding="{Binding DossierNumber}"  Width="100"/>
                            <DataGridTextColumn Header="تسلسل"        Binding="{Binding SequenceNumber}" Width="65"/>
                            <DataGridTextColumn Header="اسم السجين"   Binding="{Binding PersonName}"     Width="*"/>
                            <DataGridTextColumn Header="رقم السجين"   Binding="{Binding PrisonerNumber}" Width="120"/>
                            <DataGridTextColumn Header="التاريخ"      Binding="{Binding HijriDisplay}"   Width="90"/>
                            <DataGridTextColumn Header="الموقع"       Binding="{Binding LocationDisplay}" Width="170"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- ── Detail card (single result) ── -->
                <Border Grid.Row="1"
                        x:Name="ResultDetailCard"
                        Visibility="Collapsed">
                    <StackPanel>

                        <!-- Found card — glassmorphism -->
                        <Border CornerRadius="12" BorderThickness="1" Padding="0">
                            <Border.Background>
                                <SolidColorBrush Color="#0D1F3C" Opacity="0.90"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#00E676" Opacity="0.30"/>
                            </Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="0"
                                                  Color="#00E676" Opacity="0.10"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Card header -->
                                <Border Grid.Row="0"
                                        CornerRadius="12,12,0,0"
                                        Padding="18,12">
                                    <Border.Background>
                                        <SolidColorBrush Color="#00E676" Opacity="0.08"/>
                                    </Border.Background>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                CornerRadius="6" Padding="10,4"
                                                Margin="0,0,12,0"
                                                VerticalAlignment="Center">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#00BCD4" Offset="0"/>
                                                    <GradientStop Color="#00E676" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="تم العثور"
                                                       FontSize="11"
                                                       Foreground="#050D1A"
                                                       FontWeight="Bold"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock x:Name="DetailName"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       Foreground="#E8EDF5"/>
                                            <TextBlock x:Name="DetailPrisonerNum"
                                                       FontSize="11"
                                                       Foreground="#8A9BB8"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- ══ FIX: 5 info boxes in a single row (Columns="5") ══ -->
                                <UniformGrid Grid.Row="1" Columns="5"
                                             Margin="16,14,16,14">

                                    <!-- الشهر -->
                                    <Border CornerRadius="8" Padding="14,10"
                                            Margin="0,0,8,0">
                                        <Border.Background>
                                            <SolidColorBrush Color="#162844" Opacity="0.80"/>
                                        </Border.Background>
                                        <StackPanel>
                                            <TextBlock x:Name="DetailMonth"
                                                       FontSize="22" FontWeight="Bold"
                                                       Foreground="{StaticResource EmeraldGlow}"/>
                                            <TextBlock Text="الشهر" FontSize="11"
                                                       Foreground="#4A5A7A" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- الدوسية -->
                                    <Border CornerRadius="8" Padding="14,10"
                                            Margin="0,0,8,0">
                                        <Border.Background>
                                            <SolidColorBrush Color="#162844" Opacity="0.80"/>
                                        </Border.Background>
                                        <StackPanel>
                                            <TextBlock x:Name="DetailDossier"
                                                       FontSize="22" FontWeight="Bold"
                                                       Foreground="{StaticResource RoseGold}"/>
                                            <TextBlock Text="الدوسية" FontSize="11"
                                                       Foreground="#4A5A7A" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- الممر -->
                                    <Border CornerRadius="8" Padding="14,10"
                                            Margin="0,0,8,0">
                                        <Border.Background>
                                            <SolidColorBrush Color="#162844" Opacity="0.80"/>
                                        </Border.Background>
                                        <StackPanel>
                                            <TextBlock x:Name="DetailHallway"
                                                       FontSize="22" FontWeight="Bold"
                                                       Foreground="{StaticResource EmeraldMid}"/>
                                            <TextBlock Text="الممر" FontSize="11"
                                                       Foreground="#4A5A7A" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- الكبينة -->
                                    <Border CornerRadius="8" Padding="14,10"
                                            Margin="0,0,8,0">
                                        <Border.Background>
                                            <SolidColorBrush Color="#162844" Opacity="0.80"/>
                                        </Border.Background>
                                        <StackPanel>
                                            <TextBlock x:Name="DetailCabinet"
                                                       FontSize="22" FontWeight="Bold"
                                                       Foreground="{StaticResource EmeraldGlow}"/>
                                            <TextBlock Text="الكبينة" FontSize="11"
                                                       Foreground="#4A5A7A" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- الرف -->
                                    <Border CornerRadius="8" Padding="14,10"
                                            Margin="0,0,0,0">
                                        <Border.Background>
                                            <SolidColorBrush Color="#162844" Opacity="0.80"/>
                                        </Border.Background>
                                        <StackPanel>
                                            <TextBlock x:Name="DetailShelf"
                                                       FontSize="22" FontWeight="Bold"
                                                       Foreground="{StaticResource RoseGold}"/>
                                            <TextBlock Text="الرف" FontSize="11"
                                                       Foreground="#4A5A7A" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>

                                </UniformGrid>
                            </Grid>
                        </Border>

                        <!-- Action buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="📁 فتح الدوسية"
                                    Height="34" Margin="0,0,8,0"
                                    Foreground="#050D1A" FontWeight="SemiBold"
                                    Click="OpenDossierFromDetail_Click"
                                    x:Name="OpenDossierDetailBtn">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Style>
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#00BCD4" Offset="0"/>
                                        <GradientStop Color="#00E676" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>
                            <Button Content="🖨️ طباعة واجهة الدوسية"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="{StaticResource RoseGold}"
                                    BorderBrush="{StaticResource RoseGoldDark}"
                                    Height="34"
                                    Click="QuickPrint_Click"
                                    x:Name="PrintFromDetailBtn"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Empty state -->
                <Border Grid.Row="1"
                        x:Name="EmptySearchState"
                        CornerRadius="10"
                        BorderThickness="1"
                        Padding="32">
                    <Border.Background>
                        <SolidColorBrush Color="#0D1F3C" Opacity="0.60"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#1E3050" Opacity="0.60"/>
                    </Border.BorderBrush>
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="🔍"
                                   FontSize="42"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,14"/>
                        <TextBlock Text="ابحث عن سجل أو دوسية"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#8A9BB8"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="أدخل رقم السجين أو اسمه أو رقم الدوسية في مربع البحث أعلاه"
                                   FontSize="12"
                                   Foreground="#4A5A7A"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   MaxWidth="280"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── RIGHT: RECENT DOSSIERS ── -->
            <Border Grid.Column="2"
                    CornerRadius="10"
                    BorderThickness="1">
                <Border.Background>
                    <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                </Border.BorderBrush>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            BorderThickness="0,0,0,1"
                            Padding="16,12">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#C9956A" Opacity="0.20"/>
                        </Border.BorderBrush>
                        <TextBlock Text="آخر الدوسيات"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource RoseGold}"/>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="RecentDossiersList" Margin="0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderThickness="0,0,0,1"
                                            Padding="16,10"
                                            Cursor="Hand"
                                            Background="Transparent"
                                            MouseLeftButtonUp="RecentDossierItem_Click">
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#1E3050" Opacity="0.60"/>
                                        </Border.BorderBrush>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="#162844" Opacity="0.60"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    CornerRadius="6" Padding="8,4"
                                                    Margin="0,0,10,0"
                                                    VerticalAlignment="Center">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#00E676" Opacity="0.10"/>
                                                </Border.Background>
                                                <Border.BorderBrush>
                                                    <SolidColorBrush Color="#00E676" Opacity="0.25"/>
                                                </Border.BorderBrush>
                                                <Border.BorderThickness>1</Border.BorderThickness>
                                                <TextBlock Text="{Binding DossierNumber}"
                                                           FontSize="13" FontWeight="Bold"
                                                           Foreground="{StaticResource EmeraldGlow}"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding HijriDisplay}"
                                                           FontSize="12" Foreground="#8A9BB8"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding RecordCount}"
                                                               FontSize="11" Foreground="#4A5A7A"/>
                                                    <TextBlock Text=" ملف  ·  "
                                                               FontSize="11" Foreground="#1E3050"/>
                                                    <TextBlock Text="{Binding LocationDisplay}"
                                                               FontSize="11" Foreground="#4A5A7A"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="100"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <TextBlock Grid.Column="2"
                                                       Text="←" FontSize="12"
                                                       Foreground="#1E3050"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <DataGrid Grid.Row="1"
                              x:Name="RecentGrid"
                              Visibility="Collapsed"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              Background="Transparent"
                              Style="{StaticResource MaterialDesignDataGrid}"
                              MouseDoubleClick="RecentGrid_DoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="رقم الدوسية" Binding="{Binding DossierNumber}" Width="90"/>
                            <DataGridTextColumn Header="التاريخ"     Binding="{Binding HijriDisplay}"  Width="*"/>
                            <DataGridTextColumn Header="الموقع"      Binding="{Binding LocationDisplay}" Width="130"/>
                            <DataGridTextColumn Header="ملفات"       Binding="{Binding RecordCount}"   Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Page>
