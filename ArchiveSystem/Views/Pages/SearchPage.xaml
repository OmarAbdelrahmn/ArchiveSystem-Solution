<Page x:Class="ArchiveSystem.Views.Pages.SearchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="البحث"
      Background="#F5F5F5"
      FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White"
                BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
            <TextBlock Text="🔍  البحث"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#1a7a60"
                       VerticalAlignment="Center"
                       Margin="32,0"/>
        </Border>

        <!-- Search bar -->
        <Border Grid.Row="1"
                Background="White"
                Padding="32,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         x:Name="SearchBox"
                         materialDesign:HintAssist.Hint=
                             "ابحث باسم السجين أو رقمه أو رقم الدوسية..."
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         FontSize="14"
                         KeyDown="SearchBox_KeyDown"
                         TextChanged="SearchBox_TextChanged"/>

                <Button Grid.Column="1"
                        Content="بحث"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#1a7a60" Foreground="White"
                        Height="40" Width="90"
                        Margin="12,0,0,0"
                        Click="Search_Click"/>
            </Grid>
        </Border>

        <!-- Result count -->
        <Border Grid.Row="2"
                Padding="32,8"
                Background="#F5F5F5">
            <TextBlock x:Name="ResultCountText"
                       FontSize="12"
                       Foreground="#888"/>
        </Border>

        <!-- Results table -->
        <DataGrid Grid.Row="3"
                  x:Name="ResultsGrid"
                  Margin="24,0,24,24"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  Style="{StaticResource MaterialDesignDataGrid}"
                  materialDesign:DataGridAssist.CellPadding="12 8 12 8"
                  RowBackground="White"
                  AlternatingRowBackground="#F9FBF9"
                  MouseDoubleClick="ResultsGrid_DoubleClick">

            <DataGrid.Columns>
                <DataGridTextColumn Header="رقم الدوسية"
                                    Binding="{Binding DossierNumber}"
                                    Width="110"/>
                <DataGridTextColumn Header="التسلسل"
                                    Binding="{Binding SequenceNumber}"
                                    Width="80"/>
                <DataGridTextColumn Header="اسم السجين"
                                    Binding="{Binding PersonName}"
                                    Width="*"/>
                <DataGridTextColumn Header="رقم السجين"
                                    Binding="{Binding PrisonerNumber}"
                                    Width="130"/>
                <DataGridTextColumn Header="التاريخ الهجري"
                                    Binding="{Binding HijriDisplay}"
                                    Width="110"/>
                <DataGridTextColumn Header="الموقع"
                                    Binding="{Binding LocationDisplay}"
                                    Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</Page>
