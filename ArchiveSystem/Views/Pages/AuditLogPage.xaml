<Page x:Class="ArchiveSystem.Views.Pages.AuditLogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="سجل المراجعة"
      Background="#F5F5F5"
      FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <!-- header -->
            <RowDefinition Height="Auto"/>
            <!-- filter bar -->
            <RowDefinition Height="Auto"/>
            <!-- result bar -->
            <RowDefinition Height="*"/>
            <!-- table -->
            <RowDefinition Height="Auto"/>
            <!-- pager -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="White"
                BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>

                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="📜  سجل المراجعة"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#1a7a60"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="🖨️ تصدير PDF"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Height="36" Margin="0,0,8,0"
                        Click="ExportPdf_Click"/>

                <Button Grid.Column="2"
                        Content="📤 تصدير CSV"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Height="36"
                        Click="Export_Click"/>
            </Grid>
        </Border>

        <!-- ══ FILTER BAR ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="White"
                BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"
                Padding="20,14">
            <WrapPanel>

                <!-- Action type -->
                <ComboBox x:Name="ActionCombo"
                          materialDesign:HintAssist.Hint="نوع الحدث"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Width="200" Height="40" Margin="0,0,10,6"
                          SelectionChanged="Filter_Changed"/>

                <!-- User -->
                <ComboBox x:Name="UserCombo"
                          materialDesign:HintAssist.Hint="المستخدم"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="FullName"
                          SelectedValuePath="UserId"
                          Width="180" Height="40" Margin="0,0,10,6"
                          SelectionChanged="Filter_Changed"/>

                <!-- Search description -->
                <TextBox x:Name="SearchBox"
                         materialDesign:HintAssist.Hint="بحث في الوصف..."
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Width="220" Height="40" Margin="0,0,10,6"
                         TextChanged="Filter_Changed"/>

                <!-- Date from -->
                <TextBox x:Name="DateFromBox"
                         materialDesign:HintAssist.Hint="من تاريخ (yyyy-MM-dd)"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Width="180" Height="40" Margin="0,0,10,6"
                         TextChanged="Filter_Changed"/>

                <!-- Date to -->
                <TextBox x:Name="DateToBox"
                         materialDesign:HintAssist.Hint="إلى تاريخ (yyyy-MM-dd)"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Width="180" Height="40" Margin="0,0,10,6"
                         TextChanged="Filter_Changed"/>

                <!-- Reset -->
                <Button Content="مسح"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="#C62828" Height="40" Margin="4,0,0,6"
                        Click="Reset_Click"/>

            </WrapPanel>
        </Border>

        <!-- ══ RESULT COUNT ════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#F0F7F4"
                BorderThickness="0,0,0,1" BorderBrush="#E0E0E0"
                Padding="20,8">
            <TextBlock x:Name="ResultCountText"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="#1a7a60"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- ══ TABLE ════════════════════════════════════════════════════════════ -->
        <DataGrid Grid.Row="3"
                  x:Name="AuditGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  Style="{StaticResource MaterialDesignDataGrid}"
                  materialDesign:DataGridAssist.CellPadding="10 7 10 7"
                  RowBackground="White"
                  AlternatingRowBackground="#F9FBF9"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  EnableRowVirtualization="True"
                  Margin="12,0,12,0">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <!-- Login failures in red -->
                        <DataTrigger Binding="{Binding ActionType}" Value="LoginFailure">
                            <Setter Property="Background" Value="#FFF0F0"/>
                        </DataTrigger>
                        <!-- Deletes in amber -->
                        <DataTrigger Binding="{Binding ActionType}" Value="RecordDeleted">
                            <Setter Property="Background" Value="#FFF8E1"/>
                        </DataTrigger>
                        <!-- Restores in blue -->
                        <DataTrigger Binding="{Binding ActionType}" Value="RestoreCompleted">
                            <Setter Property="Background" Value="#E3F2FD"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="التاريخ والوقت"
                                    Binding="{Binding CreatedAt}"
                                    Width="155"/>
                <DataGridTextColumn Header="المستخدم"
                                    Binding="{Binding UserFullName}"
                                    Width="140"/>
                <DataGridTextColumn Header="نوع الحدث"
                                    Binding="{Binding ActionTypeArabic}"
                                    Width="170"/>
                <DataGridTextColumn Header="الكيان"
                                    Binding="{Binding EntityDisplay}"
                                    Width="100"/>
                <DataGridTextColumn Header="الوصف"
                                    Binding="{Binding Description}"
                                    Width="*"/>
            </DataGrid.Columns>

        </DataGrid>

        <!-- ══ PAGER ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4"
                Background="White"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0"
                Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="→ السابق"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Height="34" Width="100"
                        Click="PrevPage_Click"/>

                <TextBlock Grid.Column="1"
                           x:Name="PageText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="12" Foreground="#555"/>

                <Button Grid.Column="2"
                        Content="التالي ←"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Height="34" Width="100"
                        Click="NextPage_Click"/>
            </Grid>
        </Border>

    </Grid>
</Page>
