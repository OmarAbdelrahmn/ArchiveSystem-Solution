<Page x:Class="ArchiveSystem.Views.Pages.AuditLogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="سجل الاحداث"
      Background="{StaticResource MidnightBase}"
      FontFamily="Noto Kufi Arabic, Segoe UI"
      FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                BorderThickness="0,0,0,1">
            <Border.Background>
                <SolidColorBrush Color="#0A1628" Opacity="0.60"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
            </Border.BorderBrush>
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="📜  سجل الاحداث"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource RoseGold}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="🖨️ تصدير PDF"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="{StaticResource TextSecondary}"
                        Height="36" Margin="0,0,8,0"
                        Click="ExportPdf_Click"/>

                <Button Grid.Column="2"
                        Content="📤 تصدير CSV"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="{StaticResource TextSecondary}"
                        Height="36"
                        Click="Export_Click"/>
            </Grid>
        </Border>

        <!-- ══ FILTER BAR ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <Border.Background>
                <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
            </Border.BorderBrush>
            <WrapPanel>

                <ComboBox x:Name="ActionCombo"
                          materialDesign:HintAssist.Hint="نوع الحدث"
                          materialDesign:HintAssist.Foreground="#4A5A7A"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Width="200" Height="50" Margin="0,0,10,6"
                          SelectionChanged="Filter_Changed"/>

                <ComboBox x:Name="UserCombo"
                          materialDesign:HintAssist.Hint="المستخدم"
                          materialDesign:HintAssist.Foreground="#4A5A7A"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="FullName"
                          SelectedValuePath="UserId"
                          Width="180" Height="50" Margin="0,0,10,6"
                          SelectionChanged="Filter_Changed"/>

                <TextBox x:Name="SearchBox"
                         materialDesign:HintAssist.Hint="بحث في الوصف..."
                         materialDesign:HintAssist.Foreground="#4A5A7A"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Width="220" Height="50" Margin="0,0,10,6"
                         TextChanged="Filter_Changed"/>

                <TextBox x:Name="DateFromBox"
                         materialDesign:HintAssist.Hint="من تاريخ (yyyy-MM-dd)"
                         materialDesign:HintAssist.Foreground="#4A5A7A"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Width="180" Height="50" Margin="0,0,10,6"
                         TextChanged="Filter_Changed"/>

                <TextBox x:Name="DateToBox"
                         materialDesign:HintAssist.Hint="إلى تاريخ (yyyy-MM-dd)"
                         materialDesign:HintAssist.Foreground="#4A5A7A"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Width="180" Height="50" Margin="0,0,10,6"
                         TextChanged="Filter_Changed"/>

                <Button Content="مسح"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="{StaticResource DangerRed}"
                        Height="50" Margin="4,0,0,6"
                        Click="Reset_Click"/>

            </WrapPanel>
        </Border>

        <!-- ══ RESULT COUNT ════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                BorderThickness="0,0,0,1"
                Padding="20,8">
            <Border.Background>
                <SolidColorBrush Color="#00E676" Opacity="0.05"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
            </Border.BorderBrush>
            <TextBlock x:Name="ResultCountText"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource EmeraldMid}"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- ══ TABLE ════════════════════════════════════════════════════════════ -->
        <DataGrid Grid.Row="3"
                  x:Name="AuditGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  Style="{StaticResource MaterialDesignDataGrid}"
                  materialDesign:DataGridAssist.CellPadding="10 7 10 7"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  EnableRowVirtualization="True"
                  Margin="12,0,12,0">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background">
                        <Setter.Value>
                            <SolidColorBrush Color="#0D1F3C" Opacity="0.60"/>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ActionType}" Value="LoginFailure">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="#FF5252" Opacity="0.10"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ActionType}" Value="RecordDeleted">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="#FFB300" Opacity="0.10"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ActionType}" Value="RestoreCompleted">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="#00BCD4" Opacity="0.10"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="التاريخ والوقت"
                                    Binding="{Binding CreatedAt}"
                                    Width="155"/>
                <DataGridTextColumn Header="المستخدم"
                                    Binding="{Binding UserFullName}"
                                    Width="140"/>
                <DataGridTextColumn Header="نوع الحدث"
                                    Binding="{Binding ActionTypeArabic}"
                                    Width="170"/>
                <DataGridTextColumn Header="الكيان"
                                    Binding="{Binding EntityDisplay}"
                                    Width="100"/>
                <DataGridTextColumn Header="الوصف"
                                    Binding="{Binding Description}"
                                    Width="*"/>
            </DataGrid.Columns>

        </DataGrid>

        <!-- ══ PAGER ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4"
                BorderThickness="0,1,0,0"
                Padding="20,10">
            <Border.Background>
                <SolidColorBrush Color="#0A1628" Opacity="0.60"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
            </Border.BorderBrush>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="→ السابق"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="{StaticResource TextSecondary}"
                        Height="34" Width="100"
                        Click="PrevPage_Click"/>

                <TextBlock Grid.Column="1"
                           x:Name="PageText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondary}"/>

                <Button Grid.Column="2"
                        Content="التالي ←"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="{StaticResource TextSecondary}"
                        Height="34" Width="100"
                        Click="NextPage_Click"/>
            </Grid>
        </Border>

    </Grid>
</Page>
