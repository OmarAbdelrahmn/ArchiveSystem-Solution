<Page x:Class="ArchiveSystem.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="الإعدادات" Background="#F5F5F5"
      FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White"
                BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
            <TextBlock Text="⚙️  الإعدادات"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#1a7a60"
                       VerticalAlignment="Center"
                       Margin="32,0"/>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1"
                    Margin="24"
                    Style="{StaticResource MaterialDesignTabControl}">

            <!-- ══════════════ USERS TAB ══════════════ -->
            <TabItem Header="المستخدمون">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="AddUserBtn"
                                Content="➕ إضافة مستخدم"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#1a7a60" Foreground="White"
                                Height="36" Click="AddUser_Click"/>
                        <Button x:Name="ChangePasswordBtn"
                                Content="🔑 تغيير كلمة المرور"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="36" Margin="10,0,0,0"
                                Click="ChangePassword_Click"/>
                        <Button x:Name="ToggleActiveBtn"
                                Content="تعطيل / تفعيل"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="36" Margin="10,0,0,0"
                                Click="ToggleActive_Click"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" x:Name="UsersGrid"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" SelectionMode="Single"
                              Style="{StaticResource MaterialDesignDataGrid}"
                              materialDesign:DataGridAssist.CellPadding="12 8 12 8"
                              RowBackground="White" AlternatingRowBackground="#F9FBF9">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="الاسم الكامل"
                                                Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="اسم المستخدم"
                                                Binding="{Binding Username}" Width="140"/>
                            <DataGridTextColumn Header="رقم الموظف"
                                                Binding="{Binding EmployeeNumber}" Width="120"/>
                            <DataGridTextColumn Header="آخر دخول"
                                                Binding="{Binding LastLoginAt}" Width="160"/>
                            <DataGridCheckBoxColumn Header="نشط"
                                                    Binding="{Binding IsActive}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ══════════════ ROLES TAB ══════════════ -->
            <TabItem Header="الأدوار والصلاحيات">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="AddRoleBtn"
                                Content="➕ إضافة دور"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#1a7a60" Foreground="White"
                                Height="36" Click="AddRole_Click"/>
                        <Button x:Name="EditRoleBtn"
                                Content="✏️ تعديل الدور والصلاحيات"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="36" Margin="10,0,0,0" Click="EditRole_Click"/>
                        <Button x:Name="DeleteRoleBtn"
                                Content="🗑 حذف الدور"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="36" Margin="10,0,0,0" Foreground="#C62828"
                                Click="DeleteRole_Click"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" x:Name="RolesGrid"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" SelectionMode="Single"
                              Style="{StaticResource MaterialDesignDataGrid}"
                              materialDesign:DataGridAssist.CellPadding="12 8 12 8"
                              RowBackground="White" AlternatingRowBackground="#F9FBF9">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="اسم الدور"
                                                Binding="{Binding RoleName}" Width="*"/>
                            <DataGridTextColumn Header="الوصف"
                                                Binding="{Binding Description}" Width="*"/>
                            <DataGridCheckBoxColumn Header="دور أساسي"
                                                    Binding="{Binding IsSystemRole}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ══════════════ CUSTOM FIELDS TAB ══════════════ -->
            <TabItem Header="الحقول المخصصة">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button x:Name="AddFieldBtn"
                                    Content="➕ إضافة حقل"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="#1a7a60" Foreground="White"
                                    Height="36" Click="AddField_Click"/>
                            <Button x:Name="EditFieldBtn"
                                    Content="✏️ تعديل"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Height="36" Margin="10,0,0,0" Click="EditField_Click"/>
                            <Button x:Name="ToggleFieldBtn"
                                    Content="تفعيل / تعطيل"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Height="36" Margin="10,0,0,0" Click="ToggleField_Click"/>
                        </StackPanel>

                        <TextBlock Grid.Column="2"
                                   Text="انقر مرتين على صف لفتح نافذة التعديل"
                                   FontSize="11" Foreground="#999"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <DataGrid Grid.Row="1" x:Name="FieldsGrid"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" SelectionMode="Single"
                              Style="{StaticResource MaterialDesignDataGrid}"
                              materialDesign:DataGridAssist.CellPadding="10 7 10 7"
                              RowBackground="White" AlternatingRowBackground="#F9FBF9"
                              MouseDoubleClick="FieldsGrid_DoubleClick">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                        <Setter Property="Opacity" Value="0.45"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="التسمية العربية"
                                                Binding="{Binding ArabicLabel}" Width="*"/>
                            <DataGridTextColumn Header="النوع"
                                                Binding="{Binding FieldTypeArabic}" Width="150"/>
                            <DataGridTextColumn Header="الترتيب"
                                                Binding="{Binding SortOrder}" Width="70"/>
                            <DataGridCheckBoxColumn Header="مطلوب"
                                                    Binding="{Binding IsRequired}" Width="70"/>
                            <DataGridCheckBoxColumn Header="الإدخال"
                                                    Binding="{Binding ShowInEntry}" Width="70"/>
                            <DataGridCheckBoxColumn Header="كل البيانات"
                                                    Binding="{Binding ShowInAllData}" Width="90"/>
                            <DataGridCheckBoxColumn Header="التقارير"
                                                    Binding="{Binding ShowInReports}" Width="75"/>
                            <DataGridCheckBoxColumn Header="إحصاءات"
                                                    Binding="{Binding EnableStatistics}" Width="75"/>
                            <DataGridCheckBoxColumn Header="نشط"
                                                    Binding="{Binding IsActive}" Width="55"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ══════════════ ARCHIVE STRUCTURE TAB ══════════════ -->
            <TabItem Header="هيكل الأرشيف">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Add location form -->
                    <Border Grid.Row="0" Background="#F0F7F4" CornerRadius="6"
                            Padding="16,12" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="إضافة موقع جديد"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#1a7a60" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0" x:Name="LocHallwayBox"
                                         materialDesign:HintAssist.Hint="ممر *"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Height="40" PreviewTextInput="NumberOnly"/>
                                <TextBox Grid.Column="2" x:Name="LocCabinetBox"
                                         materialDesign:HintAssist.Hint="كبينة *"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Height="40" PreviewTextInput="NumberOnly"/>
                                <TextBox Grid.Column="4" x:Name="LocShelfBox"
                                         materialDesign:HintAssist.Hint="رف *"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Height="40" PreviewTextInput="NumberOnly"/>
                                <TextBox Grid.Column="6" x:Name="LocLabelBox"
                                         materialDesign:HintAssist.Hint="تسمية (اختياري)"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Height="40"/>
                                <TextBox Grid.Column="8" x:Name="LocCapacityBox"
                                         materialDesign:HintAssist.Hint="السعة (اختياري)"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Height="40" PreviewTextInput="NumberOnly"/>
                                <Button Grid.Column="10"
                                        Content="➕ إضافة"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="#1a7a60" Foreground="White"
                                        Height="40" Width="90"
                                        Click="AddLocation_Click"/>
                            </Grid>

                            <Border x:Name="LocErrorBorder"
                                    Background="#FFEBEE" BorderBrush="#EF9A9A"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="8,5" Margin="0,8,0,0"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="LocErrorText"
                                           Foreground="#C62828" FontSize="12"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Toolbar -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="EditLocBtn"
                                Content="✏️ تعديل"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="34" Click="EditLocation_Click"/>
                        <Button x:Name="ToggleLocBtn"
                                Content="تفعيل / تعطيل"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="34" Margin="10,0,0,0"
                                Click="ToggleLocation_Click"/>
                        <TextBlock Text="الأماكن المعطلة تُخفى من قوائم الاختيار ولكنها محفوظة للتاريخ"
                                   FontSize="11" Foreground="#999"
                                   VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>

                    <!-- Locations grid -->
                    <DataGrid Grid.Row="2" x:Name="LocationsGrid"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" SelectionMode="Single"
                              Style="{StaticResource MaterialDesignDataGrid}"
                              materialDesign:DataGridAssist.CellPadding="10 7 10 7"
                              RowBackground="White" AlternatingRowBackground="#F9FBF9">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                        <Setter Property="Opacity" Value="0.45"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="الموقع"
                                                Binding="{Binding DisplayName}" Width="*"/>
                            <DataGridTextColumn Header="تسمية"
                                                Binding="{Binding Label}" Width="130"/>
                            <DataGridTextColumn Header="السعة"
                                                Binding="{Binding Capacity}" Width="80"/>
                            <DataGridCheckBoxColumn Header="نشط"
                                                    Binding="{Binding IsActive}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ══════════════ BACKUP TAB ══════════════ -->
            <TabItem Header="النسخ الاحتياطي">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Action cards -->
                    <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,16">

                        <!-- Create backup -->
                        <Border Background="White" CornerRadius="8" Padding="18,14"
                                Margin="0,0,10,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4" Opacity="0.08" ShadowDepth="1"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="💾 إنشاء نسخة احتياطية"
                                           FontSize="13" FontWeight="Bold"
                                           Foreground="#1a7a60" Margin="0,0,0,6"/>
                                <TextBlock Text="نسخ قاعدة البيانات يدوياً الآن"
                                           FontSize="11" Foreground="#888" Margin="0,0,0,12"
                                           TextWrapping="Wrap"/>
                                <Button x:Name="CreateBackupBtn"
                                        Content="إنشاء نسخة الآن"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="#1a7a60" Foreground="White"
                                        Height="36" HorizontalAlignment="Stretch"
                                        Click="CreateBackup_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Restore -->
                        <Border Background="White" CornerRadius="8" Padding="18,14"
                                Margin="0,0,10,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4" Opacity="0.08" ShadowDepth="1"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="♻️ استعادة نسخة احتياطية"
                                           FontSize="13" FontWeight="Bold"
                                           Foreground="#E65100" Margin="0,0,0,6"/>
                                <TextBlock Text="استبدال قاعدة البيانات بملف نسخة احتياطية"
                                           FontSize="11" Foreground="#888" Margin="0,0,0,12"
                                           TextWrapping="Wrap"/>
                                <Button x:Name="RestoreBackupBtn"
                                        Content="استعادة من ملف..."
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Foreground="#C62828"
                                        Height="36" HorizontalAlignment="Stretch"
                                        Click="RestoreBackup_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Clean old backups -->
                        <Border Background="White" CornerRadius="8" Padding="18,14">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4" Opacity="0.08" ShadowDepth="1"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="🧹 تنظيف النسخ القديمة"
                                           FontSize="13" FontWeight="Bold"
                                           Foreground="#555" Margin="0,0,0,6"/>
                                <TextBlock x:Name="RetentionInfoText"
                                           FontSize="11" Foreground="#888" Margin="0,0,0,12"
                                           TextWrapping="Wrap"
                                           Text="حذف النسخ التلقائية الأقدم من مدة الاحتفاظ المحددة"/>
                                <Button x:Name="CleanBackupsBtn"
                                        Content="تنظيف الآن"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Height="36" HorizontalAlignment="Stretch"
                                        Click="CleanBackups_Click"/>
                            </StackPanel>
                        </Border>

                    </UniformGrid>

                    <!-- Status message -->
                    <Border Grid.Row="1" x:Name="BackupMsgBorder"
                            CornerRadius="4" Padding="12,8" Margin="0,0,0,12"
                            Visibility="Collapsed">
                        <TextBlock x:Name="BackupMsgText" FontSize="12" TextWrapping="Wrap"/>
                    </Border>

                    <!-- History grid -->
                    <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="16">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="4" Opacity="0.08" ShadowDepth="1"/>
                        </Border.Effect>
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="سجل النسخ الاحتياطية"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="#1a7a60"/>
                                <Button Grid.Column="1"
                                        Content="🔄 تحديث"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Height="30" Click="RefreshBackupHistory_Click"/>
                            </Grid>

                            <DataGrid x:Name="BackupHistoryGrid"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" SelectionMode="Single"
                                      Style="{StaticResource MaterialDesignDataGrid}"
                                      materialDesign:DataGridAssist.CellPadding="10 6 10 6"
                                      RowBackground="White"
                                      AlternatingRowBackground="#F9FBF9"
                                      MaxHeight="340">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                <Setter Property="Background" Value="#FFF0F0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="اسم الملف"
                                                        Binding="{Binding FileName}" Width="*"/>
                                    <DataGridTextColumn Header="النوع"
                                                        Binding="{Binding BackupType}" Width="110"/>
                                    <DataGridTextColumn Header="الحجم"
                                                        Binding="{Binding FileSizeDisplay}" Width="90"/>
                                    <DataGridTextColumn Header="الحالة"
                                                        Binding="{Binding Status}" Width="80"/>
                                    <DataGridTextColumn Header="بواسطة"
                                                        Binding="{Binding CreatedByName}" Width="120"/>
                                    <DataGridTextColumn Header="التاريخ"
                                                        Binding="{Binding CreatedAt}" Width="155"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                </Grid>
            </TabItem>

            <!-- ══════════════ APP SETTINGS TAB ══════════════ -->
            <TabItem Header="إعدادات النظام">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16" MaxWidth="720">

                        <!-- Backup settings group -->
                        <Border Background="White" CornerRadius="8" Padding="20"
                                Margin="0,0,0,16">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4" Opacity="0.08" ShadowDepth="1"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="💾  إعدادات النسخ الاحتياطي"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="#1a7a60" Margin="0,0,0,16"/>

                                <!-- Backup path -->
                                <TextBlock Text="مجلد حفظ النسخ الاحتياطية"
                                           FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             x:Name="BackupPathBox"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             Height="40" Margin="0,0,8,0"
                                             materialDesign:HintAssist.Hint="مسار مجلد النسخ الاحتياطية"/>
                                    <Button Grid.Column="1"
                                            Content="📂 تصفح"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Height="40" Width="90"
                                            Click="BrowseBackupPath_Click"/>
                                </Grid>

                                <!-- Retention days -->
                                <TextBlock Text="مدة الاحتفاظ بالنسخ (بالأيام)"
                                           FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                                <TextBox x:Name="RetentionDaysBox"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Height="40" Width="200"
                                         HorizontalAlignment="Right"
                                         Margin="0,0,0,0"
                                         PreviewTextInput="NumberOnly"
                                         materialDesign:HintAssist.Hint="عدد الأيام (مثال: 365)"/>
                            </StackPanel>
                        </Border>

                        <!-- Entry rules group -->
                        <Border Background="White" CornerRadius="8" Padding="20"
                                Margin="0,0,0,16">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4" Opacity="0.08" ShadowDepth="1"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="📋  قواعد إدخال البيانات"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="#1a7a60" Margin="0,0,0,16"/>

                                <CheckBox x:Name="PreventDuplicateChk"
                                          Content="منع تكرار رقم السجين في النظام"
                                          Margin="0,0,0,10" FontSize="13"/>
                                <CheckBox x:Name="RequireExactTenChk"
                                          Content="رقم السجين يجب أن يكون 10 أرقام بالضبط"
                                          Margin="0,0,0,10" FontSize="13"/>
                                <CheckBox x:Name="RequireLocationChk"
                                          Content="إلزامية تحديد الموقع الفيزيائي عند إنشاء الدوسية"
                                          Margin="0,0,0,10" FontSize="13"/>
                                <CheckBox x:Name="RequireMovementReasonChk"
                                          Content="إلزامية إدخال سبب نقل الدوسية"
                                          Margin="0,0,0,0" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <!-- Audit settings group -->
                        <Border Background="White" CornerRadius="8" Padding="20"
                                Margin="0,0,0,16">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4" Opacity="0.08" ShadowDepth="1"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="📜  تتبع التغييرات (سجل المراجعة)"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="#1a7a60" Margin="0,0,0,16"/>

                                <CheckBox x:Name="AuditEditsChk"
                                          Content="تسجيل عمليات التعديل على السجلات"
                                          Margin="0,0,0,10" FontSize="13"/>
                                <CheckBox x:Name="AuditPrintingChk"
                                          Content="تسجيل عمليات الطباعة"
                                          Margin="0,0,0,10" FontSize="13"/>
                                <CheckBox x:Name="AuditImportsChk"
                                          Content="تسجيل عمليات الاستيراد"
                                          Margin="0,0,0,0" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <!-- Font scale group -->
                        <Border Background="White" CornerRadius="8" Padding="20"
                            Margin="0,0,0,16">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="4" Opacity="0.08" ShadowDepth="1"/>
                                                </Border.Effect>
                                                <StackPanel>
                                                    <TextBlock Text="🔤  حجم الخط"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="#1a7a60" Margin="0,0,0,16"/>

                                                    <TextBlock Text="حجم عرض النصوص والعناصر في النظام"
                                       FontSize="12" Foreground="#555" Margin="0,0,0,10"/>

                                                    <ComboBox x:Name="FontScaleCombo"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Width="220" Height="40"
                                      HorizontalAlignment="Right">
                                    <ComboBoxItem Content="عادي (Normal)"  Tag="Normal"/>
                                    <ComboBoxItem Content="كبير (Large)"   Tag="Large"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- Status message -->
                        <Border x:Name="SettingsMsgBorder"
                                CornerRadius="4" Padding="12,8" Margin="0,0,0,12"
                                Visibility="Collapsed">
                            <TextBlock x:Name="SettingsMsgText" FontSize="12"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- Save button -->
                        <Button x:Name="SaveSettingsBtn"
                                Content="💾  حفظ الإعدادات"
