<Page x:Class="ArchiveSystem.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="الإعدادات"
      Background="{StaticResource MidnightBase}"
      FontFamily="Noto Kufi Arabic, Segoe UI"
      FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                BorderThickness="0,0,0,1">
            <Border.Background>
                <SolidColorBrush Color="#0A1628" Opacity="0.60"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
            </Border.BorderBrush>
            <TextBlock Text="⚙️  الإعدادات"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource RoseGold}"
                       VerticalAlignment="Center"
                       Margin="32,0"/>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1"
                    Margin="24"
                    Style="{StaticResource MaterialDesignTabControl}"
                    Background="Transparent">

            <!-- ══════════════ USERS TAB ══════════════ -->
            <TabItem Header="المستخدمون">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="AddUserBtn"
                                Content="➕ إضافة مستخدم"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{StaticResource EmeraldMid}" Foreground="White"
                                Height="36" Click="AddUser_Click"/>
                        <Button x:Name="ChangePasswordBtn"
                                Content="🔑 تغيير كلمة المرور"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="{StaticResource TextSecondary}"
                                Height="36" Margin="10,0,0,0"
                                Click="ChangePassword_Click"/>
                        <Button x:Name="ToggleActiveBtn"
                                Content="تعطيل / تفعيل"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="{StaticResource TextSecondary}"
                                Height="36" Margin="10,0,0,0"
                                Click="ToggleActive_Click"/>
                    </StackPanel>

                    <Border Grid.Row="1" CornerRadius="8" BorderThickness="1">
                        <Border.Background>
                            <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                        </Border.BorderBrush>
                        <DataGrid x:Name="UsersGrid"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" SelectionMode="Single"
                                  Style="{StaticResource MaterialDesignDataGrid}"
                                  materialDesign:DataGridAssist.CellPadding="12 8 12 8"
                                  Background="Transparent"
                                  Foreground="{StaticResource TextSecondary}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="الاسم الكامل"
                                                    Binding="{Binding FullName}" Width="*"/>
                                <DataGridTextColumn Header="اسم المستخدم"
                                                    Binding="{Binding Username}" Width="140"/>
                                <DataGridTextColumn Header="رقم الموظف"
                                                    Binding="{Binding EmployeeNumber}" Width="120"/>
                                <DataGridTextColumn Header="آخر دخول"
                                                    Binding="{Binding LastLoginAt}" Width="160"/>
                                <DataGridCheckBoxColumn Header="نشط"
                                                        Binding="{Binding IsActive}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══════════════ ROLES TAB ══════════════ -->
            <TabItem Header="الأدوار والصلاحيات">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="AddRoleBtn"
                                Content="➕ إضافة دور"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{StaticResource EmeraldMid}" Foreground="White"
                                Height="36" Click="AddRole_Click"/>
                        <Button x:Name="EditRoleBtn"
                                Content="✏️ تعديل الدور والصلاحيات"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="{StaticResource TextSecondary}"
                                Height="36" Margin="10,0,0,0" Click="EditRole_Click"/>
                        <Button x:Name="DeleteRoleBtn"
                                Content="🗑 حذف الدور"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="{StaticResource DangerRed}"
                                Height="36" Margin="10,0,0,0"
                                Click="DeleteRole_Click"/>
                    </StackPanel>

                    <Border Grid.Row="1" CornerRadius="8" BorderThickness="1">
                        <Border.Background>
                            <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                        </Border.BorderBrush>
                        <DataGrid x:Name="RolesGrid"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" SelectionMode="Single"
                                  Style="{StaticResource MaterialDesignDataGrid}"
                                  materialDesign:DataGridAssist.CellPadding="12 8 12 8"
                                  Background="Transparent"
                                  Foreground="{StaticResource TextSecondary}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="اسم الدور"
                                                    Binding="{Binding RoleName}" Width="*"/>
                                <DataGridTextColumn Header="الوصف"
                                                    Binding="{Binding Description}" Width="*"/>
                                <DataGridCheckBoxColumn Header="دور أساسي"
                                                        Binding="{Binding IsSystemRole}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══════════════ CUSTOM FIELDS TAB ══════════════ -->
            <TabItem Header="الحقول المخصصة">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button x:Name="AddFieldBtn"
                                    Content="➕ إضافة حقل"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{StaticResource EmeraldMid}" Foreground="White"
                                    Height="36" Click="AddField_Click"/>
                            <Button x:Name="EditFieldBtn"
                                    Content="✏️ تعديل"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="{StaticResource TextSecondary}"
                                    Height="36" Margin="10,0,0,0" Click="EditField_Click"/>
                            <Button x:Name="ToggleFieldBtn"
                                    Content="تفعيل / تعطيل"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="{StaticResource TextSecondary}"
                                    Height="36" Margin="10,0,0,0" Click="ToggleField_Click"/>
                        </StackPanel>

                        <TextBlock Grid.Column="2"
                                   Text="انقر مرتين على صف لفتح نافذة التعديل"
                                   FontSize="11" Foreground="#4A5A7A"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <Border Grid.Row="1" CornerRadius="8" BorderThickness="1">
                        <Border.Background>
                            <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                        </Border.BorderBrush>
                        <DataGrid x:Name="FieldsGrid"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" SelectionMode="Single"
                                  Style="{StaticResource MaterialDesignDataGrid}"
                                  materialDesign:DataGridAssist.CellPadding="10 7 10 7"
                                  Background="Transparent"
                                  Foreground="{StaticResource TextSecondary}"
                                  MouseDoubleClick="FieldsGrid_DoubleClick">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                            <Setter Property="Opacity" Value="0.45"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="التسمية العربية"
                                                    Binding="{Binding ArabicLabel}" Width="*"/>
                                <DataGridTextColumn Header="النوع"
                                                    Binding="{Binding FieldTypeArabic}" Width="150"/>
                                <DataGridTextColumn Header="الترتيب"
                                                    Binding="{Binding SortOrder}" Width="70"/>
                                <DataGridCheckBoxColumn Header="مطلوب"
                                                        Binding="{Binding IsRequired}" Width="70"/>
                                <DataGridCheckBoxColumn Header="الإدخال"
                                                        Binding="{Binding ShowInEntry}" Width="70"/>
                                <DataGridCheckBoxColumn Header="كل البيانات"
                                                        Binding="{Binding ShowInAllData}" Width="90"/>
                                <DataGridCheckBoxColumn Header="التقارير"
                                                        Binding="{Binding ShowInReports}" Width="75"/>
                                <DataGridCheckBoxColumn Header="إحصاءات"
                                                        Binding="{Binding EnableStatistics}" Width="75"/>
                                <DataGridCheckBoxColumn Header="نشط"
                                                        Binding="{Binding IsActive}" Width="55"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══════════════ ARCHIVE STRUCTURE TAB ══════════════ -->
            <TabItem Header="هيكل الأرشيف">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Add location form -->
                    <Border Grid.Row="0" CornerRadius="6" BorderThickness="1"
                            Padding="16,12" Margin="0,0,0,14">
                        <Border.Background>
                            <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                        </Border.BorderBrush>
                        <StackPanel>
                            <TextBlock Text="إضافة موقع جديد"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource RoseGold}" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0" x:Name="LocHallwayBox"
                                         materialDesign:HintAssist.Hint="ممر *"
                                         materialDesign:HintAssist.Foreground="#4A5A7A"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Height="49" PreviewTextInput="NumberOnly"/>
                                <TextBox Grid.Column="2" x:Name="LocCabinetBox"
                                         materialDesign:HintAssist.Hint="كبينة *"
                                         materialDesign:HintAssist.Foreground="#4A5A7A"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Height="49" PreviewTextInput="NumberOnly"/>
                                <TextBox Grid.Column="4" x:Name="LocShelfBox"
                                         materialDesign:HintAssist.Hint="رف *"
                                         materialDesign:HintAssist.Foreground="#4A5A7A"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Height="49" PreviewTextInput="NumberOnly"/>
                                <TextBox Grid.Column="6" x:Name="LocLabelBox"
                                         materialDesign:HintAssist.Hint="تسمية (اختياري)"
                                         materialDesign:HintAssist.Foreground="#4A5A7A"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Height="49"/>
                                <TextBox Grid.Column="8" x:Name="LocCapacityBox"
                                         materialDesign:HintAssist.Hint="السعة (اختياري)"
                                         materialDesign:HintAssist.Foreground="#4A5A7A"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Height="49" PreviewTextInput="NumberOnly"/>
                                <Button Grid.Column="10"
                                        Content="➕ إضافة"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="{StaticResource EmeraldMid}" Foreground="White"
                                        Height="49" Width="90"
                                        Click="AddLocation_Click"/>
                            </Grid>

                            <Border x:Name="LocErrorBorder"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="8,5" Margin="0,8,0,0"
                                    Visibility="Collapsed">
                                <Border.Background>
                                    <SolidColorBrush Color="#E53935" Opacity="0.10"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#E53935" Opacity="0.30"/>
                                </Border.BorderBrush>
                                <TextBlock x:Name="LocErrorText"
                                           Foreground="{StaticResource DangerRed}" FontSize="12"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Toolbar -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="EditLocBtn"
                                Content="✏️ تعديل"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="{StaticResource TextSecondary}"
                                Height="34" Click="EditLocation_Click"/>
                        <Button x:Name="ToggleLocBtn"
                                Content="تفعيل / تعطيل"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="{StaticResource TextSecondary}"
                                Height="34" Margin="10,0,0,0"
                                Click="ToggleLocation_Click"/>
                        <TextBlock Text="الأماكن المعطلة تُخفى من قوائم الاختيار ولكنها محفوظة للتاريخ"
                                   FontSize="11" Foreground="#4A5A7A"
                                   VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>

                    <!-- Locations grid -->
                    <Border Grid.Row="2" CornerRadius="8" BorderThickness="1">
                        <Border.Background>
                            <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                        </Border.BorderBrush>
                        <DataGrid x:Name="LocationsGrid"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" SelectionMode="Single"
                                  Style="{StaticResource MaterialDesignDataGrid}"
                                  materialDesign:DataGridAssist.CellPadding="10 7 10 7"
                                  Background="Transparent"
                                  Foreground="{StaticResource TextSecondary}">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                            <Setter Property="Opacity" Value="0.45"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="الموقع"
                                                    Binding="{Binding Display}" Width="*"/>
                                <DataGridTextColumn Header="تسمية"
                                                    Binding="{Binding Label}" Width="130"/>
                                <DataGridTextColumn Header="السعة"
                                                    Binding="{Binding Capacity}" Width="80"/>
                                <DataGridCheckBoxColumn Header="نشط"
                                                        Binding="{Binding IsActive}" Width="60"/>
                                <DataGridTextColumn Header="الإشغال"
                                                    Binding="{Binding OccupancyDisplay}" Width="100"/>
                                <DataGridTextColumn Header="الحالة"
                                                    Binding="{Binding StatusDisplay}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══════════════ BACKUP TAB ══════════════ -->
            <TabItem Header="النسخ الاحتياطي">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Three main action cards -->
                    <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,10">

                        <!-- Create backup -->
                        <Border CornerRadius="8" Padding="18,14" BorderThickness="1"
                                Margin="0,0,10,0">
                            <Border.Background>
                                <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                            </Border.BorderBrush>
                            <StackPanel>
                                <TextBlock Text="💾 إنشاء نسخة احتياطية"
                                           FontSize="13" FontWeight="Bold"
                                           Foreground="{StaticResource RoseGold}" Margin="0,0,0,6"/>
                                <TextBlock Text="نسخ قاعدة البيانات يدوياً الآن"
                                           FontSize="11" Foreground="#4A5A7A" Margin="0,0,0,12"
                                           TextWrapping="Wrap"/>
                                <Button x:Name="CreateBackupBtn"
                                        Content="إنشاء نسخة الآن"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="{StaticResource EmeraldMid}" Foreground="White"
                                        Height="36" HorizontalAlignment="Stretch"
                                        Click="CreateBackup_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Restore -->
                        <Border CornerRadius="8" Padding="18,14" BorderThickness="1"
                                Margin="0,0,10,0">
                            <Border.Background>
                                <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                            </Border.BorderBrush>
                            <StackPanel>
                                <TextBlock Text="♻️ استعادة نسخة احتياطية"
                                           FontSize="13" FontWeight="Bold"
                                           Foreground="{StaticResource RoseGold}" Margin="0,0,0,6"/>
                                <TextBlock Text="استبدال قاعدة البيانات بملف نسخة احتياطية"
                                           FontSize="11" Foreground="#4A5A7A" Margin="0,0,0,12"
                                           TextWrapping="Wrap"/>
                                <Button x:Name="RestoreBackupBtn"
                                        Content="استعادة من ملف..."
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Foreground="{StaticResource DangerRed}"
                                        Height="36" HorizontalAlignment="Stretch"
                                        Click="RestoreBackup_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Clean old backups -->
                        <Border CornerRadius="8" Padding="18,14" BorderThickness="1">
                            <Border.Background>
                                <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                            </Border.BorderBrush>
                            <StackPanel>
                                <TextBlock Text="🧹 تنظيف النسخ القديمة"
                                           FontSize="13" FontWeight="Bold"
                                           Foreground="{StaticResource RoseGold}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="RetentionInfoText"
                                           FontSize="11" Foreground="#4A5A7A" Margin="0,0,0,12"
                                           TextWrapping="Wrap"
                                           Text="حذف النسخ التلقائية الأقدم من مدة الاحتفاظ المحددة"/>
                                <Button x:Name="CleanBackupsBtn"
                                        Content="تنظيف الآن"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Foreground="{StaticResource TextSecondary}"
                                        Height="36" HorizontalAlignment="Stretch"
                                        Click="CleanBackups_Click"/>
                            </StackPanel>
                        </Border>

                    </UniformGrid>

                    <!-- Users & permissions backup card -->
                    <Border Grid.Row="1" CornerRadius="8" Padding="18,14" BorderThickness="1"
                            Margin="0,0,0,10">
                        <Border.Background>
                            <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                        </Border.BorderBrush>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                                <TextBlock Text="👥 نسخ احتياطي للمستخدمين والصلاحيات"
                                           FontSize="13" FontWeight="Bold"
                                           Foreground="{StaticResource RoseGold}" Margin="0,0,0,6"/>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#4A5A7A">
                                    ينشئ ملف قاعدة بيانات صغير يحتوي فقط على المستخدمين وأدوارهم
                                    وصلاحياتهم — دون أي بيانات أرشيف. مفيد لنقل إعدادات المستخدمين
                                    إلى جهاز آخر أو الاحتفاظ بنسخة منفصلة من هيكل الصلاحيات.
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBox x:Name="UsersBackupPathBox"
                                         materialDesign:HintAssist.Hint="مجلد الحفظ (اختياري)"
                                         materialDesign:HintAssist.Foreground="#4A5A7A"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Width="240" Height="49"
                                         Margin="0,0,8,0"
                                         IsReadOnly="True"
                                         ToolTip="اتركه فارغاً لاستخدام مجلد النسخ الاحتياطية الافتراضي"/>

                                <Button Content="📂"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Foreground="{StaticResource TextSecondary}"
                                        Height="40" Width="49"
                                        Margin="0,0,8,0"
                                        ToolTip="اختر مجلد الحفظ"
                                        Click="BrowseUsersBackupPath_Click"/>

                                <Button x:Name="CreateUsersBackupBtn"
                                        Content="نسخ المستخدمين"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="{StaticResource EmeraldMid}" Foreground="White"
                                        Height="40" Width="148"
                                        Click="CreateUsersBackup_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Status message -->
                    <Border Grid.Row="2" x:Name="BackupMsgBorder"
                            CornerRadius="4" Padding="12,8" Margin="0,0,0,12"
                            Visibility="Collapsed">
                        <TextBlock x:Name="BackupMsgText" FontSize="12" TextWrapping="Wrap"/>
                    </Border>

                    <!-- History grid -->
                    <Border Grid.Row="3" CornerRadius="8" Padding="16" BorderThickness="1">
                        <Border.Background>
                            <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                        </Border.BorderBrush>
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="سجل النسخ الاحتياطية"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource RoseGold}"/>
                                <Button Grid.Column="1"
                                        Content="🔄 تحديث"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Foreground="{StaticResource TextSecondary}"
                                        Height="30" Click="RefreshBackupHistory_Click"/>
                            </Grid>

                            <DataGrid x:Name="BackupHistoryGrid"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" SelectionMode="Single"
                                      Style="{StaticResource MaterialDesignDataGrid}"
                                      materialDesign:DataGridAssist.CellPadding="10 6 10 6"
                                      Background="Transparent"
                                      Foreground="{StaticResource TextSecondary}"
                                      MaxHeight="340">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="#E53935" Opacity="0.10"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="اسم الملف"
                                                        Binding="{Binding FileName}" Width="*"/>
                                    <DataGridTextColumn Header="النوع"
                                                        Binding="{Binding BackupType}" Width="110"/>
                                    <DataGridTextColumn Header="الحجم"
                                                        Binding="{Binding FileSizeDisplay}" Width="90"/>
                                    <DataGridTextColumn Header="الحالة"
                                                        Binding="{Binding Status}" Width="80"/>
                                    <DataGridTextColumn Header="بواسطة"
                                                        Binding="{Binding CreatedByName}" Width="120"/>
                                    <DataGridTextColumn Header="التاريخ"
                                                        Binding="{Binding CreatedAt}" Width="155"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                </Grid>
            </TabItem>

            <!-- ══════════════ APP SETTINGS TAB ══════════════ -->
            <TabItem Header="إعدادات النظام">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16" MaxWidth="720">

                        <!-- Version card -->
                        <Border CornerRadius="8" Padding="16,12" BorderThickness="1"
                                Margin="0,0,0,16">
                            <Border.Background>
                                <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                            </Border.BorderBrush>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="ℹ️  إصدار النظام"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="{StaticResource RoseGold}"/>
                                    <TextBlock Text="رقم الإصدار الحالي المثبَّت"
                                               FontSize="11" Foreground="#4A5A7A"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <Border Grid.Column="1" CornerRadius="6"
                                        Padding="14,6" VerticalAlignment="Center"
                                        BorderThickness="1">
                                    <Border.Background>
                                        <SolidColorBrush Color="#00E676" Opacity="0.08"/>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="#00E676" Opacity="0.20"/>
                                    </Border.BorderBrush>
                                    <TextBlock x:Name="AppVersionLabel"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource EmeraldMid}"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Backup settings group -->
                        <Border CornerRadius="8" Padding="20" BorderThickness="1"
                                Margin="0,0,0,16">
                            <Border.Background>
                                <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                            </Border.BorderBrush>
                            <StackPanel>
                                <TextBlock Text="💾  إعدادات النسخ الاحتياطي"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource RoseGold}" Margin="0,0,0,16"/>

                                <TextBlock Text="مجلد حفظ النسخ الاحتياطية"
                                           FontSize="12" Foreground="#4A5A7A" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             x:Name="BackupPathBox"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="مسار مجلد النسخ الاحتياطية"
                                             materialDesign:HintAssist.Foreground="#4A5A7A"
                                             Height="50" Margin="0,0,8,0"/>
                                    <Button Grid.Column="1"
                                            Content="📂 تصفح"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Foreground="{StaticResource TextSecondary}"
                                            Height="40" Width="90"
                                            Click="BrowseBackupPath_Click"/>
                                </Grid>

                                <TextBlock Text="مدة الاحتفاظ بالنسخ (بالأيام)"
                                           FontSize="12" Foreground="#4A5A7A" Margin="0,0,0,4"/>
                                <TextBox x:Name="RetentionDaysBox"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="عدد الأيام (مثال: 365)"
                                         materialDesign:HintAssist.Foreground="#4A5A7A"
                                         Height="50" Width="200"
                                         HorizontalAlignment="Right"
                                         PreviewTextInput="NumberOnly"/>

                                <TextBlock Text="وقت النسخ الاحتياطي اليومي التلقائي"
                                           FontSize="12" Foreground="#4A5A7A" Margin="0,14,0,4"/>
                                <TextBox x:Name="BackupTimeBox"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="مثال: 02:00"
                                         materialDesign:HintAssist.Foreground="#4A5A7A"
                                         Height="50" Width="200"
                                         HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Border>

                        <!-- Entry rules group -->
                        <Border CornerRadius="8" Padding="20" BorderThickness="1"
                                Margin="0,0,0,16">
                            <Border.Background>
                                <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                            </Border.BorderBrush>
                            <StackPanel>
                                <TextBlock Text="📋  قواعد إدخال البيانات"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource RoseGold}" Margin="0,0,0,16"/>

                                <CheckBox x:Name="PreventDuplicateChk"
                                          Content="منع تكرار رقم السجين في النظام"
                                          Foreground="{StaticResource TextSecondary}"
                                          Margin="0,0,0,10" FontSize="13"/>
                                <CheckBox x:Name="RequireExactTenChk"
                                          Content="رقم السجين يجب أن يكون 10 أرقام بالضبط"
                                          Foreground="{StaticResource TextSecondary}"
                                          Margin="0,0,0,10" FontSize="13"/>
                                <CheckBox x:Name="RequireLocationChk"
                                          Content="إلزامية تحديد الموقع الفيزيائي عند إنشاء الدوسية"
                                          Foreground="{StaticResource TextSecondary}"
                                          Margin="0,0,0,10" FontSize="13"/>
                                <CheckBox x:Name="RequireMovementReasonChk"
                                          Content="إلزامية إدخال سبب نقل الدوسية"
                                          Foreground="{StaticResource TextSecondary}"
                                          Margin="0,0,0,0" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <!-- Audit settings group -->
                        <Border CornerRadius="8" Padding="20" BorderThickness="1"
                                Margin="0,0,0,16">
                            <Border.Background>
                                <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                            </Border.BorderBrush>
                            <StackPanel>
                                <TextBlock Text="📜  تتبع التغييرات (سجل الاحداث)"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource RoseGold}" Margin="0,0,0,16"/>

                                <CheckBox x:Name="AuditEditsChk"
                                          Content="تسجيل عمليات التعديل على السجلات"
                                          Foreground="{StaticResource TextSecondary}"
                                          Margin="0,0,0,10" FontSize="13"/>
                                <CheckBox x:Name="AuditPrintingChk"
                                          Content="تسجيل عمليات الطباعة"
                                          Foreground="{StaticResource TextSecondary}"
                                          Margin="0,0,0,10" FontSize="13"/>
                                <CheckBox x:Name="AuditImportsChk"
                                          Content="تسجيل عمليات الاستيراد"
                                          Foreground="{StaticResource TextSecondary}"
                                          Margin="0,0,0,0" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <!-- Theme Color group -->
                        <Border CornerRadius="8" Padding="20" BorderThickness="1"
                                Margin="0,0,0,16">
                            <Border.Background>
                                <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                            </Border.BorderBrush>
                            <StackPanel>
                                <TextBlock Text="🎨  لون النظام"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource RoseGold}" Margin="0,0,0,14"/>

                                <TextBlock Text="اختر اللون الرئيسي لواجهة النظام"
                                           FontSize="12" Foreground="#4A5A7A" Margin="0,0,0,10"/>

                                <WrapPanel x:Name="ColorSwatchPanel" Margin="0,0,0,4"/>

                                <TextBlock x:Name="SelectedColorText"
                                           FontSize="11" Foreground="#4A5A7A"
                                           Margin="0,8,0,0"/>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="أو أدخل لوناً مخصصاً:"
                                               FontSize="12" Foreground="#4A5A7A"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBox Grid.Column="1" x:Name="CustomHexBox"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="#RRGGBB"
                                             materialDesign:HintAssist.Foreground="#4A5A7A"
                                             Height="49" MaxLength="7"/>
                                    <Button Grid.Column="2" Content="تطبيق"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Foreground="{StaticResource TextSecondary}"
                                            Height="36" Width="70" Margin="8,0,0,0"
                                            Click="ApplyCustomHex_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Font scale group -->
                        <Border CornerRadius="8" Padding="20" BorderThickness="1"
                                Margin="0,0,0,16">
                            <Border.Background>
                                <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                            </Border.BorderBrush>
                            <StackPanel>
                                <TextBlock Text="🔤  حجم الخط"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource RoseGold}" Margin="0,0,0,16"/>

                                <TextBlock Text="حجم عرض النصوص والعناصر في النظام"
                                           FontSize="12" Foreground="#4A5A7A" Margin="0,0,0,10"/>

                                <ComboBox x:Name="FontScaleCombo"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          Width="220" Height="50"
                                          HorizontalAlignment="Right">
                                    <ComboBoxItem Content="عادي (Normal)"  Tag="Normal"/>
                                    <ComboBoxItem Content="كبير (Large)"   Tag="Large"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- Density group -->
                        <Border CornerRadius="8" Padding="20" BorderThickness="1"
                                Margin="0,0,0,16">
                            <Border.Background>
                                <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                            </Border.BorderBrush>
                            <StackPanel>
                                <TextBlock Text="📐  كثافة العرض"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource RoseGold}" Margin="0,0,0,16"/>
                                <TextBlock Text="Comfortable = مسافات أوسع | Compact = مسافات أضيق"
                                           FontSize="12" Foreground="#4A5A7A" Margin="0,0,0,10"/>
                                <ComboBox x:Name="DensityCombo"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          Width="220" Height="50" HorizontalAlignment="Right">
                                    <ComboBoxItem Content="مريح (Comfortable)" Tag="Comfortable"/>
                                    <ComboBoxItem Content="مدمج (Compact)"     Tag="Compact"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- Status message -->
                        <Border x:Name="SettingsMsgBorder"
                                CornerRadius="4" Padding="12,8" Margin="0,0,0,12"
                                Visibility="Collapsed">
                            <TextBlock x:Name="SettingsMsgText" FontSize="12" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Keyboard shortcuts card -->
                        <Border CornerRadius="8" Padding="20" BorderThickness="1"
                                Margin="0,0,0,16">
                            <Border.Background>
                                <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                            </Border.BorderBrush>
                            <StackPanel>
                                <TextBlock Text="⌨️  اختصارات لوحة المفاتيح — صفحة الإدخال"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource RoseGold}" Margin="0,0,0,16"/>

                                <TextBlock Text="زر حفظ السجل"
                                           FontSize="12" Foreground="#4A5A7A" Margin="0,0,0,4"/>
                                <ComboBox x:Name="SaveKeyCombo"
                                          Width="220" Height="50"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          HorizontalAlignment="Right"
                                          Margin="0,0,0,14"
                                          FlowDirection="LeftToRight">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontFamily="Segoe UI"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Text="زر مسح الحقول"
                                           FontSize="12" Foreground="#4A5A7A" Margin="0,0,0,4"/>
                                <ComboBox x:Name="ClearKeyCombo"
                                          Width="220" Height="50"
                                          HorizontalAlignment="Right"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          FlowDirection="LeftToRight">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontFamily="Segoe UI"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Text="التغيير يسري عند فتح صفحة الإدخال مجدداً."
                                           FontSize="11" Foreground="#4A5A7A"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Save button -->
                        <Button x:Name="SaveSettingsBtn"
                                Content="💾  حفظ الإعدادات"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{StaticResource EmeraldMid}" Foreground="White"
                                FontSize="14" Height="44" Width="180"
                                HorizontalAlignment="Left"
                                Click="SaveSettings_Click"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</Page>
