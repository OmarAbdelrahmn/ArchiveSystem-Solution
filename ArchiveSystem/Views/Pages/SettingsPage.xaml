<Page x:Class="ArchiveSystem.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="الإعدادات" Background="#F5F5F5"
      FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White"
                BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
            <TextBlock Text="⚙️  الإعدادات"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#1a7a60"
                       VerticalAlignment="Center"
                       Margin="32,0"/>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1"
                    Margin="24"
                    Style="{StaticResource MaterialDesignTabControl}">

            <!-- ══════════════ USERS TAB ══════════════ -->
            <TabItem Header="المستخدمون">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="0,0,0,12">
                        <Button x:Name="AddUserBtn" 
                                Content="➕ إضافة مستخدم"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#1a7a60" Foreground="White"
                                Height="36"
                                Click="AddUser_Click"/>
                        <Button x:Name="ChangePasswordBtn"
                                Content="🔑 تغيير كلمة المرور"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="36" Margin="10,0,0,0"
                                Click="ChangePassword_Click"/>
                        <Button x:Name="ToggleActiveBtn"
                                Content="تعطيل / تفعيل"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="36" Margin="10,0,0,0"
                                Click="ToggleActive_Click"/>
                    </StackPanel>

                    <!-- Users Table -->
                    <DataGrid Grid.Row="1"
                              x:Name="UsersGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              Style="{StaticResource MaterialDesignDataGrid}"
                              materialDesign:DataGridAssist.CellPadding="12 8 12 8"
                              RowBackground="White"
                              AlternatingRowBackground="#F9FBF9">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="الاسم الكامل"
                                                Binding="{Binding FullName}"
                                                Width="*"/>
                            <DataGridTextColumn Header="اسم المستخدم"
                                                Binding="{Binding Username}"
                                                Width="140"/>
                            <DataGridTextColumn Header="رقم الموظف"
                                                Binding="{Binding EmployeeNumber}"
                                                Width="120"/>
                            <DataGridTextColumn Header="آخر دخول"
                                                Binding="{Binding LastLoginAt}"
                                                Width="160"/>
                            <DataGridCheckBoxColumn Header="نشط"
                                                    Binding="{Binding IsActive}"
                                                    Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ══════════════ ROLES TAB ══════════════ -->
            <TabItem Header="الأدوار والصلاحيات">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="0,0,0,12">
                        <Button x:Name="AddRoleBtn"
                                Content="➕ إضافة دور"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#1a7a60" Foreground="White"
                                Height="36"
                                Click="AddRole_Click"/>
                        <Button x:Name="EditRoleBtn"
                                Content="✏️ تعديل الدور والصلاحيات"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="36" Margin="10,0,0,0"
                                Click="EditRole_Click"/>
                        <Button x:Name="DeleteRoleBtn" 
                                Content="🗑 حذف الدور"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="36" Margin="10,0,0,0"
                                Foreground="#C62828"
                                Click="DeleteRole_Click"/>
                    </StackPanel>

                    <!-- Roles Table -->
                    <DataGrid Grid.Row="1"
                              x:Name="RolesGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              Style="{StaticResource MaterialDesignDataGrid}"
                              materialDesign:DataGridAssist.CellPadding="12 8 12 8"
                              RowBackground="White"
                              AlternatingRowBackground="#F9FBF9">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="اسم الدور"
                                                Binding="{Binding RoleName}"
                                                Width="*"/>
                            <DataGridTextColumn Header="الوصف"
                                                Binding="{Binding Description}"
                                                Width="*"/>
                            <DataGridCheckBoxColumn Header="دور أساسي"
                                                    Binding="{Binding IsSystemRole}"
                                                    Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Page>