<Page x:Class="ArchiveSystem.Views.Pages.EntryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="إدخال بيانات"
      FlowDirection="RightToLeft">

    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#050D1A" Offset="0"/>
            <GradientStop Color="#0A1628" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#0D1F3C"
                BorderThickness="0,0,0,1">
            <Border.BorderBrush>
                <SolidColorBrush Color="#C9956A" Opacity="0.20"/>
            </Border.BorderBrush>
            <TextBlock Text="➕  إدخال بيانات"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource RoseGold}"
                       VerticalAlignment="Center"
                       Margin="32,0"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40,28,40,40" MaxWidth="900">

                <!-- ══ TWO COLUMNS ══ -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.45*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="0.45*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── DOSSIER SECTION ── -->
                    <Border Grid.Column="0"
                            CornerRadius="12"
                            Padding="24">
                        <Border.Background>
                            <SolidColorBrush Color="#0D1F3C" Opacity="0.85"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#C9956A40" Offset="0"/>
                                <GradientStop Color="#1E3050"   Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.BorderThickness>1</Border.BorderThickness>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" Opacity="0.25" ShadowDepth="4"
                                              Color="#000000"/>
                        </Border.Effect>
                        <StackPanel>

                            <TextBlock Text="بيانات الدوسية"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource RoseGold}"
                                       Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         x:Name="DossierNumberBox"
                                         materialDesign:HintAssist.Hint="رقم الدوسية *"
                                         materialDesign:HintAssist.Foreground="#3A9A95"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         PreviewTextInput="NumberOnly_PreviewTextInput"
                                         TextChanged="DossierNumberBox_TextChanged"/>

                                <Button Grid.Column="1"
                                        Content="تلقائي"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Foreground="{StaticResource EmeraldMid}"
                                        Height="40" Width="80"
                                        Margin="8,0,0,0"
                                        Click="AutoDossierNumber_Click"/>
                            </Grid>

                            <TextBlock x:Name="DossierStatusText"
                                       FontSize="12" Margin="0,-8,0,10"
                                       Foreground="#4A5A7A"/>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         x:Name="HijriMonthBox"
                                         materialDesign:HintAssist.Hint="الشهر الهجري (1-12) *"
                                         materialDesign:HintAssist.Foreground="#4A5A7A"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         PreviewTextInput="NumberOnly_PreviewTextInput"/>

                                <TextBox Grid.Column="2"
                                         x:Name="HijriYearBox"
                                         materialDesign:HintAssist.Hint="السنة الهجرية *"
                                         materialDesign:HintAssist.Foreground="#4A5A7A"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         PreviewTextInput="NumberOnly_PreviewTextInput"/>
                            </Grid>

                            <TextBox x:Name="ExpectedCountBox"
                                     materialDesign:HintAssist.Hint="عدد الملفات المتوقع (اختياري)"
                                     materialDesign:HintAssist.Foreground="#4A5A7A"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,0,14"
                                     PreviewTextInput="NumberOnly_PreviewTextInput"/>

                            <TextBlock Text="الموقع الفيزيائي"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource RoseGoldLight}"
                                       Margin="0,0,0,10"/>

                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0" x:Name="HallwayBox"
                                         materialDesign:HintAssist.Hint="ممر *"
                                         materialDesign:HintAssist.Foreground="#4A5A7A"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         PreviewTextInput="NumberOnly_PreviewTextInput"/>

                                <TextBox Grid.Column="2" x:Name="CabinetBox"
                                         materialDesign:HintAssist.Hint="كبينة *"
                                         materialDesign:HintAssist.Foreground="#4A5A7A"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         PreviewTextInput="NumberOnly_PreviewTextInput"/>

                                <TextBox Grid.Column="4" x:Name="ShelfBox"
                                         materialDesign:HintAssist.Hint="رف *"
                                         materialDesign:HintAssist.Foreground="#4A5A7A"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         PreviewTextInput="NumberOnly_PreviewTextInput"/>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- ── PRISONER SECTION ── -->
                    <Border Grid.Column="2"
                            CornerRadius="12"
                            Padding="24">
                        <Border.Background>
                            <SolidColorBrush Color="#0D1F3C" Opacity="0.85"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#00E67640" Offset="0"/>
                                <GradientStop Color="#1E3050"   Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.BorderThickness>1</Border.BorderThickness>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" Opacity="0.25" ShadowDepth="4"
                                              Color="#000000"/>
                        </Border.Effect>
                        <StackPanel>

                            <TextBlock Text="بيانات السجين"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource EmeraldGlow}"
                                       Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         x:Name="SequenceBox"
                                         materialDesign:HintAssist.Hint="رقم التسلسل *"
                                         materialDesign:HintAssist.Foreground="#4A5A7A"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         PreviewTextInput="NumberOnly_PreviewTextInput"/>

                                <Button Grid.Column="1"
                                        Content="تلقائي"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Foreground="{StaticResource EmeraldMid}"
                                        Height="40" Width="80"
                                        Margin="8,0,0,0"
                                        Click="AutoSequence_Click"/>
                            </Grid>

                            <TextBox x:Name="PersonNameBox"
                                     materialDesign:HintAssist.Hint="اسم السجين *"
                                     materialDesign:HintAssist.Foreground="#4A5A7A"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,0,14"/>

                            <TextBox x:Name="PrisonerNumberBox"
                                     materialDesign:HintAssist.Hint="رقم السجين (10 أرقام) *"
                                     materialDesign:HintAssist.Foreground="#4A5A7A"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     MaxLength="10"
                                     Margin="0,0,0,14"
                                     PreviewTextInput="NumberOnly_PreviewTextInput"/>

                            <TextBox x:Name="NotesBox"
                                     materialDesign:HintAssist.Hint="ملاحظات (اختياري)"
                                     materialDesign:HintAssist.Foreground="#4A5A7A"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     AcceptsReturn="True"
                                     Height="80"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,0,0,14"/>

                            <StackPanel x:Name="CustomFieldsPanel"/>

                        </StackPanel>
                    </Border>

                </Grid>

                <!-- Error banner -->
                <Border x:Name="ErrorBorder"
                        CornerRadius="8"
                        Padding="14,10"
                        Margin="0,0,0,14"
                        Visibility="Collapsed">
                    <Border.Background>
                        <SolidColorBrush Color="#FF5252" Opacity="0.10"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#FF5252" Opacity="0.35"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <TextBlock x:Name="ErrorText"
                               Foreground="{StaticResource DangerRed}"
                               FontSize="13" TextWrapping="Wrap"/>
                </Border>

                <!-- Success banner -->
                <Border x:Name="SuccessBorder"
                        CornerRadius="8"
                        Padding="14,10"
                        Margin="0,0,0,14"
                        Visibility="Collapsed">
                    <Border.Background>
                        <SolidColorBrush Color="#00E676" Opacity="0.08"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#00E676" Opacity="0.30"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <TextBlock x:Name="SuccessText"
                               Foreground="{StaticResource EmeraldGlow}"
                               FontSize="13" TextWrapping="Wrap"/>
                </Border>

                <!-- Action buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ClearRecordBtn"
                            Content="مسح الحقول"
                            ToolTip="مسح (F6)"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Foreground="{StaticResource TextSecondary}"
                            Height="42" Width="130"
                            Margin="0,0,12,0"
                            Click="ClearRecord_Click"/>

                    <Button x:Name="SaveRecordBtn"
                            Content="💾  حفظ السجل"
                            ToolTip="حفظ (F5)"
                            FontSize="14"
                            Height="42" Width="150"
                            Foreground="#050D1A"
                            FontWeight="SemiBold"
                            Click="SaveRecord_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
                            </Style>
                        </Button.Style>
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00BCD4" Offset="0"/>
                                <GradientStop Color="#00E676" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="14" ShadowDepth="0"
                                              Color="#00E676" Opacity="0.40"/>
                        </Button.Effect>
                    </Button>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
