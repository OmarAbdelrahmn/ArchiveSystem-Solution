<Page x:Class="ArchiveSystem.Views.Pages.BulkFillHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="سجل التعبئة الجماعية"
      Background="{StaticResource MidnightBase}"
      FontFamily="Noto Kufi Arabic, Segoe UI"
      FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                BorderThickness="0,0,0,1">
            <Border.Background>
                <SolidColorBrush Color="#0A1628" Opacity="0.60"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
            </Border.BorderBrush>
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="📝  سجل التعبئة الجماعية"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource RoseGold}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="📤 تصدير CSV"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="{StaticResource TextSecondary}"
                        Height="36"
                        Click="Export_Click"/>
            </Grid>
        </Border>

        <!-- FILTER BAR -->
        <Border Grid.Row="1"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <Border.Background>
                <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
            </Border.BorderBrush>
            <WrapPanel>

                <ComboBox x:Name="FieldCombo"
                          materialDesign:HintAssist.Hint="الحقل"
                          materialDesign:HintAssist.Foreground="#4A5A7A"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Width="172" Height="50"
                          SelectionChanged="Filter_Changed"/>

                <TextBox x:Name="UserBox"
                         materialDesign:HintAssist.Hint="المستخدم"
                         materialDesign:HintAssist.Foreground="#4A5A7A"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Width="160" Height="50"
                         TextChanged="Filter_Changed"/>

                <TextBox x:Name="DateFromBox"
                         materialDesign:HintAssist.Hint="من تاريخ (yyyy-MM-dd)"
                         materialDesign:HintAssist.Foreground="#4A5A7A"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Width="180" Height="50"
                         TextChanged="Filter_Changed"/>

                <TextBox x:Name="DateToBox"
                         materialDesign:HintAssist.Hint="إلى تاريخ (yyyy-MM-dd)"
                         materialDesign:HintAssist.Foreground="#4A5A7A"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Width="180" Height="50"
                         TextChanged="Filter_Changed"/>

                <Button Content="مسح"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="{StaticResource DangerRed}"
                        Height="40"
                        Click="Reset_Click"/>
            </WrapPanel>
        </Border>

        <!-- SUMMARY BAR -->
        <Border Grid.Row="2"
                BorderThickness="0,0,0,1"
                Padding="20,8">
            <Border.Background>
                <SolidColorBrush Color="#00E676" Opacity="0.05"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
            </Border.BorderBrush>
            <TextBlock x:Name="SummaryText"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource EmeraldMid}"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- TABLE -->
        <DataGrid Grid.Row="3"
                  x:Name="HistoryGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  Style="{StaticResource MaterialDesignDataGrid}"
                  materialDesign:DataGridAssist.CellPadding="12 8 12 8"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  Margin="12,0,12,12">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background">
                        <Setter.Value>
                            <SolidColorBrush Color="#0D1F3C" Opacity="0.60"/>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding NewValue}" Value="{x:Null}">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="#FFB300" Opacity="0.08"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="التاريخ والوقت"
                                    Binding="{Binding ExecutedAt}"
                                    Width="155"/>
                <DataGridTextColumn Header="المستخدم"
                                    Binding="{Binding ExecutedByName}"
                                    Width="150"/>
                <DataGridTextColumn Header="الحقل"
                                    Binding="{Binding FieldLabel}"
                                    Width="170"/>
                <DataGridTextColumn Header="القيمة الجديدة"
                                    Binding="{Binding ValueDisplay}"
                                    Width="200"/>
                <DataGridTextColumn Header="عدد السجلات المتأثرة"
                                    Binding="{Binding RecordCount}"
                                    Width="*"/>
                <DataGridTextColumn Header="الفلتر المُطبَّق"
                                    Binding="{Binding FilterSummary}"
                                    Width="*"/>
            </DataGrid.Columns>

        </DataGrid>
    </Grid>
</Page>
