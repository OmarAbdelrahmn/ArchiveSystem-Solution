<Window x:Class="ArchiveSystem.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="أرشيف الملفات - تسجيل الدخول"
        Height="520" Width="420"
        MinHeight="520" MinWidth="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="160"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- ── HEADER ── -->
        <Border Grid.Row="0" Background="#1a7a60">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🗂"
                           FontSize="40"
                           HorizontalAlignment="Center"
                           Foreground="White"/>
                <TextBlock Text="أرشيف الملفات"
                           FontSize="24" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
                <TextBlock Text="النظام غير متصل بالإنترنت ✓"
                           FontSize="11"
                           Foreground="#aaffdd"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- ── FORM ── -->
        <StackPanel Grid.Row="1" Margin="40,32,40,0">

            <!-- Error message (hidden until needed) -->
            <Border x:Name="ErrorBorder"
                    Background="#FFEBEE"
                    BorderBrush="#EF9A9A"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12,8"
                    Margin="0,0,0,16"
                    Visibility="Collapsed">
                <TextBlock x:Name="ErrorText"
                           Foreground="#C62828"
                           FontSize="13"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- First-run setup panel (hidden until needed) -->
            <Border x:Name="SetupBorder"
                    Background="#E8F5E9"
                    BorderBrush="#A5D6A7"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12,8"
                    Margin="0,0,0,16"
                    Visibility="Collapsed">
                <TextBlock Text="مرحباً! أول تشغيل للنظام. يرجى إنشاء حساب مدير الأرشيف."
                           Foreground="#2E7D32"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Full name (first run only) -->
            <TextBox x:Name="FullNameBox"
                     materialDesign:HintAssist.Hint="الاسم الكامل"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     FontSize="14"
                     Margin="0,0,0,16"
                     Visibility="Collapsed"/>

            <!-- Username -->
            <TextBox x:Name="UsernameBox"
                     materialDesign:HintAssist.Hint="اسم المستخدم"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     FontSize="14"
                     Margin="0,0,0,16"
                     KeyDown="Input_KeyDown"/>

            <!-- Password -->
            <PasswordBox x:Name="PasswordBox"
                         materialDesign:HintAssist.Hint="كلمة المرور"
                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                         FontSize="14"
                         Margin="0,0,0,24"
                         KeyDown="Input_KeyDown"/>

            <!-- Login Button -->
            <Button x:Name="LoginButton"
                    Content="تسجيل الدخول"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="#1a7a60"
                    Foreground="White"
                    FontSize="15"
                    Height="44"
                    Click="LoginButton_Click"/>

        </StackPanel>

        <!-- ── FOOTER: last backup ── -->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0"
                Padding="16,0">
            <TextBlock x:Name="LastBackupText"
                       Text="جاري التحقق من آخر نسخة احتياطية..."
                       FontSize="11"
                       Foreground="#888"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Border>

    </Grid>
</Window>