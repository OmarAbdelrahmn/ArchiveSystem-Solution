<Window x:Class="ArchiveSystem.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="أرشيف الملفات"
        WindowState="Maximized"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        FontFamily="Noto Kufi Arabic, Segoe UI"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="#E8EAED"
        Icon="pack://application:,,,/Assets/app.ico">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="420" MinWidth="380" MaxWidth="520"/>
        </Grid.ColumnDefinitions>

        <!-- ══ LOGIN CARD ══ -->
        <Grid Grid.Column="1" Background="#F0F0F5">
            <Border VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="340"
                    Background="White"
                    CornerRadius="18"
                    Padding="36,40,36,28">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="48" ShadowDepth="0"
                                      Color="#000000" Opacity="0.12"/>
                </Border.Effect>

                <StackPanel>

                    <TextBlock Text="تسجيل الدخول"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#1A1A2E"/>

                    <TextBlock x:Name="SubtitleText"
                               Text="أدخل بيانات حسابك للدخول إلى النظام."
                               FontSize="12" Foreground="#888"
                               TextWrapping="Wrap"
                               Margin="0,6,0,20"/>

                    <!-- Error Banner -->
                    <Border x:Name="ErrorBorder"
                            Background="#FFF0F0" BorderBrush="#FFBCBC"
                            BorderThickness="1" CornerRadius="8"
                            Padding="12,8" Margin="0,0,0,16"
                            Visibility="Collapsed">
                        <TextBlock x:Name="ErrorText"
                                   Foreground="#C62828" FontSize="12"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- First-run Setup Banner -->
                    <Border x:Name="SetupBorder"
                            Background="#E8F5E9" BorderBrush="#A5D6A7"
                            BorderThickness="1" CornerRadius="8"
                            Padding="12,8" Margin="0,0,0,16"
                            Visibility="Collapsed">
                        <TextBlock Text="مرحباً! أول تشغيل للنظام. يرجى إنشاء حساب مدير الأرشيف."
                                   Foreground="#2E7D32" FontSize="12"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- Full Name (first run only) -->
                    <TextBox x:Name="FullNameBox"
                             materialDesign:HintAssist.Hint="الاسم الكامل"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             FontSize="14" Margin="0,0,0,14"
                             Visibility="Collapsed"/>

                    <!-- Username -->
                    <TextBlock Text="اسم المستخدم"
                               FontSize="12" Foreground="#555"
                               Margin="0,0,0,4"/>
                    <TextBox x:Name="UsernameBox"
                             materialDesign:HintAssist.Hint=""
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             FontSize="14" Margin="0,0,0,16"
                             KeyDown="Input_KeyDown"/>

                    <!-- Password -->
                    <TextBlock Text="كلمة المرور"
                               FontSize="12" Foreground="#555"
                               Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,28">
                        <PasswordBox x:Name="PasswordBox"
                                     materialDesign:HintAssist.Hint=""
                                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                     FontSize="14" Padding="12,0,44,0"
                                     KeyDown="Input_KeyDown"/>
                        <TextBox x:Name="PasswordVisibleBox"
                                 materialDesign:HintAssist.Hint=""
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="14" Padding="12,0,44,0"
                                 VerticalContentAlignment="Center"
                                 Visibility="Collapsed"
                                 KeyDown="Input_KeyDown"/>
                        <Button x:Name="TogglePasswordButton"
                                Width="36" Height="55" Padding="0"
                                FontSize="15" Content="👁"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Margin="232,0,0,0"
                                Click="TogglePasswordButton_Click"/>
                    </Grid>

                    <!-- Login Button -->
                    <Button x:Name="LoginButton"
                            Content="دخول إلى النظام"
                            FontSize="15" FontWeight="SemiBold"
                            Height="48" BorderThickness="0" Cursor="Hand"
                            Click="LoginButton_Click">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#1a7a60" Offset="0"/>
                                <GradientStop Color="#5B3D8A" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Foreground>
                            <SolidColorBrush Color="White"/>
                        </Button.Foreground>
                        <Button.Style>
                            <Style TargetType="{x:Type Button}"
                                   BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="10"/>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- ── RESTORE SEPARATOR ── -->
                    <Border BorderThickness="0,1,0,0"
                            BorderBrush="#F0F0F0"
                            Margin="0,20,0,0"
                            Padding="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="نقل البيانات من جهاز آخر؟"
                                       FontSize="11" Foreground="#999"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8"/>

                            <Button x:Name="RestoreDbBtn"
                                    Content="📂  استعادة قاعدة البيانات"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Height="36"
                                    FontSize="12"
                                    HorizontalAlignment="Stretch"
                                    Foreground="#555"
                                    BorderBrush="#CCCCCC"
                                    Click="RestoreDb_Click"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>
        </Grid>

        <!-- ══ HERO PANEL ══ -->
        <Grid Grid.Column="0" Background="#E8EAED">
            <Border CornerRadius="20" Margin="32,32,32,32" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0A3D2E" Offset="0"/>
                        <GradientStop Color="#2D1B55" Offset="0.40"/>
                        <GradientStop Color="#3B1F6A" Offset="0.65"/>
                        <GradientStop Color="#1a7a60" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>

                    <!-- Decorative circles -->
                    <Ellipse Width="500" Height="500"
                             HorizontalAlignment="Right" VerticalAlignment="Top"
                             Margin="0,-200,-200,0" Opacity="0.07">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#D4AF37" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <Ellipse Width="380" Height="380"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="-150,0,0,-150" Opacity="0.08">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#7C4DBA" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <Ellipse Width="260" Height="260"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Margin="0,80,0,0" Opacity="0.05">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#D4AF37" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <!-- Gold accent top-left corner bar -->
                    <Border Width="4" HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Margin="0,60,0,60" CornerRadius="2">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#D4AF37" Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Main content: image + title + description -->
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Margin="60,0,60,0">

                        <!-- App logo image — large and prominent -->
                        <Image Source="pack://application:,,,/Assets/main.png"
                               Height="180"
                               HorizontalAlignment="Right"
                               Margin="0,0,0,22"
                               RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Effect>
                                <DropShadowEffect BlurRadius="28" ShadowDepth="0"
                                                  Color="#D4AF37" Opacity="0.22"/>
                            </Image.Effect>
                        </Image>

                        <!-- Title -->
                        <TextBlock Text="أرشيف الملفات"
                                   FontSize="52" FontWeight="Bold">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="White"   Offset="0"/>
                                    <GradientStop Color="#D4AF37" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="30" ShadowDepth="0"
                                                  Color="#000" Opacity="0.25"/>
                            </TextBlock.Effect>
                        </TextBlock>

                        <!-- Gold divider line -->
                        <Border Height="2" CornerRadius="1"
                                Margin="0,10,0,14" Width="220"
                                HorizontalAlignment="Right">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#D4AF37" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <TextBlock Text="بحث سريع، إدخال ذكي، تقارير، وتتبع كامل لمكان كل دوسية."
                                   FontSize="15" Foreground="#C8B8E8"
                                   TextWrapping="Wrap" MaxWidth="520"
                                   LineHeight="26" TextAlignment="Right"/>
                    </StackPanel>

                    <!-- Bottom Stats Bar -->
                    <Grid VerticalAlignment="Bottom" Margin="36,0,36,36">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Stat 1 — Last Backup -->
                        <Border Grid.Column="0" CornerRadius="12"
                                Padding="20,16" Margin="0,0,8,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1a7a6033" Offset="0"/>
                                    <GradientStop Color="#00000022" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#D4AF37" Opacity="0.25"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <StackPanel HorizontalAlignment="Right">
                                <TextBlock x:Name="LastBackupTimeText" Text="--:--"
                                           FontSize="26" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="آخر نسخة احتياطية"
                                           FontSize="12" Foreground="#A895D0"
                                           HorizontalAlignment="Right" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Stat 2 — Total Files -->
                        <Border Grid.Column="1" CornerRadius="12"
                                Padding="20,16" Margin="8,0,8,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#5B3D8A33" Offset="0"/>
                                    <GradientStop Color="#00000022" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#D4AF37" Opacity="0.25"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <StackPanel HorizontalAlignment="Right">
                                <TextBlock x:Name="TotalFilesText" Text="0"
                                           FontSize="26" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="ملف داخل النظام"
                                           FontSize="12" Foreground="#A895D0"
                                           HorizontalAlignment="Right" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Stat 3 — Total Folders -->
                        <Border Grid.Column="2" CornerRadius="12"
                                Padding="20,16" Margin="8,0,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#D4AF3722" Offset="0"/>
                                    <GradientStop Color="#00000022" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#D4AF37" Opacity="0.35"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <StackPanel HorizontalAlignment="Right">
                                <TextBlock x:Name="TotalFoldersText" Text="0"
                                           FontSize="26" FontWeight="Bold">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="#D4AF37"/>
                                    </TextBlock.Foreground>
                                </TextBlock>
                                <TextBlock Text="دوسية مستوردة"
                                           FontSize="12" Foreground="#A895D0"
                                           HorizontalAlignment="Right" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                    </Grid>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>
