<Window x:Class="ArchiveSystem.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="موثق"
        WindowState="Maximized"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        FontFamily="Noto Kufi Arabic, Segoe UI"
        TextElement.Foreground="{DynamicResource TextPrimary}"
        Background="{StaticResource MidnightDeep}"
        Icon="pack://application:,,,/Assets/app.ico">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="420" MinWidth="380" MaxWidth="520"/>
        </Grid.ColumnDefinitions>

        <!-- ══ LOGIN CARD (glassmorphism) ══ -->
        <Grid Grid.Column="1">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#0A1628" Offset="0"/>
                    <GradientStop Color="#050D1A" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Subtle rose gold right edge glow -->
            <Border HorizontalAlignment="Left" Width="1"
                    VerticalAlignment="Stretch">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="Transparent"  Offset="0"/>
                        <GradientStop Color="#C9956A"      Offset="0.4"/>
                        <GradientStop Color="#C9956A"      Offset="0.6"/>
                        <GradientStop Color="Transparent"  Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Border VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="340"
                    CornerRadius="20"
                    Padding="36,40,36,28">
                <!-- Glassmorphism background -->
                <Border.Background>
                    <SolidColorBrush Color="#0D1F3C" Opacity="0.90"/>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#C9956A40" Offset="0"/>
                        <GradientStop Color="#1AFFFFFF" Offset="0.5"/>
                        <GradientStop Color="#C9956A20" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.BorderThickness>1</Border.BorderThickness>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="60" ShadowDepth="0"
                                      Color="#C9956A" Opacity="0.08"/>
                </Border.Effect>

                <StackPanel>

                    <!-- Rose gold accent line top -->
                    <Border Height="2" Width="80" HorizontalAlignment="Right"
                            CornerRadius="1" Margin="0,0,0,20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#C9956A"     Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <TextBlock Text="تسجيل الدخول"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#E8EDF5"/>

                    <TextBlock x:Name="SubtitleText"
                               Text="أدخل بيانات حسابك للدخول إلى النظام."
                               FontSize="12" Foreground="#4A5A7A"
                               TextWrapping="Wrap"
                               Margin="0,6,0,24"/>

                    <!-- Error Banner -->
                    <Border x:Name="ErrorBorder"
                            CornerRadius="8"
                            Padding="12,8" Margin="0,0,0,16"
                            Visibility="Collapsed">
                        <Border.Background>
                            <SolidColorBrush Color="#FF5252" Opacity="0.12"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#FF5252" Opacity="0.35"/>
                        </Border.BorderBrush>
                        <Border.BorderThickness>1</Border.BorderThickness>
                        <TextBlock x:Name="ErrorText"
                                   Foreground="#FF5252" FontSize="12"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- First-run Setup Banner -->
                    <Border x:Name="SetupBorder"
                            CornerRadius="8"
                            Padding="12,8" Margin="0,0,0,16"
                            Visibility="Collapsed">
                        <Border.Background>
                            <SolidColorBrush Color="#00E676" Opacity="0.10"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#00E676" Opacity="0.30"/>
                        </Border.BorderBrush>
                        <Border.BorderThickness>1</Border.BorderThickness>
                        <TextBlock Text="مرحباً! أول تشغيل للنظام. يرجى إنشاء حساب مدير الأرشيف."
                                   Foreground="#1adf8a" FontSize="12"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- Full Name (first run only) -->
                    <TextBox x:Name="FullNameBox"
                             materialDesign:HintAssist.Hint="الاسم الكامل"
                             materialDesign:HintAssist.Foreground="#4A5A7A"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             FontSize="14" Margin="0,0,0,14"
                             Visibility="Collapsed"/>

                    <!-- Username -->
                    <TextBlock Text="اسم المستخدم"
                               FontSize="12" Foreground="#8A9BB8"
                               Margin="0,0,0,4"/>
                    <TextBox x:Name="UsernameBox"
                             materialDesign:HintAssist.Hint=""
                             materialDesign:HintAssist.Foreground="#4A5A7A"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             FontSize="14" Margin="0,0,0,16"
                             KeyDown="Input_KeyDown"/>

                    <!-- Password -->
                    <TextBlock Text="كلمة المرور"
                               FontSize="12" Foreground="#8A9BB8"
                               Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,28">
                        <PasswordBox x:Name="PasswordBox"
                                     materialDesign:HintAssist.Hint=""
                                     materialDesign:HintAssist.Foreground="#4A5A7A"
                                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                     FontSize="14" Padding="12,0,44,0"
                                     KeyDown="Input_KeyDown"/>
                        <TextBox x:Name="PasswordVisibleBox"
                                 materialDesign:HintAssist.Hint=""
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="14" Padding="12,0,44,0"
                                 VerticalContentAlignment="Center"
                                 Visibility="Collapsed"
                                 KeyDown="Input_KeyDown"/>
                        <Button x:Name="TogglePasswordButton"
                                Width="36" Height="55" Padding="0"
                                FontSize="15" Content="👁"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Margin="232,0,0,0"
                                Click="TogglePasswordButton_Click"/>
                    </Grid>

                    <!-- Login Button — emerald glow gradient -->
                    <Button x:Name="LoginButton"
                            Content="دخول إلى النظام"
                            FontSize="15" FontWeight="SemiBold"
                            Height="48" BorderThickness="0" Cursor="Hand"
                            Foreground="White"
                            Click="LoginButton_Click">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00BCD4" Offset="0"/>
                                <GradientStop Color="#00E676" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Style>
                            <Style TargetType="{x:Type Button}"
                                   BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="10"/>
                            </Style>
                        </Button.Style>
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="0"
                                              Color="#00E676" Opacity="0.35"/>
                        </Button.Effect>
                    </Button>

                    <!-- Restore separator -->
                    <Border BorderThickness="0,1,0,0"
                            Margin="0,20,0,0"
                            Padding="0,16,0,0">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#C9956A" Opacity="0.18"/>
                        </Border.BorderBrush>
                        <StackPanel>
                            <TextBlock Text="نقل البيانات من جهاز آخر؟"
                                       FontSize="11" Foreground="#4A5A7A"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8"/>

                            <Button x:Name="RestoreDbBtn"
                                    Content="📂  استعادة قاعدة البيانات"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Height="36"
                                    FontSize="12"
                                    HorizontalAlignment="Stretch"
                                    Foreground="#8A9BB8"
                                    BorderBrush="#1E3050"
                                    Click="RestoreDb_Click"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>
        </Grid>

        <!-- ══ HERO PANEL — deep midnight + emerald + rose gold ══ -->
        <Grid Grid.Column="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#050D1A" Offset="0"/>
                    <GradientStop Color="#0A1628" Offset="0.40"/>
                    <GradientStop Color="#0D1F3C" Offset="0.70"/>
                    <GradientStop Color="#050D1A" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Border CornerRadius="0,20,20,0" Margin="32,32,0,32" ClipToBounds="True"
                    Background="Transparent">
                <Grid>

                    <!-- Emerald ambient top-right -->
                    <Ellipse Width="600" Height="600"
                             HorizontalAlignment="Right" VerticalAlignment="Top"
                             Margin="0,-250,-200,0" Opacity="0.06">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#00E676" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <!-- Rose gold ambient bottom-left -->
                    <Ellipse Width="500" Height="500"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="-160,0,0,-160" Opacity="0.09">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#C9956A" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <!-- Centre emerald soft glow -->
                    <Ellipse Width="360" Height="360"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Margin="0,60,0,0" Opacity="0.05">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#1adf8a" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <!-- Rose gold left edge bar -->
                    <Border Width="3" HorizontalAlignment="Right"
                            VerticalAlignment="Stretch"
                            Margin="0,60,0,60" CornerRadius="2">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#C9956A"     Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Main content -->
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="60,0,60,120">

                        <!-- App logo with emerald glow -->
                        <Image Source="pack://application:,,,/Assets/main.png"
                               Height="200"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,18"
                               RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Effect>
                                <DropShadowEffect BlurRadius="50" ShadowDepth="0"
                                                  Color="#00E676" Opacity="0.60"/>
                            </Image.Effect>
                        </Image>

                        <!-- Title — white to rose gold gradient -->
                        <TextBlock Text="مركز الوثائق و المعلومات"
                                   FontSize="32" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#E8EDF5" Offset="0"/>
                                    <GradientStop Color="#DDB48E" Offset="0.6"/>
                                    <GradientStop Color="#C9956A" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="30" ShadowDepth="0"
                                                  Color="#000" Opacity="0.40"/>
                            </TextBlock.Effect>
                        </TextBlock>

                        <!-- Rose gold divider -->
                        <Border Height="2" CornerRadius="1"
                                Margin="0,14,0,18" Width="240"
                                HorizontalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="#C9956A"     Offset="0.5"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <TextBlock Text="بحث سريع، إدخال ذكي، تقارير، وتتبع كامل لمكان كل دوسية."
                                   FontSize="14" Foreground="#4A5A7A"
                                   TextWrapping="Wrap" MaxWidth="460"
                                   LineHeight="26" TextAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Bottom Stats Bar — glassmorphism cards -->
                    <Grid VerticalAlignment="Bottom" Margin="36,0,36,36">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Stat 1 — Last Backup -->
                        <Border Grid.Column="0" CornerRadius="12"
                                Padding="20,16" Margin="0,0,8,0">
                            <Border.Background>
                                <SolidColorBrush Color="#0D1F3C" Opacity="0.70"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#C9956A" Opacity="0.25"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <Border.Effect>
                                <BlurEffect Radius="0"/>
                            </Border.Effect>
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock x:Name="LastBackupTimeText" Text="--:--"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource EmeraldGlow}"/>
                                <TextBlock Text="آخر نسخة احتياطية"
                                           FontSize="12" Foreground="#4A5A7A"
                                           HorizontalAlignment="Left" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Stat 2 — Total Files -->
                        <Border Grid.Column="1" CornerRadius="12"
                                Padding="20,16" Margin="8,0,8,0">
                            <Border.Background>
                                <SolidColorBrush Color="#0D1F3C" Opacity="0.70"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#1adf8a" Opacity="0.25"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock x:Name="TotalFilesText" Text="0"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource EmeraldGlow}"/>
                                <TextBlock Text="ملف داخل النظام"
                                           FontSize="12" Foreground="#4A5A7A"
                                           HorizontalAlignment="Left" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Stat 3 — Total Folders -->
                        <Border Grid.Column="2" CornerRadius="12"
                                Padding="20,16" Margin="8,0,0,0">
                            <Border.Background>
                                <SolidColorBrush Color="#0D1F3C" Opacity="0.70"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#C9956A" Opacity="0.35"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock x:Name="TotalFoldersText" Text="0"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource RoseGold}"/>
                                <TextBlock Text="دوسية مستوردة"
                                           FontSize="12" Foreground="#4A5A7A"
                                           HorizontalAlignment="Left" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                    </Grid>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>
