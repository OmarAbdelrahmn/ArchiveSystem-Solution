<Page x:Class="ArchiveSystem.Views.Pages.DossierDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="تفاصيل الدوسية"
      Background="#F5F5F5"
      FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White"
                BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="→ رجوع"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="#1a7a60"
                        Click="Back_Click"/>

                <TextBlock Grid.Column="1"
                           x:Name="HeaderTitle"
                           Text="📁  تفاصيل الدوسية"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#1a7a60"
                           VerticalAlignment="Center"
                           Margin="12,0"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Grid.RowSpan="2"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24">

                <!-- Dossier Info Card -->
                <Border Background="White"
                        CornerRadius="8"
                        Padding="24"
                        Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6"
                                          Opacity="0.08"
                                          ShadowDepth="2"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="رقم الدوسية"
                                       FontSize="12" Foreground="#888"/>
                            <TextBlock x:Name="DossierNumberText"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="#1a7a60"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="الموقع الفيزيائي"
                                       FontSize="12" Foreground="#888"/>
                            <TextBlock x:Name="LocationText"
                                       FontSize="14" FontWeight="SemiBold"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="عدد الملفات"
                                       FontSize="12" Foreground="#888"/>
                            <TextBlock x:Name="FileCountText"
                                       FontSize="14" FontWeight="SemiBold"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Records Table -->
                <Border Background="White"
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6"
                                          Opacity="0.08"
                                          ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="قائمة السجناء"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="#1a7a60"
                                   Margin="0,0,0,12"/>

                        <DataGrid x:Name="RecordsGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  Style="{StaticResource MaterialDesignDataGrid}"
                                  materialDesign:DataGridAssist.CellPadding="10 7 10 7"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F9FBF9"
                                  MaxHeight="380">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="تسلسل"
                                    Binding="{Binding SequenceNumber}"
                                    Width="70"/>
                                <DataGridTextColumn Header="اسم السجين"
                                    Binding="{Binding PersonName}"
                                    Width="*"/>
                                <DataGridTextColumn Header="رقم السجين"
                                    Binding="{Binding PrisonerNumber}"
                                    Width="140"/>
                                <DataGridTextColumn Header="ملاحظات"
                                    Binding="{Binding Notes}"
                                    Width="180"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>