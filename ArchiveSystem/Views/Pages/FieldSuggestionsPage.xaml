<Page x:Class="ArchiveSystem.Views.Pages.FieldSuggestionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="إدارة قوائم الاقتراحات"
      Background="#F5F5F5"
      FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White"
                BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="💡  إدارة قوائم الاقتراحات"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#1a7a60"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="🔄 تحديث"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Height="36"
                        Click="Refresh_Click"/>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Fields List -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderThickness="0,0,1,0"
                    BorderBrush="#E0E0E0">
                <StackPanel>
                    <TextBlock Text="الحقول من نوع اقتراحات"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#555"
                               Margin="16,16,16,10"/>
                    <ListBox x:Name="FieldsList"
                             BorderThickness="0"
                             Background="Transparent"
                             DisplayMemberPath="ArabicLabel"
                             SelectionChanged="FieldsList_SelectionChanged"/>
                </StackPanel>
            </Border>

            <!-- RIGHT: Suggestions for selected field -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Field title + add form -->
                <Border Grid.Row="0"
                        Background="#F0F7F4"
                        BorderThickness="0,0,0,1" BorderBrush="#C8E6C9"
                        Padding="20,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   x:Name="FieldTitleText"
                                   Text="اختر حقلاً من القائمة"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="#1a7a60"
                                   VerticalAlignment="Center"/>

                        <TextBox
                                 x:Name="NewSuggestionBox"
                                 materialDesign:HintAssist.Hint="قيمة اقتراح جديدة"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Width="220"
                                 Margin="121,0,10,-6"
                                 IsEnabled="False" Grid.ColumnSpan="2"/>

                        <Button Grid.Column="2"
                                x:Name="AddSuggestionBtn"
                                Content="➕ إضافة"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#1a7a60" Foreground="White"
                                Height="40" Width="100"
                                IsEnabled="False"
                                Click="AddSuggestion_Click"/>
                    </Grid>
                </Border>

                <!-- Stats bar -->
                <Border Grid.Row="1"
                        Background="#F9F9F9"
                        BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"
                        Padding="20,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   x:Name="StatsText"
                                   FontSize="12" Foreground="#666"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                x:Name="ClearAllBtn"
                                Content="🗑 مسح كل الاقتراحات"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="#C62828"
                                Height="32"
                                IsEnabled="False"
                                Click="ClearAll_Click"/>
                    </Grid>
                </Border>

                <!-- Error/Success message -->
                <Border Grid.Row="2"
                        x:Name="MsgBorder"
                        Padding="16,8" Margin="16,8,16,0"
                        CornerRadius="4"
                        Visibility="Collapsed">
                    <TextBlock x:Name="MsgText" FontSize="12" TextWrapping="Wrap"/>
                </Border>

                <!-- Suggestions DataGrid -->
                <DataGrid Grid.Row="3"
                          x:Name="SuggestionsGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          Style="{StaticResource MaterialDesignDataGrid}"
                          materialDesign:DataGridAssist.CellPadding="12 8 12 8"
                          RowBackground="White"
                          AlternatingRowBackground="#F9FBF9"
                          VirtualizingPanel.IsVirtualizing="True"
                          Margin="12,8,12,12">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="قيمة الاقتراح"
                                            Binding="{Binding Value}"
                                            Width="*"/>
                        <DataGridTextColumn Header="عدد السجلات التي تستخدمها"
                                            Binding="{Binding UsageCount}"
                                            Width="200"/>
                        <DataGridTextColumn Header="آخر استخدام"
                                            Binding="{Binding LastUsed}"
                                            Width="160"/>
                        <DataGridTemplateColumn Header="إجراء" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="🗑 حذف"
                                            Tag="{Binding Value}"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Foreground="#C62828"
                                            Height="28" Padding="6,0"
                                            Click="DeleteSuggestion_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>

                </DataGrid>

                <!-- Empty state -->
                <TextBlock Grid.Row="3"
                           x:Name="EmptyText"
                           Text="لا توجد اقتراحات محفوظة لهذا الحقل."
                           FontSize="14" Foreground="#AAA"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </Grid>
        </Grid>
    </Grid>
</Page>