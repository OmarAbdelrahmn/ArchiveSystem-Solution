<Page x:Class="ArchiveSystem.Views.Pages.StatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="الإحصاءات"
      Background="#F5F5F5"
      FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White"
                BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="📊  الإحصاءات"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#1a7a60"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="🔄 تحديث"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Height="36"
                        Click="Refresh_Click"/>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28,24,28,32">

                <!-- ══ SUMMARY CARDS ══════════════════════════════════════════ -->
                <UniformGrid x:Name="SummaryCards"
                             Columns="4"
                             Margin="0,0,0,28">
                    <!-- Cards injected in code-behind for data binding -->
                </UniformGrid>

                <!-- ══ ROW 2: Monthly + Completion ══════════════════════════ -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>

                    <!-- Monthly breakdown table -->
                    <Border Grid.Column="0"
                            Background="White"
                            CornerRadius="8" Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="6" Opacity="0.08" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="السجلات حسب الشهر الهجري"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="#1a7a60"/>
                                <ComboBox Grid.Column="1"
                                          x:Name="MonthlyYearCombo"
                                          materialDesign:HintAssist.Hint="السنة"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          Width="120" Height="34"
                                          SelectionChanged="MonthlyYear_Changed"/>
                            </Grid>
                            <DataGrid x:Name="MonthlyGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      Style="{StaticResource MaterialDesignDataGrid}"
                                      materialDesign:DataGridAssist.CellPadding="10 6 10 6"
                                      RowBackground="White"
                                      AlternatingRowBackground="#F9FBF9"
                                      MaxHeight="300">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="الشهر / السنة"
                                                        Binding="{Binding Label}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="عدد السجلات"
                                                        Binding="{Binding Count}"
                                                        Width="110"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- Completion breakdown -->
                    <Border Grid.Column="2"
                            Background="White"
                            CornerRadius="8" Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="6" Opacity="0.08" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="حالة اكتمال الدوسيات"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="#1a7a60"
                                       Margin="0,0,0,16"/>

                            <!-- Complete bar -->
                            <TextBlock x:Name="CompleteLabel"
                                       FontSize="12" Foreground="#555"
                                       Margin="0,0,0,4"/>
                            <Border CornerRadius="4" Background="#E8F5E9"
                                    Height="22" Margin="0,0,0,10">
                                <Border x:Name="CompleteBar"
                                        CornerRadius="4" Background="#43A047"
                                        HorizontalAlignment="Right"
                                        Width="0"/>
                            </Border>

                            <!-- Incomplete bar -->
                            <TextBlock x:Name="IncompleteLabel"
                                       FontSize="12" Foreground="#555"
                                       Margin="0,0,0,4"/>
                            <Border CornerRadius="4" Background="#FFF3E0"
                                    Height="22" Margin="0,0,0,10">
                                <Border x:Name="IncompleteBar"
                                        CornerRadius="4" Background="#FB8C00"
                                        HorizontalAlignment="Right"
                                        Width="0"/>
                            </Border>

                            <!-- Unknown bar -->
                            <TextBlock x:Name="UnknownLabel"
                                       FontSize="12" Foreground="#555"
                                       Margin="0,0,0,4"/>
                            <Border CornerRadius="4" Background="#F5F5F5"
                                    Height="22" Margin="0,0,0,4">
                                <Border x:Name="UnknownBar"
                                        CornerRadius="4" Background="#BDBDBD"
                                        HorizontalAlignment="Right"
                                        Width="0"/>
                            </Border>

                        </StackPanel>
                    </Border>

                </Grid>

                <!-- ══ ROW 3: Weekly breakdown ════════════════════════════════ -->
                <Border Background="White"
                        CornerRadius="8" Padding="20"
                        Margin="0,0,0,24">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" Opacity="0.08" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>

                        <!-- Title row + year filter + total badge -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="السجلات حسب الأسبوع"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="#1a7a60"
                                           VerticalAlignment="Center"/>
                                <!-- Subtle info label -->
                                <TextBlock Text="(أسابيع ميلادية — آخر 16 أسبوع)"
                                           FontSize="11" Foreground="#999"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </StackPanel>

                            <!-- Year filter -->
                            <ComboBox Grid.Column="1"
                                      x:Name="WeeklyYearCombo"
                                      materialDesign:HintAssist.Hint="السنة"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Width="120" Height="34"
                                      SelectionChanged="WeeklyYear_Changed"/>

                            <!-- Total badge -->
                            <Border Grid.Column="3"
                                    Background="#F0F7F4" CornerRadius="6"
                                    Padding="10,4">
                                <TextBlock x:Name="WeeklyTotalText"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="#1a7a60"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- Two-column layout: table on the right, bar chart on the left -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>

                            <!-- Bar chart (horizontal bars, drawn in code-behind) -->
                            <Border Grid.Column="0"
                                    BorderBrush="#EEEEEE" BorderThickness="1"
                                    CornerRadius="4" Background="#FAFAFA"
                                    Padding="12,10">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              MaxHeight="300">
                                    <ItemsControl x:Name="WeeklyBarsPanel">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="140"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="46"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Week label -->
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Label}"
                                                               FontSize="11"
                                                               Foreground="#444"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>

                                                    <!-- Bar track -->
                                                    <Border Grid.Column="1"
                                                            Background="#E8F5E9"
                                                            CornerRadius="3"
                                                            Height="18"
                                                            Margin="0,0,6,0">
                                                        <!-- Filled portion — Width bound via converter tag -->
                                                        <Border x:Name="WeekBar"
                                                                Background="#2E7D32"
                                                                CornerRadius="3"
                                                                HorizontalAlignment="Left"
                                                                Width="{Binding BarWidth}"/>
                                                    </Border>

                                                    <!-- Count -->
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding Count}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="#1a7a60"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Right"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <!-- Summary table -->
                            <DataGrid Grid.Column="2"
                                      x:Name="WeeklyGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      Style="{StaticResource MaterialDesignDataGrid}"
                                      materialDesign:DataGridAssist.CellPadding="8 5 8 5"
                                      RowBackground="White"
                                      AlternatingRowBackground="#F9FBF9"
                                      MaxHeight="300">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="الأسبوع"
                                                        Binding="{Binding Label}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="عدد"
                                                        Binding="{Binding Count}"
                                                        Width="54"/>
                                </DataGrid.Columns>
                            </DataGrid>

                        </Grid>

                    </StackPanel>
                </Border>

                <!-- ══ ROW 4: Locations ═══════════════════════════════════════ -->
                <Border Background="White"
                        CornerRadius="8" Padding="20"
                        Margin="0,0,0,24">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" Opacity="0.08" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="الدوسيات حسب الموقع (أعلى 10)"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#1a7a60" Margin="0,0,0,12"/>
                        <DataGrid x:Name="LocationGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  Style="{StaticResource MaterialDesignDataGrid}"
                                  materialDesign:DataGridAssist.CellPadding="10 6 10 6"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F9FBF9"
                                  MaxHeight="240">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="الموقع"
                                                    Binding="{Binding Display}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="عدد الدوسيات"
                                                    Binding="{Binding DossierCount}"
                                                    Width="120"/>
                                <DataGridTextColumn Header="عدد السجلات"
                                                    Binding="{Binding RecordCount}"
                                                    Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ══ ROW 5: Custom field stats ═══════════════════════════════ -->
                <Border x:Name="CustomStatsBorder"
                        Background="White"
                        CornerRadius="8" Padding="20"
                        Visibility="Collapsed">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" Opacity="0.08" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="إحصاءات الحقول المخصصة"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="#1a7a60"/>
                            <ComboBox Grid.Column="1"
                                      x:Name="CustomFieldCombo"
                                      materialDesign:HintAssist.Hint="اختر الحقل"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      DisplayMemberPath="ArabicLabel"
                                      SelectedValuePath="CustomFieldId"
                                      Width="180" Height="34"
                                      SelectionChanged="CustomField_Changed"/>
                        </Grid>

                        <DataGrid x:Name="CustomStatsGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  Style="{StaticResource MaterialDesignDataGrid}"
                                  materialDesign:DataGridAssist.CellPadding="10 6 10 6"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F9FBF9"
                                  MaxHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="القيمة"
                                                    Binding="{Binding Value}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="العدد"
                                                    Binding="{Binding Count}"
                                                    Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
