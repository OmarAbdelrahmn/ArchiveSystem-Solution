<Page x:Class="ArchiveSystem.Views.Pages.StatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="الإحصائيات"
      FlowDirection="RightToLeft">

    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#050D1A" Offset="0"/>
            <GradientStop Color="#0A1628" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#0D1F3C"
                BorderThickness="0,0,0,1">
            <Border.BorderBrush>
                <SolidColorBrush Color="#C9956A" Opacity="0.20"/>
            </Border.BorderBrush>
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="تقارير النظام"
                               FontSize="10" Foreground="#4A5A7A"
                               Margin="0,0,0,1"/>
                    <TextBlock Text="📊  الإحصائيات"
                               FontSize="17" FontWeight="Bold"
                               Foreground="#E8EDF5"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="🔄 تحديث"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="{StaticResource RoseGold}"
                        BorderBrush="{StaticResource RoseGoldDark}"
                        Height="32"
                        Click="Refresh_Click"/>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,16,20,32">

                <!-- ══ SUMMARY CARDS ══════════════════════════════════════════ -->
                <UniformGrid x:Name="SummaryCards"
                             Columns="5"
                             Margin="0,0,0,20">
                    <!-- Cards injected in code-behind for data binding -->
                </UniformGrid>

                <!-- ══ ROW 2: Monthly + Completion ══════════════════════════ -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>

                    <!-- Monthly breakdown table -->
                    <Border Grid.Column="0"
                            CornerRadius="10"
                            BorderThickness="1"
                            Padding="20">
                        <Border.Background>
                            <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                        </Border.BorderBrush>
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="السجلات حسب الشهر الهجري"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource EmeraldGlow}"/>
                                <ComboBox Grid.Column="1"
                                          x:Name="MonthlyYearCombo"
                                          materialDesign:HintAssist.Hint="السنة"
                                          materialDesign:HintAssist.Foreground="#4A5A7A"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          Foreground="#E8EDF5"
                                          Width="120" Height="49"
                                          SelectionChanged="MonthlyYear_Changed"/>
                            </Grid>
                            <DataGrid x:Name="MonthlyGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      Style="{StaticResource MaterialDesignDataGrid}"
                                      materialDesign:DataGridAssist.CellPadding="10 6 10 6"
                                      Background="Transparent"
                                      RowBackground="Transparent"
                                      AlternatingRowBackground="#0A1628"
                                      Foreground="#E8EDF5"
                                      MaxHeight="300">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="الشهر / السنة"
                                                        Binding="{Binding Label}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="عدد السجلات"
                                                        Binding="{Binding Count}"
                                                        Width="110"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- Completion breakdown -->
                    <Border Grid.Column="2"
                            CornerRadius="10"
                            BorderThickness="1"
                            Padding="20">
                        <Border.Background>
                            <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                        </Border.BorderBrush>
                        <StackPanel>
                            <TextBlock Text="حالة اكتمال الدوسيات"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource EmeraldGlow}"
                                       Margin="0,0,0,16"/>

                            <!-- Complete bar -->
                            <TextBlock x:Name="CompleteLabel"
                                       FontSize="12" Foreground="#8A9BB8"
                                       Margin="0,0,0,4"/>
                            <Border CornerRadius="4" Height="22" Margin="0,0,0,10">
                                <Border.Background>
                                    <SolidColorBrush Color="#00E676" Opacity="0.12"/>
                                </Border.Background>
                                <Border x:Name="CompleteBar"
                                        CornerRadius="4"
                                        HorizontalAlignment="Right"
                                        Width="0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00BCD4" Offset="0"/>
                                            <GradientStop Color="#00E676" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Border>

                            <!-- Incomplete bar -->
                            <TextBlock x:Name="IncompleteLabel"
                                       FontSize="12" Foreground="#8A9BB8"
                                       Margin="0,0,0,4"/>
                            <Border CornerRadius="4" Height="22" Margin="0,0,0,10">
                                <Border.Background>
                                    <SolidColorBrush Color="#C9956A" Opacity="0.12"/>
                                </Border.Background>
                                <Border x:Name="IncompleteBar"
                                        CornerRadius="4"
                                        HorizontalAlignment="Right"
                                        Width="0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#C9956A"/>
                                    </Border.Background>
                                </Border>
                            </Border>

                            <!-- Unknown bar -->
                            <TextBlock x:Name="UnknownLabel"
                                       FontSize="12" Foreground="#8A9BB8"
                                       Margin="0,0,0,4"/>
                            <Border CornerRadius="4" Height="22" Margin="0,0,0,4">
                                <Border.Background>
                                    <SolidColorBrush Color="#4A5A7A" Opacity="0.20"/>
                                </Border.Background>
                                <Border x:Name="UnknownBar"
                                        CornerRadius="4"
                                        HorizontalAlignment="Right"
                                        Width="0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#4A5A7A"/>
                                    </Border.Background>
                                </Border>
                            </Border>

                        </StackPanel>
                    </Border>

                </Grid>

                <!-- ══ ROW 3: Weekly breakdown ════════════════════════════════ -->
                <Border CornerRadius="10"
                        BorderThickness="1"
                        Padding="20"
                        Margin="0,0,0,16">
                    <Border.Background>
                        <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                    </Border.BorderBrush>
                    <StackPanel>

                        <!-- Title row + year filter + total badge -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="السجلات حسب الأسبوع"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource EmeraldGlow}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="(أسابيع ميلادية — آخر 16 أسبوع)"
                                           FontSize="11" Foreground="#4A5A7A"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </StackPanel>

                            <ComboBox Grid.Column="1"
                                      x:Name="WeeklyYearCombo"
                                      materialDesign:HintAssist.Hint="السنة"
                                      materialDesign:HintAssist.Foreground="#4A5A7A"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Foreground="#E8EDF5"
                                      Width="120" Height="49"
                                      SelectionChanged="WeeklyYear_Changed"/>

                            <Border Grid.Column="3"
                                    CornerRadius="6"
                                    Padding="10,4">
                                <Border.Background>
                                    <SolidColorBrush Color="#00E676" Opacity="0.10"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#00E676" Opacity="0.25"/>
                                </Border.BorderBrush>
                                <Border.BorderThickness>1</Border.BorderThickness>
                                <TextBlock x:Name="WeeklyTotalText"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource EmeraldGlow}"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- Two-column layout: bar chart + table -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>

                            <!-- Bar chart -->
                            <Border Grid.Column="0"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12,10">
                                <Border.Background>
                                    <SolidColorBrush Color="#162844" Opacity="0.60"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                                </Border.BorderBrush>
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              MaxHeight="300">
                                    <ItemsControl x:Name="WeeklyBarsPanel">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="140"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="46"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Label}"
                                                               FontSize="11"
                                                               Foreground="#8A9BB8"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>

                                                    <Border Grid.Column="1"
                                                            CornerRadius="3"
                                                            Height="18"
                                                            Margin="0,0,6,0">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="#00E676" Opacity="0.10"/>
                                                        </Border.Background>
                                                        <Border x:Name="WeekBar"
                                                                CornerRadius="3"
                                                                HorizontalAlignment="Left"
                                                                Width="{Binding BarWidth}">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                    <GradientStop Color="#00BCD4" Offset="0"/>
                                                                    <GradientStop Color="#00E676" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                        </Border>
                                                    </Border>

                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding Count}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource EmeraldGlow}"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Right"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <!-- Summary table -->
                            <DataGrid Grid.Column="2"
                                      x:Name="WeeklyGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      Style="{StaticResource MaterialDesignDataGrid}"
                                      materialDesign:DataGridAssist.CellPadding="8 5 8 5"
                                      Background="Transparent"
                                      RowBackground="Transparent"
                                      AlternatingRowBackground="#0A1628"
                                      Foreground="#E8EDF5"
                                      MaxHeight="300">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="الأسبوع"
                                                        Binding="{Binding Label}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="عدد"
                                                        Binding="{Binding Count}"
                                                        Width="54"/>
                                </DataGrid.Columns>
                            </DataGrid>

                        </Grid>

                    </StackPanel>
                </Border>

                <!-- ══ ROW 4: Locations ═══════════════════════════════════════ -->
                <Border CornerRadius="10"
                        BorderThickness="1"
                        Padding="20"
                        Margin="0,0,0,16">
                    <Border.Background>
                        <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                    </Border.BorderBrush>
                    <StackPanel>
                        <TextBlock Text="الدوسيات حسب الموقع (أعلى 10)"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource EmeraldGlow}"
                                   Margin="0,0,0,12"/>
                        <DataGrid x:Name="LocationGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  Style="{StaticResource MaterialDesignDataGrid}"
                                  materialDesign:DataGridAssist.CellPadding="10 6 10 6"
                                  Background="Transparent"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="#0A1628"
                                  Foreground="#E8EDF5"
                                  MaxHeight="240">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="الموقع"
                                                    Binding="{Binding Display}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="عدد الدوسيات"
                                                    Binding="{Binding DossierCount}"
                                                    Width="120"/>
                                <DataGridTextColumn Header="عدد السجلات"
                                                    Binding="{Binding RecordCount}"
                                                    Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ══ ROW 5: Custom field stats ═══════════════════════════════ -->
                <Border x:Name="CustomStatsBorder"
                        CornerRadius="10"
                        BorderThickness="1"
                        Padding="20"
                        Visibility="Collapsed">
                    <Border.Background>
                        <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                    </Border.BorderBrush>
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                   Text="إحصاءات الحقول المخصصة"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource EmeraldGlow}"/>
                            <ComboBox Grid.Column="1"
                                      x:Name="CustomFieldCombo"
                                      materialDesign:HintAssist.Hint="اختر الحقل"
                                      materialDesign:HintAssist.Foreground="#4A5A7A"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Foreground="#E8EDF5"
                                      DisplayMemberPath="ArabicLabel"
                                      SelectedValuePath="CustomFieldId"
                                      Width="180" Height="49"
                                      SelectionChanged="CustomField_Changed"/>
                            <ComboBox Grid.Column="3"
                                      x:Name="CustomFieldYearCombo"
                                      materialDesign:HintAssist.Hint="السنة الهجرية"
                                      materialDesign:HintAssist.Foreground="#4A5A7A"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Foreground="#E8EDF5"
                                      Width="140" Height="49"
                                      SelectionChanged="CustomField_Changed"/>
                        </Grid>

                        <DataGrid x:Name="CustomStatsGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  Style="{StaticResource MaterialDesignDataGrid}"
                                  materialDesign:DataGridAssist.CellPadding="10 6 10 6"
                                  Background="Transparent"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="#0A1628"
                                  Foreground="#E8EDF5"
                                  MaxHeight="300">

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                            <Setter Property="Background" Value="#162844"/>
                                            <Setter Property="FontStyle" Value="Italic"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="القيمة"
                                                    Binding="{Binding Value}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="العدد"
                                                    Binding="{Binding Count}"
                                                    Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
