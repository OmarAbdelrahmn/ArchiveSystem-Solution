<Page x:Class="ArchiveSystem.Views.Pages.StatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="الإحصاءات"
      Background="#F5F5F5"
      FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White"
                BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="📊  الإحصاءات"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#1a7a60"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="🔄 تحديث"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Height="36"
                        Click="Refresh_Click"/>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28,24,28,32">

                <!-- ══ SUMMARY CARDS ══════════════════════════════════════════ -->
                <UniformGrid x:Name="SummaryCards"
                             Columns="4"
                             Margin="0,0,0,28">

                    <!-- Cards injected in code-behind for data binding -->

                </UniformGrid>

                <!-- ══ ROW 2: Monthly + Completion ══════════════════════════ -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>

                    <!-- Monthly breakdown table -->
                    <Border Grid.Column="0"
                            Background="White"
                            CornerRadius="8" Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="6" Opacity="0.08" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="السجلات حسب الشهر الهجري"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="#1a7a60"/>
                                <ComboBox Grid.Column="1"
                                          x:Name="MonthlyYearCombo"
                                          materialDesign:HintAssist.Hint="السنة"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          Width="120" Height="34"
                                          SelectionChanged="MonthlyYear_Changed"/>
                            </Grid>
                            <DataGrid x:Name="MonthlyGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      Style="{StaticResource MaterialDesignDataGrid}"
                                      materialDesign:DataGridAssist.CellPadding="10 6 10 6"
                                      RowBackground="White"
                                      AlternatingRowBackground="#F9FBF9"
                                      MaxHeight="300">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="الشهر / السنة"
                                                        Binding="{Binding Label}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="عدد السجلات"
                                                        Binding="{Binding Count}"
                                                        Width="110"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- Completion breakdown -->
                    <Border Grid.Column="2"
                            Background="White"
                            CornerRadius="8" Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="6" Opacity="0.08" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="حالة اكتمال الدوسيات"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="#1a7a60"
                                       Margin="0,0,0,16"/>

                            <!-- Complete bar -->
                            <TextBlock x:Name="CompleteLabel"
                                       FontSize="12" Foreground="#555"
                                       Margin="0,0,0,4"/>
                            <Border CornerRadius="4" Background="#E8F5E9"
                                    Height="22" Margin="0,0,0,10">
                                <Border x:Name="CompleteBar"
                                        CornerRadius="4" Background="#43A047"
                                        HorizontalAlignment="Right"
                                        Width="0"/>
                            </Border>

                            <!-- Incomplete bar -->
                            <TextBlock x:Name="IncompleteLabel"
                                       FontSize="12" Foreground="#555"
                                       Margin="0,0,0,4"/>
                            <Border CornerRadius="4" Background="#FFF3E0"
                                    Height="22" Margin="0,0,0,10">
                                <Border x:Name="IncompleteBar"
                                        CornerRadius="4" Background="#FB8C00"
                                        HorizontalAlignment="Right"
                                        Width="0"/>
                            </Border>

                            <!-- Unknown bar -->
                            <TextBlock x:Name="UnknownLabel"
                                       FontSize="12" Foreground="#555"
                                       Margin="0,0,0,4"/>
                            <Border CornerRadius="4" Background="#F5F5F5"
                                    Height="22" Margin="0,0,0,4">
                                <Border x:Name="UnknownBar"
                                        CornerRadius="4" Background="#BDBDBD"
                                        HorizontalAlignment="Right"
                                        Width="0"/>
                            </Border>

                        </StackPanel>
                    </Border>

                </Grid>

                <!-- ══ ROW 3: Locations ═══════════════════════════════════════ -->
                <Border Background="White"
                        CornerRadius="8" Padding="20"
                        Margin="0,0,0,24">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" Opacity="0.08" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="الدوسيات حسب الموقع (أعلى 10)"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#1a7a60" Margin="0,0,0,12"/>
                        <DataGrid x:Name="LocationGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  Style="{StaticResource MaterialDesignDataGrid}"
                                  materialDesign:DataGridAssist.CellPadding="10 6 10 6"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F9FBF9"
                                  MaxHeight="240">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="الموقع"
                                                    Binding="{Binding Display}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="عدد الدوسيات"
                                                    Binding="{Binding DossierCount}"
                                                    Width="120"/>
                                <DataGridTextColumn Header="عدد السجلات"
                                                    Binding="{Binding RecordCount}"
                                                    Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ══ ROW 4: Custom field stats ═══════════════════════════════ -->
                <Border x:Name="CustomStatsBorder"
                        Background="White"
                        CornerRadius="8" Padding="20"
                        Visibility="Collapsed">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" Opacity="0.08" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="إحصاءات الحقول المخصصة"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="#1a7a60"/>
                            <ComboBox Grid.Column="1"
                                      x:Name="CustomFieldCombo"
                                      materialDesign:HintAssist.Hint="اختر الحقل"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      DisplayMemberPath="ArabicLabel"
                                      SelectedValuePath="CustomFieldId"
                                      Width="180" Height="34"
                                      SelectionChanged="CustomField_Changed"/>
                        </Grid>

                        <DataGrid x:Name="CustomStatsGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  Style="{StaticResource MaterialDesignDataGrid}"
                                  materialDesign:DataGridAssist.CellPadding="10 6 10 6"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F9FBF9"
                                  MaxHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="القيمة"
                                                    Binding="{Binding Value}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="العدد"
                                                    Binding="{Binding Count}"
                                                    Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
