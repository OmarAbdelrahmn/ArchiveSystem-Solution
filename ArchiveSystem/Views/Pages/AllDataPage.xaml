<Page x:Class="ArchiveSystem.Views.Pages.AllDataPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="كل البيانات"
      FlowDirection="RightToLeft">

    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#050D1A" Offset="0"/>
            <GradientStop Color="#0A1628" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <Border Grid.Row="0" Background="#0D1F3C"
                BorderThickness="0,0,0,1">
            <Border.BorderBrush>
                <SolidColorBrush Color="#C9956A" Opacity="0.20"/>
            </Border.BorderBrush>
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="📋  كل البيانات"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource RoseGold}"
                           VerticalAlignment="Center"/>

                <Border Grid.Column="1"
                        x:Name="SelectAllBorder"
                        CornerRadius="6"
                        Padding="10,0"
                        Margin="0,0,10,0"
                        Visibility="Collapsed"
                        VerticalAlignment="Center">
                    <Border.Background>
                        <SolidColorBrush Color="#00E676" Opacity="0.08"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#00E676" Opacity="0.25"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <CheckBox x:Name="SelectAllFilteredChk"
                              Content="{Binding ElementName=SelectAllFilteredChk, Path=Tag}"
                              Tag="تحديد كل النتائج (0)"
                              Foreground="{StaticResource EmeraldGlow}"
                              FontSize="12"
                              Height="36"
                              Checked="SelectAllFiltered_Changed"
                              Unchecked="SelectAllFiltered_Changed"/>
                </Border>

                <Button x:Name="BulkFillBtn"
                        Grid.Column="2"
                        Content="تعبئة جماعية"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="{StaticResource RoseGold}"
                        BorderBrush="{StaticResource RoseGoldDark}"
                        Height="36" Margin="0,0,10,0"
                        Click="BulkFill_Click"/>

                <Button x:Name="ExportBtn"
                        Grid.Column="3"
                        Content="📤 تصدير CSV"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="{StaticResource EmeraldMid}"
                        Height="36"
                        Click="Export_Click"/>
            </Grid>
        </Border>

        <!-- ══ FILTER BAR ══ -->
        <Border Grid.Row="1" Background="#0A1628"
                BorderThickness="0,0,0,1">
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
            </Border.BorderBrush>
            <Border Padding="20,14">
                <WrapPanel x:Name="FilterPanel">

                    <ComboBox x:Name="StatusCombo"
                              materialDesign:HintAssist.Hint="الحالة"
                              materialDesign:HintAssist.Foreground="#4A5A7A"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Width="130" Height="50" Margin="0,0,10,6"
                              SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="نشط"   Tag="Active"/>
                        <ComboBoxItem Content="محذوف" Tag="Deleted"/>
                        <ComboBoxItem Content="الكل"  Tag="All"/>
                    </ComboBox>

                    <TextBox x:Name="NameBox"
                             materialDesign:HintAssist.Hint="الاسم"
                             materialDesign:HintAssist.Foreground="#4A5A7A"
                             Style="{StaticResource DarkOutlinedTextBox}"
                             Width="160" Height="50" Margin="0,0,10,6"
                             TextChanged="Filter_Changed"/>

                    <TextBox x:Name="PNumBox"
                             materialDesign:HintAssist.Hint="رقم السجين"
                             materialDesign:HintAssist.Foreground="#4A5A7A"
                             Style="{StaticResource DarkOutlinedTextBox}"
                             Width="140" Height="50" Margin="0,0,10,6"
                             TextChanged="Filter_Changed"/>

                    <TextBox x:Name="DossierNumBox"
                             materialDesign:HintAssist.Hint="رقم الدوسية"
                             materialDesign:HintAssist.Foreground="#4A5A7A"
                             Style="{StaticResource DarkOutlinedTextBox}"
                             Width="130" Height="50" Margin="0,0,10,6"
                             PreviewTextInput="NumberOnly"
                             TextChanged="Filter_Changed"/>

                    <ComboBox x:Name="YearCombo"
                              materialDesign:HintAssist.Hint="السنة الهجرية"
                              materialDesign:HintAssist.Foreground="#4A5A7A"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Width="140" Height="50" Margin="0,0,10,6"
                              SelectionChanged="Filter_Changed"/>

                    <ComboBox x:Name="MonthCombo"
                              materialDesign:HintAssist.Hint="الشهر"
                              materialDesign:HintAssist.Foreground="#4A5A7A"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Width="100" Height="50" Margin="0,0,10,6"
                              SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="الكل" Tag="0"/>
                        <ComboBoxItem Content="1"  Tag="1"/>
                        <ComboBoxItem Content="2"  Tag="2"/>
                        <ComboBoxItem Content="3"  Tag="3"/>
                        <ComboBoxItem Content="4"  Tag="4"/>
                        <ComboBoxItem Content="5"  Tag="5"/>
                        <ComboBoxItem Content="6"  Tag="6"/>
                        <ComboBoxItem Content="7"  Tag="7"/>
                        <ComboBoxItem Content="8"  Tag="8"/>
                        <ComboBoxItem Content="9"  Tag="9"/>
                        <ComboBoxItem Content="10" Tag="10"/>
                        <ComboBoxItem Content="11" Tag="11"/>
                        <ComboBoxItem Content="12" Tag="12"/>
                    </ComboBox>

                    <TextBox x:Name="HallwayBox"
                             materialDesign:HintAssist.Hint="ممر"
                             materialDesign:HintAssist.Foreground="#4A5A7A"
                             Style="{StaticResource DarkOutlinedTextBox}"
                             Width="80" Height="50" Margin="0,0,10,6"
                             PreviewTextInput="NumberOnly"
                             TextChanged="Filter_Changed"/>

                    <TextBox x:Name="CabinetBox"
                             materialDesign:HintAssist.Hint="كبينة"
                             materialDesign:HintAssist.Foreground="#4A5A7A"
                             Style="{StaticResource DarkOutlinedTextBox}"
                             Width="80" Height="50" Margin="0,0,10,6"
                             PreviewTextInput="NumberOnly"
                             TextChanged="Filter_Changed"/>

                    <TextBox x:Name="ShelfBox"
                             materialDesign:HintAssist.Hint="رف"
                             materialDesign:HintAssist.Foreground="#4A5A7A"
                             Style="{StaticResource DarkOutlinedTextBox}"
                             Width="80" Height="50" Margin="0,0,10,6"
                             PreviewTextInput="NumberOnly"
                             TextChanged="Filter_Changed"/>

                    <Button Content="مسح الفرز"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="{StaticResource DangerRed}"
                            Height="40" Margin="4,0,0,6"
                            Click="ResetFilter_Click"/>
                </WrapPanel>
            </Border>
        </Border>

        <!-- ══ RESULT COUNT + SORT ══ -->
        <Border Grid.Row="2" Background="#0D1F3C"
                BorderThickness="0,0,0,1">
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
            </Border.BorderBrush>
            <Border Padding="20,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               x:Name="ResultCountText"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource EmeraldMid}"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="ترتيب حسب:" FontSize="12"
                                   Foreground="#4A5A7A" Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="SortCombo"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  Width="160" Height="49"
                                  SelectionChanged="Sort_Changed">
                            <ComboBoxItem Content="رقم الدوسية"   Tag="DossierNumber"/>
                            <ComboBoxItem Content="التسلسل"       Tag="SequenceNumber"/>
                            <ComboBoxItem Content="الاسم"         Tag="PersonName"/>
                            <ComboBoxItem Content="رقم السجين"    Tag="PrisonerNumber"/>
                            <ComboBoxItem Content="السنة الهجرية" Tag="HijriYear"/>
                            <ComboBoxItem Content="الموقع"        Tag="Location"/>
                            <ComboBoxItem Content="آخر تعديل"     Tag="UpdatedAt"/>
                            <ComboBoxItem Content="الحالة"        Tag="Status"/>
                        </ComboBox>
                        <Button x:Name="SortDirBtn"
                                Content="↑ تصاعدي"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="{StaticResource RoseGold}"
                                Height="32" Margin="6,0,0,0"
                                Click="SortDir_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <!-- ══ TABLE ══ -->
        <DataGrid Grid.Row="3"
                  x:Name="DataGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                                    Background="Transparent"
                  SelectionMode="Extended"
                  Style="{StaticResource MaterialDesignDataGrid}"
                  materialDesign:DataGridAssist.CellPadding="10 7 10 7"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  EnableRowVirtualization="True"
                  Margin="12,0,12,0"
                  LoadingRow="DataGrid_LoadingRow">

            <DataGrid.Columns>
                <DataGridTextColumn Header="دوسية"      Binding="{Binding DossierNumber}"  Width="75"/>
                <DataGridTextColumn Header="تسلسل"      Binding="{Binding SequenceNumber}" Width="65"/>
                <DataGridTextColumn Header="اسم السجين" Binding="{Binding PersonName}"     Width="*"/>
                <DataGridTextColumn Header="رقم السجين" Binding="{Binding PrisonerNumber}" Width="130"/>
                <DataGridTextColumn Header="التاريخ"    Binding="{Binding HijriDisplay}"   Width="95"/>
                <DataGridTextColumn Header="الموقع"     Binding="{Binding LocationDisplay}" Width="190"/>
                <DataGridTextColumn Header="الحالة"     Binding="{Binding StatusDisplay}"  Width="75"/>
            </DataGrid.Columns>

        </DataGrid>

        <!-- ══ PAGER ══ -->
        <Border Grid.Row="4" Background="#0D1F3C"
                BorderThickness="0,1,0,0">
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
            </Border.BorderBrush>
            <Border Padding="20,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="→ السابق"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Foreground="{StaticResource EmeraldMid}"
                            Height="34" Width="100"
                            Click="PrevPage_Click"/>

                    <TextBlock Grid.Column="1"
                               x:Name="PageText"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="12" Foreground="#4A5A7A"/>

                    <Button Grid.Column="2"
                            Content="التالي ←"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Foreground="{StaticResource EmeraldMid}"
                            Height="34" Width="100"
                            Click="NextPage_Click"/>
                </Grid>
            </Border>
        </Border>

    </Grid>
</Page>
