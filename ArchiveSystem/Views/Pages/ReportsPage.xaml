<Page x:Class="ArchiveSystem.Views.Pages.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="التقارير"
      Background="#F5F5F5"
      FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White"
                BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
            <TextBlock Text="🖨️  التقارير"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#1a7a60"
                       VerticalAlignment="Center"
                       Margin="32,0"/>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28,32,40" MaxWidth="960">

                <!-- ══ DOSSIER FACE ═══════════════════════════════════════════ -->
                <Border Background="White" CornerRadius="8" Padding="24"
                        Margin="0,0,0,24">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" Opacity="0.08" ShadowDepth="2"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="واجهة الدوسية (طباعة)"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="#1a7a60"
                                   Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="1"
                                   Text="تطبع جدول السجناء لدوسية محددة بالترتيب الصحيح ليُلصق على الغلاف الفيزيائي."
                                   FontSize="12" Foreground="#666"
                                   Margin="0,0,0,16"/>

                        <!-- Input + three action buttons -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     x:Name="DossierFaceNumberBox"
                                     materialDesign:HintAssist.Hint="رقم الدوسية *"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Height="44"
                                     PreviewTextInput="NumberOnly"/>

                            <!-- Preview (open PDF in viewer) -->
                            <Button x:Name="DossierFacePreviewBtn"
                                    Grid.Column="2"
                                    Content="🔍 معاينة"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Height="44" Width="110"
                                    Click="PreviewDossierFace_Click"/>

                            <!-- Save PDF to file -->
                            <Button x:Name="DossierFaceSaveBtn"
                                    Grid.Column="4"
                                    Content="💾 حفظ PDF"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Height="44" Width="120"
                                    Click="SaveDossierFacePdf_Click"/>

                            <!-- Direct print (sends to printer) -->
                            <Button x:Name="DossierFacePrintBtn"
                                    Grid.Column="6"
                                    Content="🖨️ طباعة مباشرة"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="#1a7a60" Foreground="White"
                                    Height="44" Width="150"
                                    Click="PrintDossierFaceDirect_Click"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ══ MONTHLY REPORT ═════════════════════════════════════════ -->
                <Border Background="White" CornerRadius="8" Padding="24"
                        Margin="0,0,0,24">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" Opacity="0.08" ShadowDepth="2"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="تقرير شهري"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="#1a7a60"
                                   Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="1"
                                   Text="جميع الدوسيات والملفات لشهر هجري محدد."
                                   FontSize="12" Foreground="#666"
                                   Margin="0,0,0,16"/>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     x:Name="MonthlyMonthBox"
                                     materialDesign:HintAssist.Hint="الشهر (1-12) *"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Height="44"
                                     PreviewTextInput="NumberOnly"/>

                            <TextBox Grid.Column="2"
                                     x:Name="MonthlyYearBox"
                                     materialDesign:HintAssist.Hint="السنة الهجرية *"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Height="44"
                                     PreviewTextInput="NumberOnly"/>

                            <Button x:Name="MonthlyPreviewBtn"
                                    Grid.Column="4"
                                    Content="🔍 معاينة"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Height="44" Width="110"
                                    Click="PreviewMonthly_Click"/>

                            <Button x:Name="MonthlySaveBtn"
                                    Grid.Column="6"
                                    Content="💾 حفظ PDF"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Height="44" Width="120"
                                    Click="SaveMonthlyPdf_Click"/>

                            <Button x:Name="MonthlyPrintBtn"
                                    Grid.Column="8"
                                    Content="🖨️ طباعة مباشرة"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="#1a7a60" Foreground="White"
                                    Height="44" Width="150"
                                    Click="PrintMonthlyDirect_Click"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ══ WEEKLY REPORT ══════════════════════════════════════════════════ -->
                <Border Background="White" CornerRadius="8" Padding="24"
        Margin="0,0,0,24">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" Opacity="0.08" ShadowDepth="2"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                   Text="تقرير أسبوعي"
                   FontSize="15" FontWeight="Bold"
                   Foreground="#1a7a60"
                   Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="1"
                   Text="جميع السجلات المُضافة خلال أسبوع محدد (حسب تاريخ الإنشاء الميلادي)."
                   FontSize="12" Foreground="#666"
                   Margin="0,0,0,16"/>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                     x:Name="WeeklyFromBox"
                     materialDesign:HintAssist.Hint="من تاريخ (yyyy-MM-dd) *"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Height="44"/>

                            <TextBox Grid.Column="2"
                     x:Name="WeeklyToBox"
                     materialDesign:HintAssist.Hint="إلى تاريخ (yyyy-MM-dd) *"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Height="44"/>

                            <Button x:Name="WeeklyPreviewBtn"
                    Grid.Column="4"
                    Content="🔍 معاينة"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Height="44" Width="110"
                    Click="PreviewWeekly_Click"/>

                            <Button x:Name="WeeklySaveBtn"
                    Grid.Column="6"
                    Content="💾 حفظ PDF"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Height="44" Width="120"
                    Click="SaveWeeklyPdf_Click"/>

                            <Button x:Name="WeeklyPrintBtn"
                    Grid.Column="8"
                    Content="🖨️ طباعة مباشرة"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="#1a7a60" Foreground="White"
                    Height="44" Width="150"
                    Click="PrintWeeklyDirect_Click"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ══ YEARLY REPORT ══════════════════════════════════════════ -->
                <Border Background="White" CornerRadius="8" Padding="24"
                        Margin="0,0,0,24">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" Opacity="0.08" ShadowDepth="2"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="تقرير سنوي"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="#1a7a60"
                                   Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="1"
                                   Text="ملخص سنوي لجميع الدوسيات."
                                   FontSize="12" Foreground="#666"
                                   Margin="0,0,0,16"/>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     x:Name="YearlyYearBox"
                                     materialDesign:HintAssist.Hint="السنة الهجرية *"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Height="44"
                                     PreviewTextInput="NumberOnly"/>

                            <Button x:Name="YearlyPreviewBtn"
                                    Grid.Column="2"
                                    Content="🔍 معاينة"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Height="44" Width="110"
                                    Click="PreviewYearly_Click"/>

                            <Button x:Name="YearlySaveBtn"
                                    Grid.Column="4"
                                    Content="💾 حفظ PDF"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Height="44" Width="120"
                                    Click="SaveYearlyPdf_Click"/>

                            <Button x:Name="YearlyPrintBtn"
                                    Grid.Column="6"
                                    Content="🖨️ طباعة مباشرة"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="#1a7a60" Foreground="White"
                                    Height="44" Width="150"
                                    Click="PrintYearlyDirect_Click"/>
                        </Grid>
                    </Grid>
                </Border>


                <!-- ══ DATA QUALITY / ERRORS REPORT ═══════════════════════════════════════ -->
                <Border Background="White" CornerRadius="8" Padding="24"
        Margin="0,0,0,24">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" Opacity="0.08" ShadowDepth="2"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                   Text="تقرير جودة البيانات والأخطاء"
                   FontSize="15" FontWeight="Bold"
                   Foreground="#1a7a60"
                   Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="1"
                   Text="ملخص التحذيرات غير المحلولة من الاستيراد، الدوسيات ذات التعداد غير المطابق، ونسبة تعبئة الحقول المخصصة."
                   FontSize="12" Foreground="#666"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

                        <!-- Live summary strip (loaded on Loaded event) -->
                        <Border Grid.Row="2"
                x:Name="DataQualitySummaryBorder"
                Background="#F0F7F4" CornerRadius="4"
                Padding="12,8" Margin="0,0,0,16"
                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                                <Border Background="#FFEBEE" CornerRadius="4"
                        Padding="10,5" Margin="0,0,10,0"
                        x:Name="DQWarningsBadge">
                                    <TextBlock x:Name="DQWarningsText"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#C62828"/>
                                </Border>
                                <Border Background="#FFF8E1" CornerRadius="4"
                        Padding="10,5" Margin="0,0,10,0"
                        x:Name="DQMismatchBadge">
                                    <TextBlock x:Name="DQMismatchText"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#E65100"/>
                                </Border>
                                <Border Background="#E8F5E9" CornerRadius="4"
                        Padding="10,5"
                        x:Name="DQRecordsBadge">
                                    <TextBlock x:Name="DQRecordsText"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#2E7D32"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Action buttons -->
                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Spacer / description -->
                            <TextBlock Grid.Column="0"
                       Text="يمكن تصدير التقرير كملف PDF أو إرساله للطباعة مباشرة."
                       FontSize="11" Foreground="#999"
                       VerticalAlignment="Center"/>

                            <Button x:Name="DataQualityPreviewBtn"
                    Grid.Column="2"
                    Content="🔍 معاينة"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Height="44" Width="110"
                    Click="PreviewDataQuality_Click"/>

                            <Button x:Name="DataQualitySaveBtn"
                    Grid.Column="4"
                    Content="💾 حفظ PDF"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Height="44" Width="120"
                    Click="SaveDataQualityPdf_Click"/>

                            <Button x:Name="DataQualityPrintBtn"
                    Grid.Column="6"
                    Content="🖨️ طباعة مباشرة"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="#1a7a60" Foreground="White"
                    Height="44" Width="150"
                    Click="PrintDataQualityDirect_Click"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ══ ERROR / STATUS ═════════════════════════════════════════ -->
                <Border x:Name="MsgBorder"
                        CornerRadius="6" Padding="14,10"
                        Visibility="Collapsed">
                    <TextBlock x:Name="MsgText"
                               FontSize="13" TextWrapping="Wrap"/>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
