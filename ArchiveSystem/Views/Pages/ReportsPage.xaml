<Page x:Class="ArchiveSystem.Views.Pages.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="التقارير"
      Background="{StaticResource MidnightBase}"
      FontFamily="Noto Kufi Arabic, Segoe UI"
      FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                BorderThickness="0,0,0,1">
            <Border.Background>
                <SolidColorBrush Color="#0A1628" Opacity="0.60"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
            </Border.BorderBrush>
            <TextBlock Text="🖨️  التقارير"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource RoseGold}"
                       VerticalAlignment="Center"
                       Margin="32,0"/>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28,32,40" MaxWidth="960">

                <!-- ══ DOSSIER FACE ══ -->
                <Border CornerRadius="8" Padding="24" Margin="0,0,0,20"
                        BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                    </Border.BorderBrush>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="واجهة الدوسية (طباعة)"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource RoseGold}"
                                   Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="1"
                                   Text="تطبع جدول السجناء لدوسية محددة بالترتيب الصحيح ليُلصق على الغلاف الفيزيائي."
                                   FontSize="12" Foreground="#4A5A7A"
                                   Margin="0,0,0,16"/>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     x:Name="DossierFaceNumberBox"
                                     materialDesign:HintAssist.Hint="رقم الدوسية *"
                                     materialDesign:HintAssist.Foreground="#4A5A7A"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     PreviewTextInput="NumberOnly" Margin="0,0,0,-10"/>

                            <Button x:Name="DossierFacePreviewBtn"
                                    Grid.Column="2"
                                    Content="🔍 معاينة"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="{StaticResource TextSecondary}"
                                    Height="44" Width="110"
                                    Click="PreviewDossierFace_Click"/>

                            <Button x:Name="DossierFaceSaveBtn"
                                    Grid.Column="4"
                                    Content="💾 حفظ PDF"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="{StaticResource TextSecondary}"
                                    Height="44" Width="120"
                                    Click="SaveDossierFacePdf_Click"/>

                            <Button x:Name="DossierFacePrintBtn"
                                    Grid.Column="6"
                                    Content="🖨️ طباعة مباشرة"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{StaticResource EmeraldMid}" Foreground="White"
                                    Height="44" Width="150"
                                    Click="PrintDossierFaceDirect_Click"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ══ BATCH DOSSIER FACE PRINT ══ -->
                <Border CornerRadius="8" Padding="24" Margin="0,0,0,20"
                        BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                    </Border.BorderBrush>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="طباعة مجموعة دوسيات (نطاق)"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource RoseGold}"
                                       VerticalAlignment="Center"/>
                            <Border BorderThickness="1" CornerRadius="4"
                                    Padding="8,2" Margin="12,0,0,0"
                                    VerticalAlignment="Center">
                                <Border.Background>
                                    <SolidColorBrush Color="#00E676" Opacity="0.10"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#00E676" Opacity="0.25"/>
                                </Border.BorderBrush>
                                <TextBlock Text="جديد"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource EmeraldMid}"/>
                            </Border>
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Text="تطبع واجهات جميع الدوسيات في نطاق رقمي محدد (من رقم إلى رقم) دفعةً واحدة في ملف PDF واحد."
                                   FontSize="12" Foreground="#4A5A7A"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16"/>

                        <Grid Grid.Row="2" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     x:Name="BatchFromBox"
                                     materialDesign:HintAssist.Hint="من رقم الدوسية *"
                                     materialDesign:HintAssist.Foreground="#4A5A7A"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     PreviewTextInput="NumberOnly"
                                     TextChanged="BatchRange_Changed"/>

                            <TextBlock Grid.Column="1"
                                       Text="←"
                                       FontSize="18" Foreground="#4A5A7A"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                            <TextBox Grid.Column="2"
                                     x:Name="BatchToBox"
                                     materialDesign:HintAssist.Hint="إلى رقم الدوسية *"
                                     materialDesign:HintAssist.Foreground="#4A5A7A"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     PreviewTextInput="NumberOnly"
                                     TextChanged="BatchRange_Changed"/>

                            <Border Grid.Column="4"
                                    x:Name="BatchInfoBadge"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12,6"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed">
                                <Border.Background>
                                    <SolidColorBrush Color="#00E676" Opacity="0.08"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#00E676" Opacity="0.25"/>
                                </Border.BorderBrush>
                                <StackPanel>
                                    <TextBlock x:Name="BatchCountText"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource EmeraldMid}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="BatchRecordsText"
                                               FontSize="11" Foreground="#4A5A7A"
                                               HorizontalAlignment="Center"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="3"
                                x:Name="BatchWarningBorder"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12,8"
                                Margin="0,0,0,12"
                                Visibility="Collapsed">
                            <Border.Background>
                                <SolidColorBrush Color="#FFB300" Opacity="0.08"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#FFB300" Opacity="0.30"/>
                            </Border.BorderBrush>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠️ " FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock x:Name="BatchWarningText"
                                           FontSize="12" Foreground="#FFB300"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="3" Margin="0,4,0,0"
                              x:Name="BatchButtonsGrid">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        x:Name="BatchBusyPanel"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                             Value="0" IsIndeterminate="True"
                                             Width="20" Height="20"
                                             Margin="0,0,8,0"/>
                                <TextBlock x:Name="BatchProgressText"
                                           Text="جاري إنشاء PDF..."
                                           FontSize="12" Foreground="#4A5A7A"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Button x:Name="BatchPreviewBtn"
                                    Grid.Column="2"
                                    Content="🔍 معاينة"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="{StaticResource TextSecondary}"
                                    Height="44" Width="110"
                                    Click="PreviewBatchDossierFace_Click"/>

                            <Button x:Name="BatchSaveBtn"
                                    Grid.Column="4"
                                    Content="💾 حفظ PDF"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="{StaticResource TextSecondary}"
                                    Height="44" Width="120"
                                    Click="SaveBatchDossierFacePdf_Click"/>

                            <Button x:Name="BatchPrintBtn"
                                    Grid.Column="6"
                                    Content="🖨️ طباعة مجموعة"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{StaticResource EmeraldMid}" Foreground="White"
                                    Height="44" Width="160"
                                    Click="PrintBatchDossierFaceDirect_Click"/>
                        </Grid>

                    </Grid>
                </Border>

                <!-- ══ MONTHLY REPORT ══ -->
                <Border CornerRadius="8" Padding="24" Margin="0,0,0,20"
                        BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                    </Border.BorderBrush>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="تقرير شهري"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource RoseGold}"
                                   Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="1"
                                   Text="جميع الدوسيات والملفات لشهر هجري محدد."
                                   FontSize="12" Foreground="#4A5A7A"
                                   Margin="0,0,0,16"/>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     x:Name="MonthlyMonthBox"
                                     materialDesign:HintAssist.Hint="الشهر (1-12) *"
                                     materialDesign:HintAssist.Foreground="#4A5A7A"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     PreviewTextInput="NumberOnly" Grid.ColumnSpan="2" Margin="0,0,10,-10"/>

                            <TextBox Grid.Column="2"
                                     x:Name="MonthlyYearBox"
                                     materialDesign:HintAssist.Hint="السنة الهجرية *"
                                     materialDesign:HintAssist.Foreground="#4A5A7A"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     PreviewTextInput="NumberOnly" Margin="0,0,0,-10"/>

                            <Button x:Name="MonthlyPreviewBtn"
                                    Grid.Column="4"
                                    Content="🔍 معاينة"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="{StaticResource TextSecondary}"
                                    Height="44" Width="110"
                                    Click="PreviewMonthly_Click"/>

                            <Button x:Name="MonthlySaveBtn"
                                    Grid.Column="6"
                                    Content="💾 حفظ PDF"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="{StaticResource TextSecondary}"
                                    Height="44" Width="120"
                                    Click="SaveMonthlyPdf_Click"/>

                            <Button x:Name="MonthlyPrintBtn"
                                    Grid.Column="8"
                                    Content="🖨️ طباعة مباشرة"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{StaticResource EmeraldMid}" Foreground="White"
                                    Height="44" Width="150"
                                    Click="PrintMonthlyDirect_Click"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ══ WEEKLY REPORT ══ -->
                <Border CornerRadius="8" Padding="24" Margin="0,0,0,20"
                        BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                    </Border.BorderBrush>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="تقرير أسبوعي"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource RoseGold}"
                                   Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="1"
                                   Text="جميع السجلات المُضافة خلال أسبوع محدد (حسب تاريخ الإنشاء الميلادي)."
                                   FontSize="12" Foreground="#4A5A7A"
                                   Margin="0,0,0,16"/>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     x:Name="WeeklyFromBox"
                                     materialDesign:HintAssist.Hint="من تاريخ (yyyy-MM-dd) *"
                                     materialDesign:HintAssist.Foreground="#4A5A7A"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Height="53" Grid.ColumnSpan="2" Margin="0,0,10,0" VerticalAlignment="Top"/>

                            <TextBox Grid.Column="2"
                                     x:Name="WeeklyToBox"
                                     materialDesign:HintAssist.Hint="إلى تاريخ (yyyy-MM-dd) *"
                                     materialDesign:HintAssist.Foreground="#4A5A7A"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,4,0,0"/>

                            <Button x:Name="WeeklyPreviewBtn"
                                    Grid.Column="4"
                                    Content="🔍 معاينة"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="{StaticResource TextSecondary}"
                                    Height="44" Width="110"
                                    Click="PreviewWeekly_Click"/>

                            <Button x:Name="WeeklySaveBtn"
                                    Grid.Column="6"
                                    Content="💾 حفظ PDF"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="{StaticResource TextSecondary}"
                                    Height="44" Width="120"
                                    Click="SaveWeeklyPdf_Click"/>

                            <Button x:Name="WeeklyPrintBtn"
                                    Grid.Column="8"
                                    Content="🖨️ طباعة مباشرة"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{StaticResource EmeraldMid}" Foreground="White"
                                    Height="44" Width="150"
                                    Click="PrintWeeklyDirect_Click"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ══ YEARLY REPORT ══ -->
                <Border CornerRadius="8" Padding="24" Margin="0,0,0,20"
                        BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                    </Border.BorderBrush>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="تقرير سنوي"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource RoseGold}"
                                   Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="1"
                                   Text="ملخص سنوي لجميع الدوسيات."
                                   FontSize="12" Foreground="#4A5A7A"
                                   Margin="0,0,0,16"/>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     x:Name="YearlyYearBox"
                                     materialDesign:HintAssist.Hint="السنة الهجرية *"
                                     materialDesign:HintAssist.Foreground="#4A5A7A"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     PreviewTextInput="NumberOnly" Margin="0,0,0,-9"/>

                            <Button x:Name="YearlyPreviewBtn"
                                    Grid.Column="2"
                                    Content="🔍 معاينة"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="{StaticResource TextSecondary}"
                                    Height="44" Width="110"
                                    Click="PreviewYearly_Click"/>

                            <Button x:Name="YearlySaveBtn"
                                    Grid.Column="4"
                                    Content="💾 حفظ PDF"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="{StaticResource TextSecondary}"
                                    Height="44" Width="120"
                                    Click="SaveYearlyPdf_Click"/>

                            <Button x:Name="YearlyPrintBtn"
                                    Grid.Column="6"
                                    Content="🖨️ طباعة مباشرة"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{StaticResource EmeraldMid}" Foreground="White"
                                    Height="44" Width="150"
                                    Click="PrintYearlyDirect_Click"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ══ DATA QUALITY REPORT ══ -->
                <Border CornerRadius="8" Padding="24" Margin="0,0,0,20"
                        BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                    </Border.BorderBrush>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="تقرير جودة البيانات والأخطاء"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource RoseGold}"
                                   Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="1"
                                   Text="ملخص التحذيرات غير المحلولة من الاستيراد، الدوسيات ذات التعداد غير المطابق، ونسبة تعبئة الحقول المخصصة."
                                   FontSize="12" Foreground="#4A5A7A"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16"/>

                        <Border Grid.Row="2"
                                x:Name="DataQualitySummaryBorder"
                                BorderThickness="1" CornerRadius="4"
                                Padding="12,8" Margin="0,0,0,16"
                                Visibility="Collapsed">
                            <Border.Background>
                                <SolidColorBrush Color="#00E676" Opacity="0.06"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#00E676" Opacity="0.15"/>
                            </Border.BorderBrush>
                            <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                                <Border BorderThickness="1" CornerRadius="4"
                                        Padding="10,5" Margin="0,0,10,0"
                                        x:Name="DQWarningsBadge">
                                    <Border.Background>
                                        <SolidColorBrush Color="#E53935" Opacity="0.10"/>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="#E53935" Opacity="0.25"/>
                                    </Border.BorderBrush>
                                    <TextBlock x:Name="DQWarningsText"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource DangerRed}"/>
                                </Border>
                                <Border BorderThickness="1" CornerRadius="4"
                                        Padding="10,5" Margin="0,0,10,0"
                                        x:Name="DQMismatchBadge">
                                    <Border.Background>
                                        <SolidColorBrush Color="#FFB300" Opacity="0.08"/>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="#FFB300" Opacity="0.25"/>
                                    </Border.BorderBrush>
                                    <TextBlock x:Name="DQMismatchText"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="#FFB300"/>
                                </Border>
                                <Border BorderThickness="1" CornerRadius="4"
                                        Padding="10,5"
                                        x:Name="DQRecordsBadge">
                                    <Border.Background>
                                        <SolidColorBrush Color="#00E676" Opacity="0.08"/>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="#00E676" Opacity="0.20"/>
                                    </Border.BorderBrush>
                                    <TextBlock x:Name="DQRecordsText"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource EmeraldMid}"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="يمكن تصدير التقرير كملف PDF أو إرساله للطباعة مباشرة."
                                       FontSize="11" Foreground="#4A5A7A"
                                       VerticalAlignment="Center"/>

                            <Button x:Name="DataQualityPreviewBtn"
                                    Grid.Column="2"
                                    Content="🔍 معاينة"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="{StaticResource TextSecondary}"
                                    Height="44" Width="110"
                                    Click="PreviewDataQuality_Click"/>

                            <Button x:Name="DataQualitySaveBtn"
                                    Grid.Column="4"
                                    Content="💾 حفظ PDF"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="{StaticResource TextSecondary}"
                                    Height="44" Width="120"
                                    Click="SaveDataQualityPdf_Click"/>

                            <Button x:Name="DataQualityPrintBtn"
                                    Grid.Column="6"
                                    Content="🖨️ طباعة مباشرة"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{StaticResource EmeraldMid}" Foreground="White"
                                    Height="44" Width="150"
                                    Click="PrintDataQualityDirect_Click"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ══ ERROR / STATUS ══ -->
                <Border x:Name="MsgBorder"
                        CornerRadius="6" Padding="14,10"
                        Visibility="Collapsed">
                    <TextBlock x:Name="MsgText"
                               FontSize="13" TextWrapping="Wrap"/>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
