<Window x:Class="ArchiveSystem.Views.Dialogs.AddEditCustomFieldDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="حقل مخصص"
        Height="640" Width="500"
        Padding="0"
        MinHeight="500"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        FontFamily="Noto Kufi Arabic, Segoe UI"
        Background="{StaticResource MidnightBase}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      Padding="28,24,28,0">
            <StackPanel>

                <!-- Title -->
                <TextBlock x:Name="TitleText"
                           Text="إضافة حقل مخصص"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource RoseGold}"
                           Margin="0,0,0,20"/>

                <!-- Error -->
                <Border x:Name="ErrorBorder"
                        CornerRadius="6"
                        Padding="10,6" Margin="0,0,0,12"
                        Visibility="Collapsed">
                    <Border.Background>
                        <SolidColorBrush Color="#FF5252" Opacity="0.10"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#FF5252" Opacity="0.35"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <TextBlock x:Name="ErrorText"
                               Foreground="{StaticResource DangerRed}"
                               FontSize="12" TextWrapping="Wrap"/>
                </Border>

                <!-- Arabic label -->
                <TextBox x:Name="ArabicLabelBox"
                         materialDesign:HintAssist.Hint="التسمية العربية *"
                         materialDesign:HintAssist.Foreground="#4A5A7A"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,14"/>

                <!-- Field type -->
                <ComboBox x:Name="FieldTypeCombo"
                          materialDesign:HintAssist.Hint="نوع الحقل *"
                          materialDesign:HintAssist.Foreground="#4A5A7A"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,0,14"
                          SelectionChanged="FieldTypeCombo_SelectionChanged">
                    <ComboBoxItem Content="نص"                  Tag="Text"/>
                    <ComboBoxItem Content="نص مع اقتراحات"      Tag="TextWithSuggestions"/>
                    <ComboBoxItem Content="رقم"                  Tag="Number"/>
                    <ComboBoxItem Content="تاريخ"                Tag="Date"/>
                    <ComboBoxItem Content="نعم / لا"             Tag="Boolean"/>
                    <ComboBoxItem Content="اختيار واحد"          Tag="SingleChoice"/>
                    <ComboBoxItem Content="اختيار متعدد"         Tag="MultiChoice"/>
                </ComboBox>

                <!-- Suggestion limit (TextWithSuggestions only) -->
                <StackPanel x:Name="SuggestionPanel" Visibility="Collapsed" Margin="0,0,0,14">
                    <TextBox x:Name="SuggestionLimitBox"
                             materialDesign:HintAssist.Hint="حد الاقتراحات (0 = بلا حد)"
                             materialDesign:HintAssist.Foreground="#4A5A7A"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             PreviewTextInput="NumberOnly"/>
                </StackPanel>

                <!-- Options panel (SingleChoice / MultiChoice) -->
                <StackPanel x:Name="OptionsPanel" Visibility="Collapsed" Margin="0,0,0,14">
                    <TextBlock Text="خيارات القائمة"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource RoseGoldLight}"
                               Margin="0,0,0,8"/>

                    <!-- Add option row -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 x:Name="NewOptionBox"
                                 materialDesign:HintAssist.Hint="قيمة جديدة"
                                 materialDesign:HintAssist.Foreground="#4A5A7A"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Height="40" Margin="0,0,8,0"/>
                        <Button Grid.Column="1"
                                Content="➕ إضافة"
                                Height="40" Width="90"
                                Foreground="#050D1A" FontWeight="SemiBold"
                                Click="AddOption_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                    <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="6"/>
                                </Style>
                            </Button.Style>
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00BCD4" Offset="0"/>
                                    <GradientStop Color="#00E676" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>
                    </Grid>

                    <!-- Options list -->
                    <Border CornerRadius="6" MaxHeight="160">
                        <Border.Background>
                            <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                        </Border.BorderBrush>
                        <Border.BorderThickness>1</Border.BorderThickness>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="OptionsList" Margin="4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="6" Margin="0,3" Padding="10,6">
                                            <Border.Background>
                                                <SolidColorBrush Color="#00E676" Opacity="0.06"/>
                                            </Border.Background>
                                            <Border.BorderBrush>
                                                <SolidColorBrush Color="#00E676" Opacity="0.15"/>
                                            </Border.BorderBrush>
                                            <Border.BorderThickness>1</Border.BorderThickness>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding ArabicValue}"
                                                           FontSize="13"
                                                           VerticalAlignment="Center"
                                                           Padding="8,4"
                                                           Foreground="{StaticResource EmeraldMid}"/>
                                                <Button Grid.Column="1"
                                                        Content="✕"
                                                        Style="{StaticResource MaterialDesignFlatButton}"
                                                        Foreground="{StaticResource DangerRed}"
                                                        Height="28" Width="32"
                                                        Padding="0"
                                                        Tag="{Binding CustomFieldOptionId}"
                                                        Click="RemoveOption_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>

                <!-- Sort order -->
                <TextBox x:Name="SortOrderBox"
                         materialDesign:HintAssist.Hint="ترتيب العرض (0 = أول)"
                         materialDesign:HintAssist.Foreground="#4A5A7A"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,16"
                         PreviewTextInput="NumberOnly"/>

                <!-- Checkboxes -->
                <WrapPanel Margin="0,0,0,6">
                    <CheckBox x:Name="IsRequiredChk"    Content="مطلوب"               Margin="0,0,16,8"/>
                    <CheckBox x:Name="IsActiveChk"      Content="نشط"                 Margin="0,0,16,8" IsChecked="True"/>
                    <CheckBox x:Name="ShowInEntryChk"   Content="يظهر في الإدخال"     Margin="0,0,16,8" IsChecked="True"/>
                    <CheckBox x:Name="ShowInAllDataChk" Content="يظهر في كل البيانات" Margin="0,0,16,8" IsChecked="True"/>
                    <CheckBox x:Name="ShowInReportsChk" Content="يظهر في التقارير"    Margin="0,0,16,8"/>
                    <CheckBox x:Name="EnableStatisticsChk" Content="إحصاءات"          Margin="0,0,16,8"/>
                    <CheckBox x:Name="AllowBulkUpdateChk"  Content="تعبئة جماعية"     Margin="0,0,16,8" IsChecked="True"/>
                </WrapPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Fixed buttons at bottom -->
        <Border Grid.Row="1"
                BorderThickness="0,1,0,0"
                Padding="28,14">
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
            </Border.BorderBrush>
            <Border.Background>
                <SolidColorBrush Color="#0A1628" Opacity="0.60"/>
            </Border.Background>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="حفظ"
                        Height="38" Width="100"
                        Margin="0,0,10,0"
                        Foreground="#050D1A" FontWeight="SemiBold"
                        Click="Save_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="6"/>
                        </Style>
                    </Button.Style>
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00BCD4" Offset="0"/>
                            <GradientStop Color="#00E676" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
                <Button Content="إلغاء"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="{StaticResource TextSecondary}"
                        Width="100" Height="38"
                        Click="Cancel_Click"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
