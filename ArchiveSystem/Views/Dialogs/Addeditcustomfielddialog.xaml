<Window x:Class="ArchiveSystem.Views.Dialogs.AddEditCustomFieldDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="حقل مخصص"
        Height="620" Width="500"
        Padding="20"
        MinHeight="500"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      Padding="28,24,28,0">
            <StackPanel>

                <!-- Title -->
                <TextBlock x:Name="TitleText"
                           Text="إضافة حقل مخصص"
                           FontSize="18" FontWeight="Bold"
                           Foreground="#1a7a60"
                           Margin="0,0,0,20"/>

                <!-- Error -->
                <Border x:Name="ErrorBorder"
                        Background="#FFEBEE" BorderBrush="#EF9A9A"
                        BorderThickness="1" CornerRadius="4"
                        Padding="10,6" Margin="0,0,0,12"
                        Visibility="Collapsed">
                    <TextBlock x:Name="ErrorText"
                               Foreground="#C62828" FontSize="12"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Arabic label -->
                <TextBox x:Name="ArabicLabelBox"
                         materialDesign:HintAssist.Hint="التسمية العربية *"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="20,0,20,14"/>

                <!-- Field type -->
                <ComboBox x:Name="FieldTypeCombo"
                          materialDesign:HintAssist.Hint="نوع الحقل *"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="20,0,20,14"
                          SelectionChanged="FieldTypeCombo_SelectionChanged">
                    <ComboBoxItem Content="نص"                  Tag="Text"/>
                    <ComboBoxItem Content="نص مع اقتراحات"      Tag="TextWithSuggestions"/>
                    <ComboBoxItem Content="رقم"                  Tag="Number"/>
                    <ComboBoxItem Content="تاريخ"                Tag="Date"/>
                    <ComboBoxItem Content="نعم / لا"             Tag="Boolean"/>
                    <ComboBoxItem Content="اختيار واحد"          Tag="SingleChoice"/>
                    <ComboBoxItem Content="اختيار متعدد"         Tag="MultiChoice"/>
                </ComboBox>

                <!-- Suggestion limit (TextWithSuggestions only) -->
                <StackPanel x:Name="SuggestionPanel" Visibility="Collapsed" Margin="20,0,20,14">
                    <TextBox x:Name="SuggestionLimitBox"
                             materialDesign:HintAssist.Hint="حد الاقتراحات (0 = بلا حد)"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             PreviewTextInput="NumberOnly"/>
                </StackPanel>

                <!-- Options panel (SingleChoice / MultiChoice) -->
                <StackPanel x:Name="OptionsPanel" Visibility="Collapsed" Margin="20,0,20,14">
                    <TextBlock Text="خيارات القائمة"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#555" Margin="0,0,0,8"/>

                    <!-- Add option row -->
                    <Grid Margin="20,0,20,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 x:Name="NewOptionBox"
                                 materialDesign:HintAssist.Hint="قيمة جديدة"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Height="40" Margin="0,0,8,0"/>
                        <Button Grid.Column="1"
                                Content="➕ إضافة"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#1a7a60" Foreground="White"
                                Height="40" Width="90"
                                Click="AddOption_Click"/>
                    </Grid>

                    <!-- Options list -->
                    <Border BorderBrush="#E0E0E0" BorderThickness="1"
                            CornerRadius="4" Background="White" MaxHeight="160">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="OptionsList" Margin="4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding ArabicValue}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"
                                                       Padding="8,4"/>
                                            <Button Grid.Column="1"
                                                    Content="✕"
                                                    Style="{StaticResource MaterialDesignFlatButton}"
                                                    Foreground="#C62828"
                                                    Height="28" Width="32"
                                                    Padding="0"
                                                    Tag="{Binding CustomFieldOptionId}"
                                                    Click="RemoveOption_Click"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>

                <!-- Sort order -->
                <TextBox x:Name="SortOrderBox"
                         materialDesign:HintAssist.Hint="ترتيب العرض (0 = أول)"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="20,0,20,16"
                         PreviewTextInput="NumberOnly"/>

                <!-- Checkboxes -->
                <WrapPanel Margin="0,0,0,6">
                    <CheckBox x:Name="IsRequiredChk"    Content="مطلوب"             Margin="0,0,16,8"/>
                    <CheckBox x:Name="IsActiveChk"      Content="نشط"               Margin="0,0,16,8" IsChecked="True"/>
                    <CheckBox x:Name="ShowInEntryChk"   Content="يظهر في الإدخال"   Margin="0,0,16,8" IsChecked="True"/>
                    <CheckBox x:Name="ShowInAllDataChk" Content="يظهر في كل البيانات" Margin="0,0,16,8" IsChecked="True"/>
                    <CheckBox x:Name="ShowInReportsChk" Content="يظهر في التقارير"  Margin="0,0,16,8"/>
                    <CheckBox x:Name="EnableStatisticsChk" Content="إحصاءات"        Margin="0,0,16,8"/>
                    <CheckBox x:Name="AllowBulkUpdateChk" Content="تعبئة جماعية"    Margin="0,0,16,8" IsChecked="True"/>
                </WrapPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Fixed buttons at bottom -->
        <Border Grid.Row="1"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0"
                Background="#F5F5F5"
                Padding="28,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="حفظ"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#1a7a60" Foreground="White"
                        Width="100" Height="38"
                        Margin="0,0,10,0"
                        Click="Save_Click"/>
                <Button Content="إلغاء"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Width="100" Height="38"
                        Click="Cancel_Click"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
