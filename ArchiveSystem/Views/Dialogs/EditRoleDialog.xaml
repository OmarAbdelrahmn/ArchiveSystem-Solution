<!-- ═══════════════════════════════════════════════════════════════
     EditRoleDialog.xaml
═══════════════════════════════════════════════════════════════ -->
<Window x:Class="ArchiveSystem.Views.Dialogs.EditRoleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="تعديل الدور والصلاحيات"
        Height="580" Width="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        FontFamily="Noto Kufi Arabic, Segoe UI"
        Background="{StaticResource MidnightBase}">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="تعديل الدور والصلاحيات"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource RoseGold}"
                   Margin="0,0,0,16"/>

        <Border Grid.Row="1"
                x:Name="ErrorBorder"
                CornerRadius="6" Padding="10,6" Margin="0,0,0,10"
                Visibility="Collapsed">
            <Border.Background>
                <SolidColorBrush Color="#FF5252" Opacity="0.10"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#FF5252" Opacity="0.35"/>
            </Border.BorderBrush>
            <Border.BorderThickness>1</Border.BorderThickness>
            <TextBlock x:Name="ErrorText" Foreground="{StaticResource DangerRed}"
                       FontSize="12" TextWrapping="Wrap"/>
        </Border>

        <TextBox Grid.Row="2"
                 x:Name="RoleNameBox"
                 materialDesign:HintAssist.Hint="اسم الدور *"
                 materialDesign:HintAssist.Foreground="#4A5A7A"
                 Style="{StaticResource DarkOutlinedTextBox}"
                 Margin="0,0,0,16"/>

        <Grid Grid.Row="3" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      x:Name="PermissionCombo"
                      materialDesign:HintAssist.Hint="اختر صلاحية لإضافتها"
                      materialDesign:HintAssist.Foreground="#4A5A7A"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      DisplayMemberPath="ArabicLabel"
                      Margin="0,0,10,0"/>

            <Button Grid.Column="1"
                    Content="➕ إضافة"
                    Height="40" Width="90"
                    Foreground="#050D1A" FontWeight="SemiBold"
                    Click="AddPermission_Click">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="6"/>
                    </Style>
                </Button.Style>
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#00BCD4" Offset="0"/>
                        <GradientStop Color="#00E676" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>
        </Grid>

        <StackPanel Grid.Row="4">
            <TextBlock Text="الصلاحيات المُعيَّنة"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource RoseGoldLight}"
                       Margin="0,0,0,8"/>

            <Border CornerRadius="6">
                <Border.Background>
                    <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
                </Border.BorderBrush>
                <Border.BorderThickness>1</Border.BorderThickness>
                <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="AssignedList" Margin="8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" Margin="0,3" Padding="10,6">
                                    <Border.Background>
                                        <SolidColorBrush Color="#00E676" Opacity="0.06"/>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="#00E676" Opacity="0.15"/>
                                    </Border.BorderBrush>
                                    <Border.BorderThickness>1</Border.BorderThickness>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding ArabicLabel}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource EmeraldMid}"/>
                                        <Button Grid.Column="1"
                                                Content="✕"
                                                Style="{StaticResource MaterialDesignFlatButton}"
                                                Foreground="{StaticResource DangerRed}"
                                                Height="28" Width="32" Padding="0"
                                                Tag="{Binding PermissionKey}"
                                                Click="RemovePermission_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal"
                    HorizontalAlignment="Left" Margin="0,16,0,0">
            <Button Content="حفظ"
                    Height="38" Width="100" Margin="0,0,10,0"
                    Foreground="#050D1A" FontWeight="SemiBold"
                    Click="SaveButton_Click">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="6"/>
                    </Style>
                </Button.Style>
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#00BCD4" Offset="0"/>
                        <GradientStop Color="#00E676" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>
            <Button Content="إغلاق"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Foreground="{StaticResource TextSecondary}"
                    Width="100" Height="38"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
