<Window x:Class="ArchiveSystem.Views.Dialogs.EditRoleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="تعديل الدور والصلاحيات"
        Height="580" Width="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI"
        Background="#F5F5F5">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="تعديل الدور والصلاحيات"
                   FontSize="18" FontWeight="Bold"
                   Foreground="#1a7a60"
                   Margin="0,0,0,16"/>

        <!-- Error -->
        <Border Grid.Row="1"
                x:Name="ErrorBorder"
                Background="#FFEBEE" BorderBrush="#EF9A9A"
                BorderThickness="1" CornerRadius="4"
                Padding="10,6" Margin="0,0,0,10"
                Visibility="Collapsed">
            <TextBlock x:Name="ErrorText"
                       Foreground="#C62828" FontSize="12"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Role name -->
        <TextBox Grid.Row="2"
                 x:Name="RoleNameBox"
                 materialDesign:HintAssist.Hint="اسم الدور *"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0,0,0,16"/>

        <!-- Dropdown + Add button -->
        <Grid Grid.Row="3" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      x:Name="PermissionCombo"
                      materialDesign:HintAssist.Hint="اختر صلاحية لإضافتها"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      DisplayMemberPath="ArabicLabel"
                      Margin="0,0,10,0"/>

            <Button Grid.Column="1"
                    Content="➕ إضافة"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="#1a7a60" Foreground="White"
                    Height="40" Width="90"
                    Click="AddPermission_Click"/>
        </Grid>

        <!-- Assigned permissions list -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="الصلاحيات المُعيَّنة"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="#555"
                       Margin="0,0,0,8"/>

            <Border BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="4"
                    Background="White">
                <ScrollViewer MaxHeight="260"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="AssignedList"
                                  Margin="8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F1F8F5"
                                        CornerRadius="4"
                                        Margin="0,3"
                                        Padding="10,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding ArabicLabel}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"
                                                   Foreground="#1a7a60"/>

                                        <Button Grid.Column="1"
                                                Content="✕"
                                                Style="{StaticResource MaterialDesignFlatButton}"
                                                Foreground="#C62828"
                                                Height="28" Width="32"
                                                Padding="0"
                                                Tag="{Binding PermissionKey}"
                                                Click="RemovePermission_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="0,16,0,0">
            <Button Content="حفظ"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="#1a7a60" Foreground="White"
                    Width="100" Height="38"
                    Margin="0,0,10,0"
                    Click="SaveButton_Click"/>
            <Button Content="إغلاق"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Width="100" Height="38"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>