<Window x:Class="ArchiveSystem.Views.Dialogs.EditRecordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="تعديل السجل"
        Height="500" Width="460"
        MinHeight="420"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        FontFamily="Noto Kufi Arabic, Segoe UI"
        Background="{StaticResource MidnightBase}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      Padding="28,24,28,0">
            <StackPanel>

                <TextBlock Text="تعديل السجل"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource RoseGold}"
                           Margin="0,0,0,20"/>

                <Border x:Name="ErrorBorder"
                        CornerRadius="6" Padding="10,6" Margin="0,0,0,12"
                        Visibility="Collapsed">
                    <Border.Background>
                        <SolidColorBrush Color="#FF5252" Opacity="0.10"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#FF5252" Opacity="0.35"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <TextBlock x:Name="ErrorText"
                               Foreground="{StaticResource DangerRed}"
                               FontSize="12" TextWrapping="Wrap"/>
                </Border>

                <TextBox x:Name="SequenceBox"
                         materialDesign:HintAssist.Hint="رقم التسلسل"
                         materialDesign:HintAssist.Foreground="#4A5A7A"
                         Style="{StaticResource DarkOutlinedTextBox}"
                         IsReadOnly="True" Opacity="0.5"
                         Margin="20,0,20,14"/>

                <TextBox x:Name="PersonNameBox"
                         materialDesign:HintAssist.Hint="اسم السجين *"
                         materialDesign:HintAssist.Foreground="#4A5A7A"
                         Style="{StaticResource DarkOutlinedTextBox}"
                         Margin="20,0,20,14"/>

                <TextBox x:Name="PrisonerNumberBox"
                         materialDesign:HintAssist.Hint="رقم السجين (10 أرقام) *"
                         materialDesign:HintAssist.Foreground="#4A5A7A"
                         Style="{StaticResource DarkOutlinedTextBox}"
                         MaxLength="10"
                         Margin="20,0,20,14"/>

                <TextBox x:Name="NotesBox"
                         materialDesign:HintAssist.Hint="ملاحظات (اختياري)"
                         materialDesign:HintAssist.Foreground="#4A5A7A"
                         Style="{StaticResource DarkOutlinedTextBox}"
                         AcceptsReturn="True"
                         Height="70"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Margin="20,0,20,14"/>

                <StackPanel x:Name="CustomFieldsPanel" Margin="20,0,20,14"/>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1"
                BorderThickness="0,1,0,0"
                Padding="28,14">
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
            </Border.BorderBrush>
            <Border.Background>
                <SolidColorBrush Color="#0A1628" Opacity="0.60"/>
            </Border.Background>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="حفظ"
                        Height="38" Width="100" Margin="0,0,10,0"
                        Foreground="#050D1A" FontWeight="SemiBold"
                        Click="Save_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="6"/>
                        </Style>
                    </Button.Style>
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00BCD4" Offset="0"/>
                            <GradientStop Color="#00E676" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
                <Button Content="إلغاء"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="{StaticResource TextSecondary}"
                        Width="100" Height="38"
                        Click="Cancel_Click"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
