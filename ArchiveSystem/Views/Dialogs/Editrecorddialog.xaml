<Window x:Class="ArchiveSystem.Views.Dialogs.EditRecordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="تعديل السجل"
        Height="500" Width="460"
        MinHeight="420"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scrollable fields -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      Padding="28,24,28,0">
            <StackPanel>

                <TextBlock Text="تعديل السجل"
                           FontSize="18" FontWeight="Bold"
                           Foreground="#1a7a60"
                           Margin="0,0,0,20"/>

                <!-- Error -->
                <Border x:Name="ErrorBorder"
                        Background="#FFEBEE" BorderBrush="#EF9A9A"
                        BorderThickness="1" CornerRadius="4"
                        Padding="10,6" Margin="0,0,0,12"
                        Visibility="Collapsed">
                    <TextBlock x:Name="ErrorText"
                               Foreground="#C62828" FontSize="12"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Sequence (read-only) -->
                <TextBox x:Name="SequenceBox"
                         materialDesign:HintAssist.Hint="رقم التسلسل"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         IsReadOnly="True" Opacity="0.6"
                         Margin="0,0,0,14"/>

                <!-- Person name -->
                <TextBox x:Name="PersonNameBox"
                         materialDesign:HintAssist.Hint="اسم السجين *"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,14"/>

                <!-- Prisoner number -->
                <TextBox x:Name="PrisonerNumberBox"
                         materialDesign:HintAssist.Hint="رقم السجين (10 أرقام) *"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         MaxLength="10"
                         Margin="0,0,0,14"/>

                <!-- Notes -->
                <TextBox x:Name="NotesBox"
                         materialDesign:HintAssist.Hint="ملاحظات (اختياري)"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         AcceptsReturn="True"
                         Height="70"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,14"/>

                <!-- Custom fields injected in code-behind -->
                <StackPanel x:Name="CustomFieldsPanel"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Border Grid.Row="1"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0"
                Background="#F5F5F5"
                Padding="28,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="حفظ"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#1a7a60" Foreground="White"
                        Width="100" Height="38"
                        Margin="0,0,10,0"
                        Click="Save_Click"/>
                <Button Content="إلغاء"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Width="100" Height="38"
                        Click="Cancel_Click"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
