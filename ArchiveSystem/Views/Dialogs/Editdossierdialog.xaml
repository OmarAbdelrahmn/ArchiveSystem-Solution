<Window x:Class="ArchiveSystem.Views.Dialogs.EditDossierDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="تعديل بيانات الدوسية"
        Height="480" Width="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI"
        Background="#F5F5F5">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="تعديل بيانات الدوسية"
                   FontSize="18" FontWeight="Bold"
                   Foreground="#1a7a60"
                   Margin="0,0,0,20"/>

        <!-- Error -->
        <Border Grid.Row="1"
                x:Name="ErrorBorder"
                Background="#FFEBEE" BorderBrush="#EF9A9A"
                BorderThickness="1" CornerRadius="4"
                Padding="10,6" Margin="0,0,0,12"
                Visibility="Collapsed">
            <TextBlock x:Name="ErrorText"
                       Foreground="#C62828" FontSize="12"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Hijri Month + Year -->
        <Grid Grid.Row="2" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     x:Name="HijriMonthBox"
                     materialDesign:HintAssist.Hint="الشهر الهجري (1-12) *"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

            <TextBox Grid.Column="2"
                     x:Name="HijriYearBox"
                     materialDesign:HintAssist.Hint="السنة الهجرية *"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
        </Grid>

        <!-- Expected count -->
        <TextBox Grid.Row="3"
                 x:Name="ExpectedCountBox"
                 materialDesign:HintAssist.Hint="عدد الملفات المتوقع (اختياري)"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0,0,0,20"/>

        <!-- Location heading -->
        <TextBlock Grid.Row="4"
                   Text="الموقع الفيزيائي"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="#555"
                   Margin="0,0,0,10"/>

        <!-- Location fields -->
        <Grid Grid.Row="5" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     x:Name="HallwayBox"
                     materialDesign:HintAssist.Hint="ممر *"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

            <TextBox Grid.Column="2"
                     x:Name="CabinetBox"
                     materialDesign:HintAssist.Hint="كبينة *"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

            <TextBox Grid.Column="4"
                     x:Name="ShelfBox"
                     materialDesign:HintAssist.Hint="رف *"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
        </Grid>

        <TextBlock Grid.Row="6"
                   Text="تغيير الموقع هنا يُحدِّث بيانات الدوسية فقط. لتسجيل حركة رسمية استخدم 'نقل الدوسية'."
                   FontSize="11" Foreground="#999"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="0,20,0,0">
            <Button Content="حفظ"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="#1a7a60" Foreground="White"
                    Width="100" Height="38"
                    Margin="0,0,10,0"
                    Click="Save_Click"/>
            <Button Content="إلغاء"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Width="100" Height="38"
                    Click="Cancel_Click"/>
        </StackPanel>

    </Grid>
</Window>
