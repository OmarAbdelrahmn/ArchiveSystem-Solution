<Window x:Class="ArchiveSystem.Views.Dialogs.BulkFillDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="تعبئة جماعية"
        Height="360" Width="440"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        FontFamily="Noto Kufi Arabic, Segoe UI"
        Background="{StaticResource MidnightBase}">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   x:Name="TitleText"
                   Text="تعبئة حقل لعدد من السجلات"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource RoseGold}"
                   Margin="0,0,0,6"/>

        <!-- Count -->
        <TextBlock Grid.Row="1"
                   x:Name="CountText"
                   FontSize="12"
                   Foreground="{StaticResource TextSecondary}"
                   Margin="0,0,0,18"/>

        <!-- Error -->
        <Border Grid.Row="2"
                x:Name="ErrorBorder"
                CornerRadius="6"
                Padding="10,6" Margin="0,0,0,12"
                Visibility="Collapsed">
            <Border.Background>
                <SolidColorBrush Color="#FF5252" Opacity="0.10"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#FF5252" Opacity="0.35"/>
            </Border.BorderBrush>
            <Border.BorderThickness>1</Border.BorderThickness>
            <TextBlock x:Name="ErrorText"
                       Foreground="{StaticResource DangerRed}"
                       FontSize="12"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Field selector -->
        <ComboBox Grid.Row="3"
                  x:Name="FieldCombo"
                  materialDesign:HintAssist.Hint="اختر الحقل"
                  materialDesign:HintAssist.Foreground="#4A5A7A"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  DisplayMemberPath="ArabicLabel"
                  SelectedValuePath="CustomFieldId"
                  Margin="0,0,0,14"
                  SelectionChanged="FieldCombo_SelectionChanged"/>

        <!-- Value input -->
        <TextBox Grid.Row="4"
                 x:Name="ValueBox"
                 materialDesign:HintAssist.Hint="القيمة الجديدة"
                 materialDesign:HintAssist.Foreground="#4A5A7A"
                 Style="{StaticResource DarkOutlinedTextBox}"
                 Margin="0,0,0,4"/>

        <!-- Suggestions list -->
        <Border Grid.Row="5"
                x:Name="SuggestionsBorder"
                CornerRadius="6"
                MaxHeight="90"
                Margin="0,4,0,0"
                Visibility="Collapsed">
            <Border.Background>
                <SolidColorBrush Color="#0D1F3C" Opacity="0.80"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
            </Border.BorderBrush>
            <Border.BorderThickness>1</Border.BorderThickness>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="SuggestionsList"
                              Margin="4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="{StaticResource EmeraldMid}"
                                    HorizontalContentAlignment="Right"
                                    Height="30" Padding="8,0"
                                    Tag="{Binding}"
                                    Click="Suggestion_Click"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <Border Grid.Row="6"
                BorderThickness="0,1,0,0"
                Padding="0,14,0,0"
                Margin="0,16,0,0">
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
            </Border.BorderBrush>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left">
                <Button Content="تطبيق"
                        Height="38" Width="110"
                        Margin="0,0,10,0"
                        Foreground="#050D1A" FontWeight="SemiBold"
                        Click="Apply_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="6"/>
                        </Style>
                    </Button.Style>
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00BCD4" Offset="0"/>
                            <GradientStop Color="#00E676" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
                <Button Content="إلغاء"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="{StaticResource TextSecondary}"
                        Width="100" Height="38"
                        Click="Cancel_Click"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
