<Window x:Class="ArchiveSystem.Views.Dialogs.BulkFillDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="تعبئة جماعية"
        Height="460" Width="440"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        FontFamily="Noto Kufi Arabic, Segoe UI"
        Background="{StaticResource MidnightBase}">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   x:Name="TitleText"
                   Text="تعبئة حقل لعدد من السجلات"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource RoseGold}"
                   Margin="0,0,0,6"/>

        <!-- Count -->
        <TextBlock Grid.Row="1"
                   x:Name="CountText"
                   FontSize="12"
                   Foreground="{StaticResource TextSecondary}"
                   Margin="0,0,0,18"/>

        <!-- Error -->
        <Border Grid.Row="2"
                x:Name="ErrorBorder"
                CornerRadius="6"
                Padding="10,6" Margin="0,0,0,12"
                Visibility="Collapsed">
            <Border.Background>
                <SolidColorBrush Color="#FF5252" Opacity="0.10"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#FF5252" Opacity="0.35"/>
            </Border.BorderBrush>
            <Border.BorderThickness>1</Border.BorderThickness>
            <TextBlock x:Name="ErrorText"
                       Foreground="{StaticResource DangerRed}"
                       FontSize="12"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Field selector -->
        <ComboBox Grid.Row="3"
                  x:Name="FieldCombo"
                  materialDesign:HintAssist.Hint="اختر الحقل"
                  materialDesign:HintAssist.Foreground="#4A5A7A"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  DisplayMemberPath="ArabicLabel"
                  SelectedValuePath="CustomFieldId"
                  Margin="0,0,0,14"
                  SelectionChanged="FieldCombo_SelectionChanged"/>

        <!-- Value input -->
        <TextBox Grid.Row="4"
                 x:Name="ValueBox"
                 materialDesign:HintAssist.Hint="القيمة الجديدة"
                 materialDesign:HintAssist.Foreground="#4A5A7A"
                 Style="{StaticResource DarkOutlinedTextBox}"
                 Margin="0,0,0,4"/>

        <!-- Suggestions list -->
        <Border Grid.Row="5"
                x:Name="SuggestionsBorder"
                CornerRadius="8"
                Padding="8"
                Margin="0,6,0,0"
                Visibility="Collapsed">
            <Border.Background>
                <SolidColorBrush Color="#0D1F3C" Opacity="0.90"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
            </Border.BorderBrush>
            <Border.BorderThickness>1</Border.BorderThickness>

            <StackPanel>
                <TextBlock Text="اقتراحات سابقة"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondary}"
                           Margin="2,0,2,6"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="80">
                    <ItemsControl x:Name="SuggestionsList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Tag="{Binding}"
                                        Click="Suggestion_Click"
                                        Cursor="Hand"
                                        Margin="3"
                                        Padding="10,4"
                                        Height="28"
                                        Foreground="{StaticResource DarkSeaGreen}"
                                        FontSize="12">
                                    <Button.Content>
                                        <TextBlock Text="{Binding}" TextAlignment="Center"/>
                                    </Button.Content>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="#1A3A2A"/>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="BorderBrush">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="#2E6B44" Opacity="0.7"/>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="14"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <SolidColorBrush Color="#2A5A3A"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <SolidColorBrush Color="#3A7A4A"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <Border Grid.Row="6"
                BorderThickness="0,1,0,0"
                Padding="0,14,0,0"
                Margin="0,16,0,0">
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
            </Border.BorderBrush>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left">
                <Button Content="تطبيق"
                        Height="38" Width="110"
                        Margin="0,0,10,0"
                        Foreground="#050D1A" FontWeight="SemiBold"
                        Click="Apply_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="6"/>
                        </Style>
                    </Button.Style>
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#8FBC8B" Offset="0"/>
                            <GradientStop Color="#8FBC8B" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
                <Button Content="إلغاء"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="{StaticResource TextSecondary}"
                        Width="100" Height="38"
                        Click="Cancel_Click"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
