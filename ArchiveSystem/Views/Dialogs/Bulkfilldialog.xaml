<Window x:Class="ArchiveSystem.Views.Dialogs.BulkFillDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="تعبئة جماعية"
        Height="360" Width="440"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI"
        Background="#F5F5F5">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   x:Name="TitleText"
                   Text="تعبئة حقل لعدد من السجلات"
                   FontSize="17" FontWeight="Bold"
                   Foreground="#1a7a60"
                   Margin="0,0,0,6"/>

        <TextBlock Grid.Row="1"
                   x:Name="CountText"
                   FontSize="12" Foreground="#666"
                   Margin="0,0,0,18"/>

        <!-- Error -->
        <Border Grid.Row="2"
                x:Name="ErrorBorder"
                Background="#FFEBEE" BorderBrush="#EF9A9A"
                BorderThickness="1" CornerRadius="4"
                Padding="10,6" Margin="0,0,0,10"
                Visibility="Collapsed">
            <TextBlock x:Name="ErrorText"
                       Foreground="#C62828" FontSize="12"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Field selector -->
        <ComboBox Grid.Row="3"
                  x:Name="FieldCombo"
                  materialDesign:HintAssist.Hint="اختر الحقل"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  DisplayMemberPath="ArabicLabel"
                  SelectedValuePath="CustomFieldId"
                  Margin="0,0,0,14"
                  SelectionChanged="FieldCombo_SelectionChanged"/>

        <!-- Value input (plain text — field-type-aware UI can be extended later) -->
        <TextBox Grid.Row="4"
                 x:Name="ValueBox"
                 materialDesign:HintAssist.Hint="القيمة الجديدة"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0,0,0,4"/>

        <!-- Suggestions list -->
        <Border Grid.Row="5"
                x:Name="SuggestionsBorder"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="4"
                Background="White"
                MaxHeight="90"
                Margin="0,4,0,0"
                Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="SuggestionsList"
                              Margin="4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    HorizontalContentAlignment="Right"
                                    Height="30" Padding="8,0"
                                    Tag="{Binding}"
                                    Click="Suggestion_Click"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="0,16,0,0">
            <Button Content="تطبيق"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="#1a7a60" Foreground="White"
                    Width="110" Height="38"
                    Margin="0,0,10,0"
                    Click="Apply_Click"/>
            <Button Content="إلغاء"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Width="100" Height="38"
                    Click="Cancel_Click"/>
        </StackPanel>

    </Grid>
</Window>
