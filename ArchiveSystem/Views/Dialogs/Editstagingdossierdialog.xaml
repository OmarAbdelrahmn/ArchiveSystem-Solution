<Window x:Class="ArchiveSystem.Views.Dialogs.EditStagingDossierDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="تعديل بيانات الدوسية"
        Height="420" Width="440"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        FontFamily="Noto Kufi Arabic, Segoe UI"
        Background="{StaticResource MidnightBase}">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="تعديل بيانات الدوسية"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource RoseGold}"
                   Margin="0,0,0,6"/>

        <!-- Sheet info -->
        <TextBlock Grid.Row="1"
                   x:Name="SheetNameText"
                   FontSize="12"
                   Foreground="{StaticResource TextSecondary}"
                   Margin="0,0,0,4"/>

        <TextBlock Grid.Row="2"
                   x:Name="ActualCountText"
                   FontSize="12"
                   Foreground="{StaticResource EmeraldMid}"
                   Margin="0,0,0,16"/>

        <!-- Error -->
        <Border Grid.Row="3"
                x:Name="ErrorBorder"
                CornerRadius="6"
                Padding="10,6" Margin="0,0,0,12"
                Visibility="Collapsed">
            <Border.Background>
                <SolidColorBrush Color="#FF5252" Opacity="0.10"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#FF5252" Opacity="0.35"/>
            </Border.BorderBrush>
            <Border.BorderThickness>1</Border.BorderThickness>
            <TextBlock x:Name="ErrorText"
                       Foreground="{StaticResource DangerRed}"
                       FontSize="12"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Dossier Number -->
        <TextBox Grid.Row="4"
                 x:Name="DossierNumberBox"
                 materialDesign:HintAssist.Hint="رقم الدوسية *"
                 materialDesign:HintAssist.Foreground="#4A5A7A"
                 Style="{StaticResource DarkOutlinedTextBox}"
                 Margin="0,0,0,14"/>

        <!-- Hijri Month + Year -->
        <Grid Grid.Row="5" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     x:Name="HijriMonthBox"
                     materialDesign:HintAssist.Hint="الشهر الهجري (1-12) *"
                     materialDesign:HintAssist.Foreground="#4A5A7A"
                     Style="{StaticResource DarkOutlinedTextBox}"/>

            <TextBox Grid.Column="2"
                     x:Name="HijriYearBox"
                     materialDesign:HintAssist.Hint="السنة الهجرية *"
                     materialDesign:HintAssist.Foreground="#4A5A7A"
                     Style="{StaticResource DarkOutlinedTextBox}"/>
        </Grid>

        <!-- Expected Count -->
        <TextBox Grid.Row="6"
                 x:Name="ExpectedCountBox"
                 materialDesign:HintAssist.Hint="عدد الملفات المتوقع (اختياري)"
                 materialDesign:HintAssist.Foreground="#4A5A7A"
                 Style="{StaticResource DarkOutlinedTextBox}"
                 Margin="0,0,0,4"/>

        <!-- Hint text -->
        <TextBlock Grid.Row="7"
                   Text="يمكن ترك عدد الملفات فارغاً إذا لم يكن معروفاً."
                   FontSize="11"
                   Foreground="{StaticResource TextSecondary}"
                   Margin="0,0,0,0"/>

        <!-- Buttons -->
        <Border Grid.Row="9"
                BorderThickness="0,1,0,0"
                Padding="0,14,0,0"
                Margin="0,20,0,0">
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
            </Border.BorderBrush>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left">
                <Button Content="حفظ"
                        Height="38" Width="100"
                        Margin="0,0,10,0"
                        Foreground="#050D1A" FontWeight="SemiBold"
                        Click="Save_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="6"/>
                        </Style>
                    </Button.Style>
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#8FBC8B" Offset="0"/>
                            <GradientStop Color="#8FBC8B" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
                <Button Content="إلغاء"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="{StaticResource TextSecondary}"
                        Width="100" Height="38"
                        Click="Cancel_Click"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
