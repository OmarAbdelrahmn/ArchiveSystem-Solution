<Window x:Class="ArchiveSystem.Views.Dialogs.AddUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="إضافة مستخدم جديد"
        Height="480" Width="420"
        MinHeight="400"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      Padding="28,24,28,16">
            <StackPanel>

                <TextBlock Text="إضافة مستخدم جديد"
                           FontSize="18" FontWeight="Bold"
                           Foreground="#1a7a60"
                           Margin="0,0,0,20"/>

                <Border x:Name="ErrorBorder"
                        Background="#FFEBEE" BorderBrush="#EF9A9A"
                        BorderThickness="1" CornerRadius="4"
                        Padding="10,6" Margin="0,0,0,12"
                        Visibility="Collapsed">
                    <TextBlock x:Name="ErrorText"
                               Foreground="#C62828" FontSize="12"
                               TextWrapping="Wrap"/>
                </Border>

                <TextBox x:Name="FullNameBox"
                         materialDesign:HintAssist.Hint="الاسم الكامل *"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="20,0,20,14" TextChanged="FullNameBox_TextChanged"/>

                <TextBox x:Name="UsernameBox"
                         materialDesign:HintAssist.Hint="اسم المستخدم *"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="20,0,20,14"/>

                <TextBox x:Name="EmployeeNumberBox"
                         materialDesign:HintAssist.Hint="رقم الموظف (اختياري)"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="20,0,20,14"/>

                <PasswordBox x:Name="PasswordBox"
                             materialDesign:HintAssist.Hint="كلمة المرور * (6 أحرف على الأقل)"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             Margin="20,0,20,14"/>

                <ComboBox x:Name="RoleCombo"
                          materialDesign:HintAssist.Hint="الدور *"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="RoleName"
                          SelectedValuePath="RoleId"
                          Margin="20,0,20,8"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Fixed buttons at bottom -->
        <Border Grid.Row="1"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0"
                Background="#F5F5F5"
                Padding="28,14">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left">
                <Button Content="إضافة"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#1a7a60" Foreground="White"
                        Width="100" Height="38"
                        Margin="0,0,10,0"
                        Click="AddButton_Click"/>
                <Button Content="إلغاء"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Width="100" Height="38"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>