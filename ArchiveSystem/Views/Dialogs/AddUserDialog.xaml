<!-- AddUserDialog.xaml -->
<Window x:Class="ArchiveSystem.Views.Dialogs.AddUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="إضافة مستخدم جديد"
        Height="480" Width="420"
        MinHeight="400"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        FontFamily="Noto Kufi Arabic, Segoe UI"
        Background="{StaticResource MidnightBase}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      Padding="28,24,28,16">
            <StackPanel>

                <TextBlock Text="إضافة مستخدم جديد"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource RoseGold}"
                           Margin="0,0,0,20"/>

                <Border x:Name="ErrorBorder"
                        CornerRadius="6"
                        Padding="10,6" Margin="0,0,0,12"
                        Visibility="Collapsed">
                    <Border.Background>
                        <SolidColorBrush Color="#FF5252" Opacity="0.10"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#FF5252" Opacity="0.35"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <TextBlock x:Name="ErrorText"
                               Foreground="{StaticResource DangerRed}"
                               FontSize="12" TextWrapping="Wrap"/>
                </Border>

                <TextBox x:Name="FullNameBox"
                         materialDesign:HintAssist.Hint="الاسم الكامل *"
                         materialDesign:HintAssist.Foreground="#4A5A7A"
                         Style="{StaticResource DarkOutlinedTextBox}"
                         Margin="20,0,20,14"/>

                <TextBox x:Name="UsernameBox"
                         materialDesign:HintAssist.Hint="اسم المستخدم *"
                         materialDesign:HintAssist.Foreground="#4A5A7A"
                         Style="{StaticResource DarkOutlinedTextBox}"
                         Margin="20,0,20,14"/>

                <TextBox x:Name="EmployeeNumberBox"
                         materialDesign:HintAssist.Hint="رقم الموظف (اختياري)"
                         materialDesign:HintAssist.Foreground="#4A5A7A"
                         Style="{StaticResource DarkOutlinedTextBox}"
                         Margin="20,0,20,14"/>

                <PasswordBox x:Name="PasswordBox"
                             materialDesign:HintAssist.Hint="كلمة المرور * (6 أحرف على الأقل)"
                             materialDesign:HintAssist.Foreground="#4A5A7A"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             Margin="20,0,20,14"/>

                <ComboBox x:Name="RoleCombo"
                          materialDesign:HintAssist.Hint="الدور *"
                          materialDesign:HintAssist.Foreground="#4A5A7A"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="RoleName"
                          SelectedValuePath="RoleId"
                          Margin="20,0,20,8"/>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1"
                BorderThickness="0,1,0,0"
                Padding="28,14">
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E3050" Opacity="0.80"/>
            </Border.BorderBrush>
            <Border.Background>
                <SolidColorBrush Color="#0A1628" Opacity="0.60"/>
            </Border.Background>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="إضافة"
                        Height="38" Width="100"
                        Margin="0,0,10,0"
                        Foreground="#050D1A" FontWeight="SemiBold"
                        Click="AddButton_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="6"/>
                        </Style>
                    </Button.Style>
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#8FBC8B" Offset="0"/>
                            <GradientStop Color="#8FBC8B" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
                <Button Content="إلغاء"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="{StaticResource TextSecondary}"
                        Width="100" Height="38"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
