<Window x:Class="ArchiveSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="أرشفة الوثائق DMS DMS"
        Height="700" Width="1100"
        MinHeight="500" MinWidth="800"
        FlowDirection="RightToLeft"
        FontFamily="Noto Kufi Arabic, Segoe UI"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}">
    <!-- Icon="pack://application:,,,/Assets/app.ico" -->
    <!-- Uncomment the Icon attribute above after placing app.ico in the Assets folder -->

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarCol" Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#1a7a60">
            <DockPanel>

                <!-- App title -->
                <StackPanel DockPanel.Dock="Top" Margin="0,24,0,24">
                    <TextBlock Text="أرشفة الوثائق"
                               Foreground="White"
                               FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="DMS"
                               Foreground="#aaffdd" FontSize="13"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Nav buttons -->
                <StackPanel DockPanel.Dock="Top" Margin="8,0">

                    <Button x:Name="NavSearchButton"
                            Content="🔍   البحث"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White" FontSize="14"
                            HorizontalContentAlignment="Right"
                            Height="46" Margin="0,2"
                            Click="NavSearch_Click"/>

                    <Button x:Name="NavEntryButton"
                            Content="➕   إدخال بيانات"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White" FontSize="14"
                            HorizontalContentAlignment="Right"
                            Height="46" Margin="0,2"
                            Click="NavEntry_Click"/>

                    <Button x:Name="NavAllDataButton"
                            Content="📋   كل البيانات"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White" FontSize="14"
                            HorizontalContentAlignment="Right"
                            Height="46" Margin="0,2"
                            Click="NavAllData_Click"/>

                    <Button x:Name="NavStatsButton"
                            Content="📊   الإحصاءات"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White" FontSize="14"
                            HorizontalContentAlignment="Right"
                            Height="46" Margin="0,2"
                            Click="NavStats_Click"/>

                    <Button x:Name="NavImportButton"
                            Content="📥   استيراد Excel"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White" FontSize="14"
                            HorizontalContentAlignment="Right"
                            Height="46" Margin="0,2"
                            Click="NavImport_Click"/>

                    <Button x:Name="NavManagementButton"
                            Content="🏢   الإدارة"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White" FontSize="14"
                            HorizontalContentAlignment="Right"
                            Height="46" Margin="0,2"
                            Click="NavManagement_Click"/>

                    <Button x:Name="NavReportsButton"
                            Content="🖨️   التقارير"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White" FontSize="14"
                            HorizontalContentAlignment="Right"
                            Height="46" Margin="0,2"
                            Click="NavReports_Click"/>

                    <Button x:Name="NavSuggestionsButton"
                            Content="💡   الاقتراحات"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White" FontSize="14"
                            HorizontalContentAlignment="Right"
                            Height="46" Margin="0,2"
                            Click="NavSuggestions_Click"/>

                    <Button x:Name="NavAuditLogButton"
                            Content="📜   سجل الاحداث"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White" FontSize="14"
                            HorizontalContentAlignment="Right"
                            Height="46" Margin="0,2"
                            Click="NavAuditLog_Click"/>

                    <Button x:Name="NavBulkHistoryButton"
                            Content="📝   التعبئة الجماعية"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White" FontSize="14"
                            HorizontalContentAlignment="Right"
                            Height="46" Margin="0,2"
                            Click="NavBulkHistory_Click"/>

                    <Button x:Name="NavSettingsButton"
                            Content="⚙️   الإعدادات"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White" FontSize="14"
                            HorizontalContentAlignment="Right"
                            Height="46" Margin="0,2"
                            Click="NavSettings_Click"/>

                </StackPanel>

                <Border DockPanel.Dock="Bottom"
                        BorderThickness="0,1,0,0"
                        BorderBrush="#2a8a70"
                        Padding="12,10">
                            <StackPanel>
                                <TextBlock x:Name="CurrentUserText"
                       Foreground="#ccffee" FontSize="12"
                       HorizontalAlignment="Center"/>
                                <TextBlock x:Name="CurrentUserRoleText"
                       Foreground="#aaddcc" FontSize="11"
                       HorizontalAlignment="Center"
                       Margin="0,2,0,0"/>
                                <TextBlock x:Name="AppVersionText"
                       Foreground="#5a9a80" FontSize="10"
                       HorizontalAlignment="Center"
                       Margin="0,3,0,0"/>
                                <Button Content="🚪  تسجيل الخروج"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="#ffccaa"
                    FontSize="12"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    Margin="0,6,0,0"
                    Click="Logout_Click"/>
                    </StackPanel>
                </Border>

            </DockPanel>
        </Border>

        <!-- CONTENT AREA -->
        <Frame Grid.Column="1"
               x:Name="MainFrame"
               NavigationUIVisibility="Hidden"/>

    </Grid>
</Window>
