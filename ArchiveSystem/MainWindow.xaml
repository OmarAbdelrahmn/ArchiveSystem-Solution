<Window x:Class="ArchiveSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="أرشيف الملفات"
        Height="700" Width="1100"
        MinHeight="500" MinWidth="800"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#1a7a60">
            <DockPanel>

                <!-- App title -->
                <StackPanel DockPanel.Dock="Top" Margin="0,24,0,24">
                    <TextBlock Text="أرشيف الملفات"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="النظام غير متصل بالإنترنت"
                               Foreground="#aaffdd"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Nav buttons -->
                <StackPanel DockPanel.Dock="Top" Margin="8,0">

                    <Button Content="🔍   البحث"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White" FontSize="14"
                            HorizontalContentAlignment="Right"
                            Height="46" Margin="0,2"
                            Click="NavSearch_Click"/>

                    <Button Content="➕   إدخال بيانات"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White" FontSize="14"
                            HorizontalContentAlignment="Right"
                            Height="46" Margin="0,2"
                            Click="NavEntry_Click"/>

                    <Button Content="📋   كل البيانات"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White" FontSize="14"
                            HorizontalContentAlignment="Right"
                            Height="46" Margin="0,2"
                            Click="NavAllData_Click"/>

                    <Button Content="📊   الإحصاءات"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White" FontSize="14"
                            HorizontalContentAlignment="Right"
                            Height="46" Margin="0,2"
                            Click="NavStats_Click"/>

                    <Button Content="📥   استيراد Excel"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White" FontSize="14"
                            HorizontalContentAlignment="Right"
                            Height="46" Margin="0,2"
                            Click="NavImport_Click"/>

                    <Button Content="🖨️   التقارير"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White" FontSize="14"
                            HorizontalContentAlignment="Right"
                            Height="46" Margin="0,2"
                            Click="NavReports_Click"/>

                    <Button Content="📜   سجل المراجعة"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White" FontSize="14"
                            HorizontalContentAlignment="Right"
                            Height="46" Margin="0,2"
                            Click="NavAuditLog_Click"/>

                    <Button Content="⚙️   الإعدادات"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White" FontSize="14"
                            HorizontalContentAlignment="Right"
                            Height="46" Margin="0,2"
                            Click="NavSettings_Click"/>

                </StackPanel>

                <!-- Logged-in user footer -->
                <Border DockPanel.Dock="Bottom"
                        BorderThickness="0,1,0,0"
                        BorderBrush="#2a8a70"
                        Padding="12,10">
                    <TextBlock x:Name="CurrentUserText"
                               Text="مدير الأرشيف"
                               Foreground="#ccffee"
                               FontSize="12"
                               HorizontalAlignment="Center"/>
                </Border>

            </DockPanel>
        </Border>

        <!-- CONTENT AREA -->
        <Frame Grid.Column="1"
               x:Name="MainFrame"
               NavigationUIVisibility="Hidden"/>

    </Grid>
</Window>
