<Window x:Class="ArchiveSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="موثق"
        Height="700" Width="1100"
        MinHeight="500" MinWidth="800"
        FlowDirection="RightToLeft"
        FontFamily="Amiri, Segoe UI"
        Icon="pack://application:,,,/Assets/app.ico"
        TextElement.Foreground="{DynamicResource TextPrimary}"
        Background="{DynamicResource MidnightBase}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarCol" Width="235"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR with padding for floating effect -->
        <Border Grid.Column="0"
                Padding="10"
                Background="{StaticResource MidnightDeep}">

            <!-- Glassmorphism sidebar card -->
            <Border Background="#0D1A30"
                    CornerRadius="16"
                    ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect Direction="270"
                                      ShadowDepth="6"
                                      BlurRadius="24"
                                      Opacity="0.6"
                                      Color="#000000"/>
                </Border.Effect>

                <!-- Subtle rose gold left accent line -->
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#C9956A"     Offset="0.4"/>
                        <GradientStop Color="#C9956A"     Offset="0.6"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.BorderThickness>1,0,0,0</Border.BorderThickness>

                <!-- Use a ScrollViewer so nav doesn't clip on small screens -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel VerticalAlignment="Top">

                        <!-- Logo / Title area -->
                        <StackPanel Margin="0,28,0,24">

                            <!-- Rose gold top divider -->
                            <Border Height="2" Width="120" HorizontalAlignment="Center"
                                    CornerRadius="1" Margin="0,0,0,16">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="Transparent" Offset="0"/>
                                        <GradientStop Color="#C9956A"     Offset="0.5"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <TextBlock Text="موثق"
                                       Foreground="#E8EDF5"
                                       FontSize="17" FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="DMS"
                                       FontSize="12" FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,3,0,0">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#C9956A" Offset="0"/>
                                        <GradientStop Color="#DDB48E" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </StackPanel>

                        <!-- Nav buttons -->
                        <StackPanel Margin="8,0">

                            <Button x:Name="NavSearchButton"
                                    Content="🔍   البحث"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="#8A9BB8" FontSize="13"
                                    HorizontalContentAlignment="Left"
                                    Height="44" Margin="0,2"
                                    Click="NavSearch_Click"/>

                            <Button x:Name="NavEntryButton"
                                    Content="➕   إدخال بيانات"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="#8A9BB8" FontSize="13"
                                    HorizontalContentAlignment="Left"
                                    Height="44" Margin="0,2"
                                    Click="NavEntry_Click"/>

                            <Button x:Name="NavAllDataButton"
                                    Content="📋   كل البيانات"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="#8A9BB8" FontSize="13"
                                    HorizontalContentAlignment="Left"
                                    Height="44" Margin="0,2"
                                    Click="NavAllData_Click"/>

                            <Button x:Name="NavStatsButton"
                                    Content="📊   الإحصائيات"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="#8A9BB8" FontSize="13"
                                    HorizontalContentAlignment="Left"
                                    Height="44" Margin="0,2"
                                    Click="NavStats_Click"/>

                            <Button x:Name="NavImportButton"
                                    Content="📥   استيراد Excel"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="#8A9BB8" FontSize="13"
                                    HorizontalContentAlignment="Left"
                                    Height="44" Margin="0,2"
                                    Click="NavImport_Click"/>

                            <Button x:Name="NavManagementButton"
                                    Content="🏢   الإدارات"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="#8A9BB8" FontSize="13"
                                    HorizontalContentAlignment="Left"
                                    Height="44" Margin="0,2"
                                    Click="NavManagement_Click"/>

                            <Button x:Name="NavReportsButton"
                                    Content="🖨️   التقارير"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="#8A9BB8" FontSize="13"
                                    HorizontalContentAlignment="Left"
                                    Height="44" Margin="0,2"
                                    Click="NavReports_Click"/>

                            <Button x:Name="NavSuggestionsButton"
                                    Content="💡   الاقتراحات"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="#8A9BB8" FontSize="13"
                                    HorizontalContentAlignment="Left"
                                    Height="44" Margin="0,2"
                                    Click="NavSuggestions_Click"/>

                            <Button x:Name="NavAuditLogButton"
                                    Content="📜   سجل الاحداث"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="#8A9BB8" FontSize="13"
                                    HorizontalContentAlignment="Left"
                                    Height="44" Margin="0,2"
                                    Click="NavAuditLog_Click"/>

                            <Button x:Name="NavBulkHistoryButton"
                                    Content="📝   التعبئة الجماعية"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="#8A9BB8" FontSize="13"
                                    HorizontalContentAlignment="Left"
                                    Height="44" Margin="0,2"
                                    Click="NavBulkHistory_Click"/>

                            <Button x:Name="NavSettingsButton"
                                    Content="⚙️   الإعدادات"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="#8A9BB8" FontSize="13"
                                    HorizontalContentAlignment="Left"
                                    Height="44" Margin="0,2"
                                    Click="NavSettings_Click"/>

                        </StackPanel>

                        <!-- Divider -->
                        <Border Height="1" Margin="16,12,16,12">
                            <Border.Background>
                                <SolidColorBrush Color="#C9956A" Opacity="0.15"/>
                            </Border.Background>
                        </Border>

                        <!-- Bottom user info — sits right after nav, no stretching -->
                        <Border Margin="8,0,8,12"
                                CornerRadius="10"
                                Padding="12,12">
                            <Border.Background>
                                <SolidColorBrush Color="#0A1628" Opacity="0.8"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#C9956A" Opacity="0.25"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <StackPanel>
                                <TextBlock x:Name="CurrentUserText"
                                           Foreground="#C9956A" FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="CurrentUserRoleText"
                                           Foreground="#8A9BB8" FontSize="11"
                                           HorizontalAlignment="Center"
                                           Margin="0,2,0,0"/>
                                <TextBlock x:Name="AppVersionText"
                                           Foreground="#4A5A7A" FontSize="10"
                                           HorizontalAlignment="Center"
                                           Margin="0,3,0,8"/>
                                <Button Content="🚪  تسجيل الخروج"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Foreground="#FF5252"
                                        FontSize="12"
                                        Height="32"
                                        HorizontalAlignment="Stretch"
                                        Click="Logout_Click"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

            </Border>
        </Border>

        <!-- CONTENT AREA — midnight background -->
        <Border Grid.Column="1" Background="{StaticResource MidnightBase}">
            <Frame x:Name="MainFrame"
                   NavigationUIVisibility="Hidden"
                   Background="Transparent"/>
        </Border>

    </Grid>
</Window>
